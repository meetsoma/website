---
import { ViewTransitions } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Starfield from '../components/Starfield.astro';
import Sky from '../components/Sky.astro';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, any>;
  ogType?: string;
  ogImage?: string;
}

const {
  title,
  description = "Soma — An AI agent that grows with you. Memory that persists. Identity that evolves.",
  canonicalUrl = Astro.url.href.replace(/\/$/, '') || "https://soma.gravicity.ai",
  jsonLd,
  ogType = "website",
  ogImage,
} = Astro.props;

const ogImageUrl = ogImage
  ? `https://soma.gravicity.ai${ogImage}`
  : "https://soma.gravicity.ai/og-image.png";

// Default JSON-LD: SoftwareApplication (shows on all pages if no override)
const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Soma',
  description: 'An AI agent that grows with you. Memory that persists across sessions. Identity that evolves through use.',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Linux, Windows',
  url: 'https://soma.gravicity.ai',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Organization',
    name: 'Gravicity',
    url: 'https://gravicity.ai',
  },
};

const schemaData = jsonLd || defaultJsonLd;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="Soma Blog" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts: Clash Display + Satoshi from Fontshare -->
    <link rel="preconnect" href="https://api.fontshare.com">
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin>
    <link href="https://api.fontshare.com/v2/css?f[]=clash-display@700,600,500&f[]=satoshi@400,500,700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet">

    <title>{title}</title>
    <ViewTransitions />

    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

    <script is:inline>
      (() => {
        const saved = localStorage.getItem('soma-theme');
        const theme = saved === 'light' || saved === 'dark' ? saved : 'dark';
        document.documentElement.classList.add('no-transition');
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            document.documentElement.classList.remove('no-transition');
          });
        });
      })();
    </script>

    <style is:global>
      :root {
        /* ── Design System Tokens ── */

        /* Spacing — Fibonacci scale (px) */
        --space-xs: 0.188rem;   /* 3px */
        --space-sm: 0.313rem;   /* 5px */
        --space-md: 0.5rem;     /* 8px */
        --space-lg: 0.813rem;   /* 13px */
        --space-xl: 1.313rem;   /* 21px */
        --space-2xl: 2.125rem;  /* 34px */
        --space-3xl: 3.438rem;  /* 55px */
        --space-4xl: 5.563rem;  /* 89px */

        /* Typography — 8-step scale */
        --text-xs: 0.813rem;   /* badges, tags */
        --text-sm: 0.938rem;   /* labels, metadata */
        --text-base: 0.938rem; /* secondary body */
        --text-md: 1rem;       /* body default */
        --text-lg: 1.125rem;   /* subheadings */
        --text-xl: 1.25rem;    /* section heads */
        --text-2xl: 1.5rem;    /* page subheads */
        --text-3xl: 2.25rem;   /* page titles */

        /* Semantic aliases — change these to adjust all body/card/section text */
        --body-text: var(--text-md);        /* descriptions, paragraphs, card body */
        --body-secondary: var(--text-base); /* secondary body, less prominent */
        --label-text: var(--text-sm);       /* metadata, dates, author names */
        --badge-text: var(--text-xs);       /* tags, tier badges, version numbers */

        /* List-specific */
        --list-text: var(--text-base);      /* list items — slightly smaller than body */
        --list-leading: var(--leading-normal); /* tighter line-height for lists */

        /* Content widths */
        --content-narrow: 560px;            /* subtitle, intro text — readable line length */
        --content-wide: 610px;              /* description blocks — slightly wider */
        --card-pad-y: var(--space-2xl);     /* vertical card padding */
        --card-pad-x: var(--space-xl);      /* horizontal card padding */
        --section-gap: var(--space-3xl);    /* gap between major sections */
        --grid-gap: var(--space-xl);        /* gap between grid cards */

        /* Line-heights */
        --leading-none: 1;
        --leading-tight: 1.2;
        --leading-normal: 1.4;
        --leading-relaxed: 1.618;
        --leading-loose: 1.8;

        /* Border-radii */
        --radius-sm: 4px;
        --radius-md: 8px;
        --radius-lg: 13px;
        --radius-xl: 21px;
        --radius-full: 9999px;

        /* Soma deep space palette */
        --bg-deep: #0C0F16;
        --bg-surface: #0b1018;
        --bg-elevated: #121a28;

        /* Soma accent — canonical #7cb2d4, aligned with Somaverse workspace */
        --accent-bright: #7cb2d4;
        --accent-mid: #5282a8;
        --accent-dark: #3e6c92;

        /* Moon accent — warm complement */
        --moon-bright: #7cb2d4;
        --moon-mid: #669cc0;
        --moon-glow: rgba(124, 178, 212, 0.4);

        /* Signal warmth — for CTAs, highlights */
        --warm-bright: #e8a87c;
        --warm-mid: #d4926a;
        --warm-glow: rgba(232, 168, 124, 0.3);

        /* Promo / Genesis — golden accent, may evolve */
        --promo: #f0c866;
        --promo-dim: #c4a24e;
        --promo-glow: rgba(240, 200, 102, 0.15);
        --promo-border: rgba(240, 200, 102, 0.25);

        /* Text */
        --text-primary: #e4eaf4;
        --text-secondary: #9dafc4;
        --blog-body: #94a3b8;
        --text-muted: #647080;

        /* Borders */
        --border-subtle: rgba(132, 148, 170, 0.12);
        --border-accent: rgba(104, 152, 190, 0.3);

        /* Surfaces */
        --surface-card: rgba(11, 16, 24, 0.7);
        --surface-card-strong: rgba(11, 16, 24, 0.85);
        --surface-overlay: rgba(0, 0, 0, 0.3);
        --surface-interactive: rgba(255, 255, 255, 0.06);
        --surface-interactive-hover: rgba(255, 255, 255, 0.12);
        --surface-accent-soft: rgba(104, 152, 190, 0.12);
        --surface-warm-soft: rgba(232, 168, 124, 0.1);
        --surface-inset-highlight: rgba(255, 255, 255, 0.04);

        /* Shadows */
        --shadow-accent-soft: rgba(104, 152, 190, 0.15);
        --shadow-accent-mid: rgba(104, 152, 190, 0.25);
        --shadow-warm-soft: rgba(232, 168, 124, 0.15);

        /* Hero gradient */
        --hero-title-start: #e4eaf4;
        --hero-title-end: #7cb2d4;

        /* Logo */
        --logo-glow: rgba(104, 152, 190, 0.35);
        --logo-glow-hover: rgba(124, 178, 212, 0.5);

        /* Fonts */
        --font-display: 'Manrope', system-ui, sans-serif;
        --font-body: 'Satoshi', system-ui, sans-serif;
        --font-mono: 'SF Mono', 'Fira Code', 'JetBrains Mono', monospace;
      }

      html[data-theme='light'] {
        /* Light theme: "cloud cover at dawn" — daytime counterpart to the
         * dark theme's "deep space." Pale sky + soft warm undertone, not
         * stark office-white. Cycle 17 (s01-7b287c) palette rework:
         * Old #f4f6f9 was a cool gray with no atmosphere. New palette mixes
         * pale dawn blue with a hint of warmth so cards (off-white) read as
         * "sun on snow" against a sky-mist background. */
        --bg-deep: #e8eef5;       /* pale dawn sky — base atmosphere */
        --bg-surface: #fafbfc;    /* near-white cloud, with cool undertone */
        --bg-elevated: #dde5f0;   /* deeper cloud edge */

        /* Deeper accent tones for readability */
        --accent-bright: #2e6094;
        --accent-mid: #245080;
        --accent-dark: #1a3d66;

        --moon-bright: #3878a0;
        --moon-mid: #2d6888;
        --moon-glow: rgba(46, 96, 148, 0.2);

        --warm-bright: #a85a2a;
        --warm-mid: #8e4820;
        --warm-glow: rgba(168, 90, 42, 0.18);

        /* Dark text for real contrast */
        --text-primary: #0a0f1a;
        --text-secondary: #2a3648;
        --blog-body: #3a4d63;
        --text-muted: #4a5a70;

        /* Visible borders */
        --border-subtle: rgba(10, 15, 26, 0.18);
        --border-accent: rgba(46, 96, 148, 0.35);

        /* Cards: warm cloud-white. Off-white not stark white — cards
         * feel like sun on snow against the pale sky bg. */
        --surface-card: rgba(252, 253, 254, 0.92);
        --surface-card-strong: rgba(250, 252, 253, 1);
        --surface-overlay: rgba(100, 120, 145, 0.22);
        --surface-interactive: rgba(10, 15, 26, 0.08);
        --surface-interactive-hover: rgba(10, 15, 26, 0.14);
        --surface-accent-soft: rgba(46, 96, 148, 0.1);
        --surface-warm-soft: rgba(168, 90, 42, 0.08);
        --surface-inset-highlight: rgba(10, 15, 26, 0.06);

        /* Visible shadows */
        --shadow-accent-soft: rgba(46, 96, 148, 0.2);
        --shadow-accent-mid: rgba(46, 96, 148, 0.32);
        --shadow-warm-soft: rgba(168, 90, 42, 0.18);

        --hero-title-start: #1a3d66;
        --hero-title-end: #2e6094;

        --logo-glow: rgba(46, 96, 148, 0.15);
        --logo-glow-hover: rgba(46, 96, 148, 0.28);
      }

      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
        /* Slow theme crossfade — let eyes adjust */
        transition: background-color 0.8s ease, color 0.6s ease;
      }

      body {
        font-family: var(--font-body);
        background: var(--bg-deep);
        color: var(--text-primary);
        line-height: var(--leading-relaxed);
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        transition: background-color 0.8s ease, color 0.6s ease;
      }

      /* Theme transition on all surfaces */
      *:not(script):not(style) {
        transition:
          background-color 0.6s ease,
          border-color 0.5s ease,
          color 0.5s ease,
          box-shadow 0.5s ease;
      }

      /* Disable transition on first load (prevent flash) */
      html.no-transition,
      html.no-transition *,
      html.no-transition *::before,
      html.no-transition *::after {
        transition: none !important;
      }

      ::selection {
        background: var(--accent-bright);
        color: var(--bg-deep);
      }

      /* ── Noise overlay ── */
      .noise-overlay {
        pointer-events: none;
        position: fixed;
        inset: 0;
        z-index: 1;
        opacity: 0.04;
        mix-blend-mode: overlay;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      }

      /* Cloud-puff noise: bumped + multiply blend so it textures the
       * pale sky as overcast atmosphere, not flat paper (cycle 17). */
      html[data-theme='light'] .noise-overlay { opacity: 0.05; mix-blend-mode: multiply; }

      /* ── Glow orbs ── */
      .glow-orbs {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
      }

      .glow-orb {
        position: absolute;
        border-radius: 50%;
        mix-blend-mode: screen;
      }

      .glow-orb-1 {
        top: -10%;
        left: 10%;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(104, 152, 190, 0.12) 0%, transparent 70%);
        animation: orbDrift1 25s ease-in-out infinite;
      }

      .glow-orb-2 {
        bottom: -5%;
        right: 5%;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, rgba(124, 178, 212, 0.10) 0%, transparent 70%);
        animation: orbDrift2 30s ease-in-out infinite;
      }

      .glow-orb-3 {
        top: 40%;
        right: 25%;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(232, 168, 124, 0.07) 0%, transparent 70%);
        animation: orbDrift3 35s ease-in-out infinite;
      }

      @keyframes orbDrift1 {
        0%, 100% { transform: translate(0, 0); }
        33% { transform: translate(40px, 30px); }
        66% { transform: translate(-20px, 50px); }
      }

      @keyframes orbDrift2 {
        0%, 100% { transform: translate(0, 0); }
        33% { transform: translate(-30px, -40px); }
        66% { transform: translate(25px, -20px); }
      }

      @keyframes orbDrift3 {
        0%, 100% { transform: translate(0, 0); }
        50% { transform: translate(-35px, 25px); }
      }

      /* Cycle 17 (s01-7b287c) refined per Curtis: "more blue and the whispy
       * touch of clouds a bit like the highlights in dark but different
       * shaped thin wide ovalish."
       *
       * Glow orbs become WISPY HORIZONTAL CLOUD STREAKS in light mode.
       * Where dark theme has circular nebula orbs, light theme stretches them
       * into thin wide ellipses (like cirrus clouds drawn across the sky).
       * Bluer palette overall — cool-dominant with one rare warm wisp. */
      html[data-theme='light'] .glow-orbs { opacity: 0.65; }
      html[data-theme='light'] .glow-orb {
        mix-blend-mode: multiply;
        /* Stretch circles into wide ellipses — wispy cloud streaks */
        border-radius: 50%;
        transform: scale(1.6, 0.35) rotate(-8deg);
      }
      html[data-theme='light'] .glow-orb-1 {
        /* main blue cirrus — upper sky */
        background: radial-gradient(ellipse, rgba(46, 96, 148, 0.16) 0%, rgba(46, 96, 148, 0.04) 50%, transparent 75%);
        transform: scale(1.7, 0.3) rotate(-6deg);
      }
      html[data-theme='light'] .glow-orb-2 {
        /* deeper blue mid — wider streak */
        background: radial-gradient(ellipse, rgba(46, 96, 148, 0.14) 0%, rgba(46, 96, 148, 0.03) 55%, transparent 80%);
        transform: scale(2.0, 0.32) rotate(4deg);
      }
      html[data-theme='light'] .glow-orb-3 {
        /* warm wisp — sun-touched cloud edge, RARE accent */
        background: radial-gradient(ellipse, rgba(232, 168, 124, 0.10) 0%, rgba(232, 168, 124, 0.02) 60%, transparent 80%);
        transform: scale(1.5, 0.28) rotate(-12deg);
      }


      @media (prefers-reduced-motion: reduce) {
        .glow-orb { animation: none !important; }
      }

      /* Cycle 17 (s01-7b287c): Shiki dual-theme hook. astro.config.mjs ships
       * code blocks with CSS vars (--shiki-light, --shiki-dark) on every span.
       * Default render uses the dark color (we set in dark theme). In light
       * theme, swap each color var. Without this, code blocks stay dark on a
       * near-white page background — jarring slabs of darkness. */
      html[data-theme='light'] code,
      html[data-theme='light'] code span {
        color: var(--shiki-light) !important;
        background-color: var(--shiki-light-bg, transparent) !important;
        font-style: var(--shiki-light-font-style) !important;
        font-weight: var(--shiki-light-font-weight) !important;
        text-decoration: var(--shiki-light-text-decoration) !important;
      }
      /* The pre wrapper around code blocks gets its own bg from Shiki */
      html[data-theme='light'] pre.astro-code,
      html[data-theme='light'] pre[class*="language-"] {
        background-color: #f6f8fa !important;
        border: 1px solid var(--border-subtle);
      }

      /* Content offset for fixed nav */
      .site-content {
        padding-top: 55px;
      }

      /* Skip to content — visible on focus only */
      .skip-to-content {
        position: absolute;
        top: -100%;
        left: var(--space-lg);
        z-index: 200;
        padding: var(--space-md) var(--space-xl);
        background: var(--accent-bright);
        color: var(--bg-deep);
        font-family: var(--font-body);
        font-size: var(--label-text);
        font-weight: 600;
        border-radius: var(--radius-md);
        text-decoration: none;
        transition: top 0.2s ease;
      }

      .skip-to-content:focus {
        top: var(--space-md);
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      /* Theme toggle styles are in Nav.astro */
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>

    <!-- Atmospheric layers -->
    <Starfield />
    <Sky />
    <div class="noise-overlay"></div>
    <div class="glow-orbs" aria-hidden="true">
      <div class="glow-orb glow-orb-1"></div>
      <div class="glow-orb glow-orb-2"></div>
      <div class="glow-orb glow-orb-3"></div>
    </div>

    <Nav />
    <div class="site-content" id="main-content">
      <slot />
    </div>
    <Footer />

    <!-- Vercel Analytics — privacy-respecting, no cookies -->
    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>

    <script>
      // Cycle 17 (s01-7b287c): theme toggle as a CINEMATIC TIME-LAPSE.
      // Curtis's vision: "stars could slide out of view and in comes the
      // orange/blue then daylight hue of the sky as if time just
      // fast-forwarded to day." Refactored per gsap-skills (gsap-core +
      // gsap-timeline) — uses autoAlpha (not opacity), transform aliases,
      // gsap.matchMedia for reduced-motion, position parameter with labels.
      //
      // Timeline labels:
      //   stars-buzz   (0.0): stars warp out / settle in (lateral + vertical drift boost)
      //   sky-sweep    (0.2): horizon glow sweeps from one side, sun spins in/out
      //   palette-swap (0.7): data-theme swap mid-sequence, dispatch settled event
      //   settle       (1.0): horizon clears inline, idle CSS rule resumes
      //
      // Honors prefers-reduced-motion via gsap.matchMedia.
      import { gsap } from 'gsap';

      const KEY = 'soma-theme';
      let transitioning = false;

      function initThemeToggle() {
        const root = document.documentElement;
        const toggle = document.querySelector('.theme-toggle');
        if (!toggle) return;

        // Apply saved theme on first load (no transition — instant)
        const saved = localStorage.getItem(KEY);
        const initial = saved === 'light' || saved === 'dark' ? saved : (root.dataset.theme || 'dark');
        root.dataset.theme = initial;
        (root.style as any).colorScheme = initial;
        toggle.setAttribute('aria-label', initial === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');

        // Remove old listener (view transitions re-run init)
        const newToggle = toggle.cloneNode(true) as HTMLElement;
        toggle.parentNode!.replaceChild(newToggle, toggle);
        newToggle.addEventListener('click', handleToggle);
      }

      function applyTheme(theme: string) {
        const root = document.documentElement;
        root.dataset.theme = theme;
        (root.style as any).colorScheme = theme;
        const toggle = document.querySelector('.theme-toggle');
        toggle?.setAttribute('aria-label', theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
        localStorage.setItem(KEY, theme);
        window.dispatchEvent(new CustomEvent('soma-theme', { detail: { theme } }));
      }

      function handleToggle() {
        if (transitioning) return;
        const root = document.documentElement;
        const next = root.dataset.theme === 'light' ? 'dark' : 'light';

        // gsap.matchMedia handles reduced-motion declaratively per skill guidance.
        const mm = gsap.matchMedia();
        mm.add({
          fullCinematic: '(prefers-reduced-motion: no-preference)',
          reduced: '(prefers-reduced-motion: reduce)'
        }, (ctx) => {
          const { reduced } = ctx.conditions!;
          if (reduced) {
            applyTheme(next);
          } else {
            runTransition(next);
          }
          return () => mm.revert();
        });
      }

      function runTransition(toTheme: string) {
        transitioning = true;
        const root = document.documentElement;
        const horizon = document.querySelector('.sky-horizon') as HTMLElement | null;
        const isSunrise = toTheme === 'light';

        // Sunrise: warm yellow → orange → red → indigo, anchored to bottom-right.
        // Sunset: orange → violet → deep indigo, same anchor (light setting on the right).
        // Side-anchored per Curtis: "light fading in heavier from one side, like
        // as if spinning out of view."
        const sweepGradient = isSunrise
          ? 'radial-gradient(ellipse 90% 100% at 105% 100%, rgba(255, 196, 130, 0.7) 0%, rgba(232, 124, 90, 0.5) 22%, rgba(124, 80, 140, 0.32) 50%, rgba(46, 60, 110, 0.18) 78%, transparent 100%)'
          : 'radial-gradient(ellipse 90% 100% at 105% 100%, rgba(232, 124, 90, 0.45) 0%, rgba(124, 80, 140, 0.4) 30%, rgba(46, 56, 100, 0.32) 60%, rgba(16, 22, 48, 0.22) 88%, transparent 100%)';

        // Notify Starfield to play its warp animation (it owns its own GSAP tween).
        window.dispatchEvent(new CustomEvent('soma-theme:transitioning', {
          detail: { fromTheme: root.dataset.theme, toTheme, isSunrise }
        }));
        root.classList.add('sky-transitioning');

        const tl = gsap.timeline({
          defaults: { ease: 'power2.inOut', duration: 0.6 },
          onComplete: () => {
            transitioning = false;
            root.classList.remove('sky-transitioning');
          }
        });

        // Labels for readability per gsap-timeline skill guidance
        tl.addLabel('stars-buzz', 0)
          .addLabel('sky-sweep', 0.2)
          .addLabel('palette-swap', 0.7)
          .addLabel('settle', 1.0);

        if (horizon) {
          // Sweep horizon at the sky-sweep label — GSAP can't tween background-image
          // gradient strings directly, so we set it via onStart and use autoAlpha on
          // the wrapper for the visual ramp.
          tl.to(horizon, {
            autoAlpha: 1,
            duration: 0.5,
            ease: 'power1.in',
            onStart: () => { horizon.style.background = sweepGradient; }
          }, 'sky-sweep');

          // Clear inline override at settle so CSS theme rule resumes
          tl.to(horizon, {
            autoAlpha: 1,
            duration: 0.8,
            ease: 'power2.out',
            onStart: () => { horizon.style.background = ''; }
          }, 'settle');
        }

        // Theme palette swap mid-sequence
        tl.call(applyTheme, [toTheme], 'palette-swap');
      }

      // Run on initial load + Astro view transitions
      initThemeToggle();
      document.addEventListener('astro:page-load', initThemeToggle);
    </script>
  </body>
</html>
