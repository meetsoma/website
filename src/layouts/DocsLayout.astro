---
import Layout from './Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Search from '../components/Search.astro';
import TableOfContents from '../components/islands/TableOfContents';
import { getCollection } from 'astro:content';
import { docUrl } from '../lib/blog';

interface Props {
  title: string;
  description?: string;
  currentSlug: string;
}

const { title, description, currentSlug } = Astro.props;

const docJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: title,
  description: description || `${title} — Soma documentation`,
  url: `https://soma.gravicity.ai/docs/${currentSlug}`,
  author: {
    '@type': 'Organization',
    name: 'Gravicity',
    url: 'https://gravicity.ai',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Gravicity',
  },
};

// Get all docs, sorted by order
const allDocs = (await getCollection('docs'))
  .filter(doc => !doc.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

// Group by section
const sections = new Map<string, typeof allDocs>();
for (const doc of allDocs) {
  const section = doc.data.section;
  if (!sections.has(section)) sections.set(section, []);
  sections.get(section)!.push(doc);
}
---

<Layout title={`${title} — Soma Docs`} description={description} jsonLd={docJsonLd} canonicalUrl={`https://soma.gravicity.ai/docs/${currentSlug}`}>
  <div class="stars"></div>

  <div class="docs-wrapper">
    <!-- Left Sidebar -->
    <aside class="sidebar">
      <a href="/docs" class="sidebar-brand">
        <img src="/media/soma-logo-animated.svg" alt="Soma" width="28" height="28" />
        <span>Soma Docs</span>
      </a>

      <Search />

      <nav class="sidebar-nav">
        {[...sections.entries()].map(([sectionName, docs]) => (
          <div class="nav-section">
            <h3 class="nav-section-title">{sectionName}</h3>
            <ul class="nav-list">
              {docs.map(doc => (
                <li>
                  <a
                    href={docUrl(doc)}
                    class:list={['nav-link', { active: doc.id.replace(/\.mdx?$/, '') === currentSlug }]}
                  >
                    {doc.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>

      <div class="sidebar-footer">
        <a href="https://www.npmjs.com/package/meetsoma" target="_blank" rel="noopener">npm</a>
        <span class="sep">·</span>
        <a href="https://github.com/meetsoma" target="_blank" rel="noopener">GitHub</a>
      </div>
    </aside>

    <!-- Content -->
    <main class="docs-content">
      <article class="docs-article">
        <Breadcrumbs items={[
          { label: 'Docs', href: '/docs' },
          { label: title, href: `/docs/${currentSlug}` },
        ]} />
        <header class="docs-header">
          <h1>{title}</h1>
          {description && <p class="docs-description">{description}</p>}
        </header>

        <div class="prose">
          <slot />
        </div>

        <!-- Prev/Next -->
        {(() => {
          const currentIndex = allDocs.findIndex(d => d.id.replace(/\.mdx?$/, '') === currentSlug);
          const prev = currentIndex > 0 ? allDocs[currentIndex - 1] : null;
          const next = currentIndex < allDocs.length - 1 ? allDocs[currentIndex + 1] : null;
          return (
            <nav class="docs-pager">
              {prev ? (
                <a href={docUrl(prev)} class="pager-link pager-prev">
                  <span class="pager-label">← Previous</span>
                  <span class="pager-title">{prev.data.title}</span>
                </a>
              ) : <div />}
              {next ? (
                <a href={docUrl(next)} class="pager-link pager-next">
                  <span class="pager-label">Next →</span>
                  <span class="pager-title">{next.data.title}</span>
                </a>
              ) : <div />}
            </nav>
          );
        })()}
      </article>
    </main>

    <!-- Right Sidebar: Table of Contents -->
    <aside class="toc-sidebar">
      <TableOfContents client:idle />
    </aside>
  </div>

  <!-- Copy buttons for code blocks -->
  <script>
    function initCopyButtons() {
      document.querySelectorAll('.prose pre').forEach(pre => {
        if (pre.querySelector('.code-copy-btn')) return;
        const btn = document.createElement('button');
        btn.className = 'code-copy-btn';
        btn.title = 'Copy';
        btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
        btn.addEventListener('click', async () => {
          const code = pre.querySelector('code')?.textContent || pre.textContent || '';
          await navigator.clipboard.writeText(code.trim());
          btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="20 6 9 17 4 12"/></svg>`;
          setTimeout(() => {
            btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
          }, 2000);
        });
        (pre as HTMLElement).style.position = 'relative';
        pre.appendChild(btn);
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCopyButtons);
    } else {
      initCopyButtons();
    }
  </script>
</Layout>

<style>
  .stars {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 20px 30px, rgba(228,234,244,0.6), transparent),
      radial-gradient(1px 1px at 150px 100px, rgba(124,178,212,0.5), transparent);
    background-size: 400px 180px;
    animation: twinkle 10s ease-in-out infinite alternate;
  }
  @keyframes twinkle { 0% { opacity: 0.3; } 100% { opacity: 0.6; } }

  .docs-wrapper {
    position: relative; z-index: 1;
    display: flex;
    min-height: 100vh;
  }

  /* Left Sidebar */
  .sidebar {
    position: sticky;
    top: 0;
    width: 260px;
    height: 100vh;
    overflow-y: auto;
    padding: var(--space-xl) var(--space-xl);
    border-right: 1px solid var(--border-subtle);
    background: var(--surface-card);
    backdrop-filter: blur(12px);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  .sidebar-brand {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    text-decoration: none;
    color: var(--text-primary);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--body-text);
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border-subtle);
  }

  .sidebar-brand img {
    filter: drop-shadow(0 0 var(--space-md) var(--logo-glow));
  }

  .sidebar-nav { flex: 1; }

  .nav-section { margin-bottom: var(--space-xl); }

  .nav-section-title {
    font-family: var(--font-display);
    font-size: var(--badge-text);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: var(--space-md);
    padding: 0 var(--space-md);
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-link {
    display: block;
    padding: 6px var(--space-md);
    border-radius: var(--radius-md);
    font-size: var(--body-secondary);
    color: var(--text-secondary);
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .nav-link:hover {
    color: var(--text-primary);
    background: var(--surface-interactive);
  }

  .nav-link.active {
    color: var(--accent-bright);
    background: var(--surface-accent-soft);
    font-weight: 500;
  }

  .sidebar-footer {
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border-subtle);
    font-size: var(--label-text);
    color: var(--text-muted);
    display: flex;
    gap: var(--space-sm);
  }

  .sidebar-footer a {
    color: var(--accent-bright);
    text-decoration: none;
  }
  .sidebar-footer a:hover { color: var(--moon-bright); }
  .sep { color: var(--text-muted); }

  /* Content */
  .docs-content {
    flex: 1;
    min-width: 0;
    max-width: 760px;
    padding: var(--space-3xl) var(--space-3xl) var(--space-4xl);
  }

  .docs-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--border-subtle);
  }

  .docs-header h1 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 700;
    margin-bottom: var(--space-md);
  }

  .docs-description {
    color: var(--text-secondary);
    font-size: var(--body-text);
  }

  /* Right Sidebar: TOC */
  .toc-sidebar {
    position: sticky;
    top: 0;
    width: 220px;
    height: 100vh;
    overflow-y: auto;
    padding: var(--space-3xl) var(--space-lg) var(--space-xl);
    flex-shrink: 0;
  }

  .toc-sidebar :global(.toc) {
    position: sticky;
    top: 48px;
  }

  .toc-sidebar :global(.toc-title) {
    font-family: var(--font-display);
    font-size: var(--badge-text);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: var(--space-lg);
  }

  .toc-sidebar :global(.toc-list) {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 1px solid var(--border-subtle);
  }

  .toc-sidebar :global(.toc-item) {
    margin: 0;
  }

  .toc-sidebar :global(.toc-sub) {
    padding-left: var(--space-lg);
  }

  .toc-sidebar :global(.toc-link) {
    display: block;
    padding: var(--space-xs) 0 var(--space-xs) var(--space-lg);
    font-size: var(--badge-text);
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.15s;
    border-left: 2px solid transparent;
    margin-left: -1px;
    line-height: var(--leading-normal);
  }

  .toc-sidebar :global(.toc-link:hover) {
    color: var(--text-primary);
  }

  .toc-sidebar :global(.toc-link.active) {
    color: var(--accent-bright);
    border-left-color: var(--accent-bright);
  }

  /* Prose styling */
  .prose {
    font-size: var(--body-secondary);
    line-height: var(--leading-loose);
    color: var(--text-primary);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--border-subtle);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-lg);
  }

  .prose :global(h4) {
    font-family: var(--font-display);
    font-size: var(--body-text);
    font-weight: 600;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .prose :global(p) { margin-bottom: var(--space-lg); }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    padding: 2px var(--space-sm);
    border-radius: var(--radius-sm);
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  .prose :global(pre) {
    position: relative;
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card-strong) !important;
    overflow-x: auto;
    margin: var(--space-xl) 0;
  }

  .prose :global(pre code) {
    padding: 0;
    background: none;
    color: var(--text-primary);
    font-size: var(--label-text);
    line-height: var(--leading-relaxed);
  }

  /* Copy button for code blocks */
  :global(.code-copy-btn) {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    padding: var(--space-sm);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: var(--surface-card);
    color: var(--text-muted);
    cursor: pointer;
    opacity: 0;
    transition: all 0.15s;
    line-height: 1;
  }

  .prose :global(pre:hover .code-copy-btn) {
    opacity: 1;
  }

  :global(.code-copy-btn:hover) {
    color: var(--accent-bright);
    border-color: var(--border-accent);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-xl) 0;
    font-size: var(--body-secondary);
  }

  .prose :global(th) {
    text-align: left;
    padding: var(--space-md) var(--space-lg);
    border-bottom: 2px solid var(--border-subtle);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--label-text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .prose :global(td) {
    padding: var(--space-md) var(--space-lg);
    border-bottom: 1px solid var(--border-subtle);
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: var(--space-xl);
    margin-bottom: var(--space-lg);
  }

  .prose :global(li) { margin-bottom: var(--space-sm); }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent-bright);
    padding: var(--space-lg) var(--space-xl);
    margin: var(--space-xl) 0;
    background: var(--surface-accent-soft);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    color: var(--text-secondary);
  }

  .prose :global(a) {
    color: var(--accent-bright);
    text-decoration: none;
    border-bottom: 1px solid var(--border-accent);
    transition: color 0.2s;
  }

  .prose :global(a:hover) { color: var(--moon-bright); }

  /* Pager */
  .docs-pager {
    display: flex;
    justify-content: space-between;
    gap: var(--space-lg);
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--border-subtle);
  }

  .pager-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg) var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.2s;
    min-width: 0;
  }

  .pager-link:hover {
    border-color: var(--border-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--shadow-accent-soft);
  }

  .pager-next { text-align: right; margin-left: auto; }

  .pager-label {
    font-size: var(--badge-text);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .pager-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--body-secondary);
    color: var(--accent-bright);
  }

  /* Mobile */
  @media (max-width: 1080px) {
    .toc-sidebar { display: none; }
  }

  @media (max-width: 768px) {
    .docs-wrapper { flex-direction: column; }
    .sidebar {
      position: relative;
      width: 100%;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--border-subtle);
    }
    .docs-content { padding: var(--space-xl) var(--space-xl) var(--space-3xl); }
  }
</style>
