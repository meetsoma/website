---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import RoadmapTimeline from '../../components/islands/RoadmapTimeline.tsx';
import { getCollection } from 'astro:content';

// ─── Data ───────────────────────────────────────────────────────────────
// Pull everything from public/data/roadmap.json so the page is one source
// of truth. Blog-post links resolve via a lookup against the content
// collection — no dead links when a post id changes.

import roadmapData from '../../../public/data/roadmap.json';

type Release = {
  version: string;
  date?: string;
  title?: string;
  tagline?: string;
  blogPost?: string;
  features?: {
    added?: string[];
    changed?: string[];
    fixed?: string[];
  };
};

const timeline: Release[] = roadmapData.timeline || [];
const next = timeline.find((t) => t.version === 'Next') ?? null;
const recent = timeline.filter((t) => t.version !== 'Next').slice(0, 3);
const latestRelease = recent[0];

// Blog collection for post-resolution + latest-post lookup
const blogPosts = await getCollection('blog', (p) => !p.data.draft);
blogPosts.sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));
const blogById = new Map(blogPosts.map((p) => [p.id.replace(/\.md$/, ''), p]));
const latestPost = blogPosts[0];

// Helper to resolve a blog reference from a release
function blogLinkFor(release: Release): { href: string; title: string } | null {
  if (!release.blogPost) return null;
  const post = blogById.get(release.blogPost);
  if (!post) return null;
  return {
    href: `/blog/${release.blogPost}`,
    title: post.data.title,
  };
}

// Format a date like "Apr 22, 2026"
function formatDate(d?: string): string {
  if (!d) return '';
  const date = new Date(d);
  if (Number.isNaN(+date)) return d;
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

// Days since last release (for header freshness indicator)
function daysSince(d?: string): number | null {
  if (!d) return null;
  const date = new Date(d);
  if (Number.isNaN(+date)) return null;
  return Math.floor((+new Date() - +date) / (1000 * 60 * 60 * 24));
}

const lastShipDays = daysSince(latestRelease?.date);
---

<Layout
  title="Roadmap — σ"
  description="What Soma is shipping next and what shipped recently. Every release linked to its story."
  canonicalUrl="https://soma.gravicity.ai/roadmap"
>
  <main class="container">
    <header class="hero">
      <Breadcrumbs items={[{ label: 'Roadmap', href: '/roadmap' }]} />
      <h1 class="title">Roadmap</h1>
      <p class="subtitle">What we're shipping. What just shipped. The story of each.</p>

      <!-- ─── Release badges ─────────────────────────────────────── -->
      <div class="badges" aria-label="Release status">
        {latestRelease && (
          <a class="badge badge-latest" href="/docs/changelog" title="View full changelog">
            <span class="badge-label">Latest</span>
            <span class="badge-value">v{latestRelease.version}</span>
            {latestRelease.date && (
              <span class="badge-meta">{formatDate(latestRelease.date)}</span>
            )}
          </a>
        )}
        {lastShipDays !== null && (
          <span class="badge badge-ship">
            <span class="badge-label">Shipped</span>
            <span class="badge-value">
              {lastShipDays === 0 ? 'today' : lastShipDays === 1 ? 'yesterday' : `${lastShipDays}d ago`}
            </span>
          </span>
        )}
        {next && next.features?.added && (
          <span class="badge badge-next">
            <span class="badge-label">Next</span>
            <span class="badge-value">{next.features.added.length} items in flight</span>
          </span>
        )}
      </div>
    </header>

    <!-- ─── Section 1: Shipping Next ──────────────────────────── -->
    {next && next.features?.added && next.features.added.length > 0 && (
      <section class="section">
        <SectionHeader title="Shipping Next" />
        <p class="section-sub">
          What's in flight. Unordered — priorities shift. Run
          <code>soma vote &lt;feature&gt;</code> to weigh in (coming soon).
        </p>
        <ul class="next-list">
          {next.features.added.map((item) => (
            <li class="next-item">
              <span class="next-dot" aria-hidden="true"></span>
              <span class="next-body" set:html={item} />
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- ─── Section 2: Recently Shipped ───────────────────────── -->
    {recent.length > 0 && (
      <section class="section">
        <SectionHeader title="Recently Shipped" />
        <p class="section-sub">
          The last three releases. Each links to its changelog entry — some also link to the post that tells the story.
        </p>
        <div class="recent-grid">
          {recent.map((release) => {
            const blog = blogLinkFor(release);
            return (
              <article class="recent-card">
                <header class="recent-head">
                  <div class="recent-version">
                    <span class="recent-v">v{release.version}</span>
                    <span class="recent-date">{formatDate(release.date)}</span>
                  </div>
                  {release.title && <h3 class="recent-title">{release.title}</h3>}
                </header>

                {release.tagline && <p class="recent-tagline">{release.tagline}</p>}

                {release.features && (
                  <div class="recent-features">
                    {release.features.added && release.features.added.length > 0 && (
                      <div class="feat-group">
                        <span class="feat-label feat-added">Added</span>
                        <ul>
                          {release.features.added.slice(0, 3).map((f) => (
                            <li set:html={f} />
                          ))}
                          {release.features.added.length > 3 && (
                            <li class="feat-more">+{release.features.added.length - 3} more</li>
                          )}
                        </ul>
                      </div>
                    )}
                    {release.features.fixed && release.features.fixed.length > 0 && (
                      <div class="feat-group">
                        <span class="feat-label feat-fixed">Fixed</span>
                        <ul>
                          {release.features.fixed.slice(0, 2).map((f) => (
                            <li set:html={f} />
                          ))}
                          {release.features.fixed.length > 2 && (
                            <li class="feat-more">+{release.features.fixed.length - 2} more</li>
                          )}
                        </ul>
                      </div>
                    )}
                  </div>
                )}

                <footer class="recent-foot">
                  <a href="/docs/changelog" class="recent-link">changelog</a>
                  {blog && (
                    <a href={blog.href} class="recent-link recent-link-blog" title={blog.title}>
                      read the story →
                    </a>
                  )}
                </footer>
              </article>
            );
          })}
        </div>
      </section>
    )}

    <!-- ─── Section 3: Release History (timeline) ────────────── -->
    <section class="section">
      <SectionHeader title="Release History" />
      <p class="section-sub">
        Every release Soma has shipped. Collapsible entries — click a version to expand.
      </p>
      <RoadmapTimeline client:load />
    </section>

    <!-- ─── Footer callouts ────────────────────────────────────── -->
    <div class="callouts">
      <div class="callout">
        <strong>Every commit is in the changelog.</strong>
        <p>
          The full history of fixes, features, and refactors lives at
          <a href="/docs/changelog">/docs/changelog</a>.
        </p>
      </div>
      {latestPost && (
        <div class="callout">
          <strong>Latest from the blog:</strong>
          <p>
            <a href={`/blog/${latestPost.id.replace(/\.md$/, '')}`}>{latestPost.data.title}</a>
            <span class="callout-date">{formatDate(latestPost.data.date as any)}</span>
          </p>
        </div>
      )}
      <div class="callout">
        <strong>Feature voting coming soon.</strong>
        <p>
          Run <code>soma vote &lt;feature&gt;</code> from any session to shape what ships next.
        </p>
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    position: relative;
    z-index: 1;
    max-width: 920px;
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-xl) var(--space-2xl);
    min-height: 100vh;
  }

  /* ── Hero ────────────────────────────────────────────────── */
  .hero {
    text-align: center;
    margin-bottom: var(--section-gap);
    animation: fadeUp 0.8s ease-out;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(21px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .title {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: var(--space-lg) 0 var(--space-md);
    color: var(--text-primary);
  }

  .subtitle {
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    color: var(--text-secondary);
    max-width: 540px;
    margin: 0 auto var(--space-xl);
    line-height: 1.6;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-top: var(--space-lg);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border-subtle, #30363d);
    border-radius: 999px;
    font-size: 0.82rem;
    color: var(--text-secondary);
    background: var(--bg-elevated, rgba(22, 27, 34, 0.5));
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .badge:hover {
    border-color: var(--accent, #7cb2d4);
    color: var(--text-primary);
  }

  .badge-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary, #6e7681);
  }

  .badge-value {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-weight: 500;
    color: var(--text-primary);
  }

  .badge-meta {
    font-size: 0.78rem;
    color: var(--text-tertiary, #6e7681);
  }

  .badge-latest .badge-value {
    color: var(--accent, #7cb2d4);
  }

  /* ── Sections ────────────────────────────────────────────── */
  .section {
    margin-bottom: var(--section-gap, 4rem);
    animation: fadeUp 0.9s ease-out 0.15s both;
  }

  .section-sub {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin: -0.5rem 0 var(--space-xl);
    line-height: 1.55;
  }
  .section-sub code {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.88em;
    padding: 0.12em 0.45em;
    background: var(--bg-elevated, rgba(22, 27, 34, 0.5));
    border: 1px solid var(--border-subtle, #30363d);
    border-radius: 4px;
  }

  /* ── Shipping Next ───────────────────────────────────────── */
  .next-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 0.5rem;
  }
  .next-item {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 1.1rem;
    background: var(--bg-elevated, rgba(22, 27, 34, 0.45));
    border: 1px solid var(--border-subtle, #30363d);
    border-radius: 10px;
    line-height: 1.55;
  }
  .next-dot {
    flex-shrink: 0;
    display: inline-block;
    width: 8px;
    height: 8px;
    margin-top: 0.45em;
    border-radius: 50%;
    background: var(--accent, #7cb2d4);
    opacity: 0.85;
    animation: pulse 2.2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.85; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.85); }
  }
  .next-body {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
  .next-body :global(code) {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.88em;
    color: var(--text-primary);
  }

  /* ── Recently Shipped ────────────────────────────────────── */
  .recent-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1rem;
  }

  .recent-card {
    display: flex;
    flex-direction: column;
    padding: 1.3rem 1.4rem;
    background: var(--bg-elevated, rgba(22, 27, 34, 0.5));
    border: 1px solid var(--border-subtle, #30363d);
    border-radius: 12px;
    transition: border-color 0.15s, transform 0.15s;
  }
  .recent-card:hover {
    border-color: var(--accent-muted, rgba(124, 178, 212, 0.4));
    transform: translateY(-1px);
  }

  .recent-head {
    margin-bottom: 0.65rem;
  }

  .recent-version {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.3rem;
  }
  .recent-v {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--accent, #7cb2d4);
  }
  .recent-date {
    font-size: 0.82rem;
    color: var(--text-tertiary, #6e7681);
  }
  .recent-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 1.25rem;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.25;
  }

  .recent-tagline {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.55;
    margin: 0 0 1rem;
  }

  .recent-features {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    margin: 0 0 1rem;
    flex-grow: 1;
  }

  .feat-group {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    font-size: 0.86rem;
  }
  .feat-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.55;
    flex-grow: 1;
  }
  .feat-group ul li {
    padding-left: 0.7em;
    text-indent: -0.7em;
  }
  .feat-group ul li::before {
    content: "· ";
    color: var(--text-tertiary, #6e7681);
    margin-right: 0.35em;
  }
  .feat-group :global(code) {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.88em;
    color: var(--text-primary);
  }
  .feat-more {
    font-style: italic;
    color: var(--text-tertiary, #6e7681) !important;
  }
  .feat-more::before { content: none !important; }

  .feat-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 0.15em 0.55em;
    border-radius: 4px;
    border: 1px solid currentColor;
    flex-shrink: 0;
    min-width: 54px;
    text-align: center;
    height: fit-content;
    margin-top: 0.15rem;
  }
  .feat-added { color: #7ee787; border-color: rgba(126, 231, 135, 0.3); }
  .feat-fixed { color: #ffa657; border-color: rgba(255, 166, 87, 0.3); }

  .recent-foot {
    display: flex;
    gap: 1.1rem;
    padding-top: 0.7rem;
    border-top: 1px solid var(--border-subtle, #30363d);
  }
  .recent-link {
    font-size: 0.88rem;
    color: var(--text-tertiary, #6e7681);
    text-decoration: none;
    transition: color 0.15s;
  }
  .recent-link:hover {
    color: var(--accent, #7cb2d4);
  }
  .recent-link-blog {
    margin-left: auto;
    color: var(--accent, #7cb2d4);
    font-weight: 500;
  }

  /* ── Callouts (footer strip) ────────────────────────────── */
  .callouts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
    margin-top: var(--section-gap, 4rem);
    padding-top: var(--space-2xl);
    border-top: 1px solid var(--border-subtle, #30363d);
  }
  .callout {
    padding: 1rem 1.2rem;
    background: var(--bg-elevated, rgba(22, 27, 34, 0.45));
    border: 1px solid var(--border-subtle, #30363d);
    border-radius: 10px;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .callout strong {
    display: block;
    color: var(--text-primary);
    margin-bottom: 0.35rem;
    font-weight: 500;
  }
  .callout p {
    color: var(--text-secondary);
    margin: 0;
  }
  .callout a {
    color: var(--accent, #7cb2d4);
    text-decoration: none;
  }
  .callout a:hover { text-decoration: underline; }
  .callout code {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.85em;
    padding: 0.1em 0.35em;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 4px;
  }
  .callout-date {
    display: block;
    font-size: 0.78rem;
    color: var(--text-tertiary, #6e7681);
    margin-top: 0.25rem;
  }

  /* ── Mobile ───────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .container {
      padding: var(--space-xl) var(--space-lg) var(--space-xl);
    }
    .badges {
      gap: 0.35rem;
    }
    .badge {
      font-size: 0.76rem;
      padding: 0.3rem 0.65rem;
    }
    .recent-grid, .next-list, .callouts {
      grid-template-columns: 1fr;
    }
  }
</style>
