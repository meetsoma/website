---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const timeline = [
  {
    version: 'v0.2.1',
    label: 'Public Launch',
    date: 'Mar 2026',
    items: [
      'Commit history flattened for clean public release',
      'Terminology standardized across all 9 docs',
      '/breathe command — exhale + auto-continue',
      'CI: PR check, release validation, release-publish workflows',
      'Scripts restored: search, scan, snapshot, TL;DR, date hook',
    ]
  },
  {
    version: 'v0.2.0',
    label: 'The Engine',
    date: 'Mar 2026',
    items: [
      '9 core modules: boot, protocols, heat, muscles, search, settings, init, applies-to, exhale',
      'Heat system — adaptive protocol/muscle loading with decay',
      'Muscles — pattern memory with digest blocks and load tracking',
      'Applies-to — protocol domain scoping by project signals',
      '5 test suites, 188 assertions passing',
    ]
  },
  {
    version: 'v0.1.0',
    label: 'First Breath',
    date: 'Mar 2026',
    items: [
      'Protocol architecture — four-layer plugin model',
      'Extensions: soma-boot, soma-header, soma-statusline',
      'Identity discovery — layered from project → parent → global',
      'Agent templates — shareable soma configurations',
      'npm packages: meetsoma (public CLI)',
    ]
  },
];

const upcoming = [
  {
    name: 'Rituals',
    icon: '🔮',
    description: 'Multi-step workflows — /rest (deep cleanup), /pulse (health check), /introspect (self-audit). YAML-defined, composable.',
    status: 'In Design',
  },
  {
    name: 'Template Install',
    icon: '🛠',
    description: 'soma init --template <name> — pull starter configs from a registry. Team configs, framework starters, community templates.',
    status: 'Planned',
  },
  {
    name: 'Parent-Child Memory',
    icon: '🧬',
    description: 'Monorepo support — child .soma/ inherits from parent. Protocol chains, shared identity, scoped overrides.',
    status: 'Planned',
  },
  {
    name: 'Souls & Symlinks',
    icon: '🌐',
    description: 'Community hub where soma agents share reflections, refine identity, and discover each other. Verification protocol for agent-only submissions.',
    status: 'Exploring',
  },
  {
    name: 'Muscle Sharing',
    icon: '💪',
    description: 'Publish and install muscles from a community registry. soma install muscle <name>.',
    status: 'Planned',
  },
  {
    name: 'Voice Extension',
    icon: '⟐',
    description: 'TTS integration — /voice command for spoken responses. Agent finds its literal voice.',
    status: 'Exploring',
  },
];
---

<Layout
  title="Roadmap — Soma"
  description="Where Soma has been and where it's going. Timeline of shipped features and what's next."
  canonicalUrl="https://soma.gravicity.ai/roadmap"
>
  <div class="stars"></div>
  <div class="nebula"></div>

  <main class="container">
    <header class="hero">
      <Breadcrumbs items={[{ label: 'Roadmap', href: '/roadmap' }]} />
      <h1 class="title">Roadmap</h1>
      <p class="subtitle">
        Where Soma has been. Where it's going.
      </p>
    </header>

    <section class="section">
      <SectionHeader title="Shipped" />
      <div class="timeline">
        {timeline.map((release, i) => (
          <div class="timeline-entry" style={`animation-delay: ${i * 0.1}s`}>
            <div class="timeline-dot">◉</div>
            <div class="timeline-body">
              <div class="timeline-head">
                <span class="version">{release.version}</span>
                <span class="label">{release.label}</span>
                <span class="date">{release.date}</span>
              </div>
              <ul class="timeline-items">
                {release.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <SectionHeader title="What's Next" />
      <div class="upcoming-grid">
        {upcoming.map((feature, i) => (
          <div class="feature-card" style={`animation-delay: ${i * 0.08}s`}>
            <div class="feature-head">
              <span class="feature-icon">{feature.icon}</span>
              <span class="feature-name">{feature.name}</span>
              <span class="feature-status">{feature.status}</span>
            </div>
            <p class="feature-desc">{feature.description}</p>
          </div>
        ))}
      </div>

      <div class="voting-teaser">
        <p>
          <strong>Feature voting coming soon.</strong> Run <code>soma vote &lt;feature&gt;</code> to 
          shape what ships next. Requires soma installed — your agent identity is your ballot.
        </p>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* ═══════════════════════════════════════════════════════
     Roadmap — matches site Fibonacci + deep space palette
     ═══════════════════════════════════════════════════════ */

  .stars {
    position: fixed;
    inset: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 20px 30px, rgba(228,234,244,0.6), transparent),
      radial-gradient(1px 1px at 80px 60px, rgba(228,234,244,0.4), transparent),
      radial-gradient(1.5px 1.5px at 150px 100px, rgba(124,178,212,0.5), transparent),
      radial-gradient(1px 1px at 300px 80px, rgba(232,168,124,0.3), transparent);
    background-size: 400px 180px;
    animation: twinkle 10s ease-in-out infinite alternate;
    pointer-events: none;
    z-index: 0;
  }

  .nebula {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 15% 20%, rgba(104, 152, 190, 0.08), transparent 50%),
      radial-gradient(ellipse 50% 50% at 85% 30%, rgba(124, 178, 212, 0.06), transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  @keyframes twinkle {
    0% { opacity: 0.3; }
    100% { opacity: 0.6; }
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 890px;
    margin: 0 auto;
    padding: 55px 21px 34px;
    min-height: 100vh;
  }

  /* ── Hero ── */
  .hero {
    text-align: center;
    margin-bottom: 55px;
    animation: fadeUp 0.8s ease-out;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(21px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2.625rem, 8vw, 4.25rem);
    font-weight: 700;
    margin: 8px 0;
    background: linear-gradient(135deg, var(--hero-title-start) 0%, var(--hero-title-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: 1.15rem;
    color: var(--text-secondary);
    max-width: 34rem;
    margin: 8px auto 0;
    line-height: 1.618;
  }

  /* ── Sections ── */
  .section {
    margin-bottom: 55px;
  }

  /* ── Timeline ── */
  .timeline {
    position: relative;
    padding-left: 34px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 8px;
    top: 5px;
    bottom: 5px;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--border-accent),
      var(--border-subtle)
    );
  }

  .timeline-entry {
    position: relative;
    margin-bottom: 34px;
    animation: fadeUp 0.6s ease-out both;
  }

  .timeline-dot {
    position: absolute;
    left: -29px;
    top: 3px;
    font-size: 0.85rem;
    color: var(--accent-bright);
  }

  .timeline-head {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }

  .version {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--accent-bright);
    font-weight: 600;
  }

  .label {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .date {
    font-family: var(--font-body);
    font-size: 0.813rem;
    color: var(--text-muted);
  }

  .timeline-items {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline-items li {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.618;
    padding: 3px 0;
  }

  .timeline-items li::before {
    content: '· ';
    color: var(--text-muted);
  }

  /* ── Upcoming Grid ── */
  .upcoming-grid {
    display: grid;
    gap: 13px;
  }

  .feature-card {
    padding: 21px;
    border-radius: 13px;
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    backdrop-filter: blur(8px);
    transition: all 0.25s ease;
    animation: fadeUp 0.6s ease-out both;
  }

  .feature-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-3px);
    box-shadow: 0 13px 34px var(--shadow-accent-soft);
  }

  .feature-head {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .feature-icon {
    font-size: 1.15rem;
  }

  .feature-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    flex: 1;
  }

  .feature-status {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    padding: 3px 8px;
    border-radius: 8px;
    background: var(--surface-interactive);
  }

  .feature-desc {
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.618;
    margin: 0;
  }

  /* ── Voting Teaser ── */
  .voting-teaser {
    margin-top: 34px;
    padding: 21px;
    background: var(--surface-accent-soft);
    border: 1px solid var(--border-accent);
    border-radius: 13px;
    text-align: center;
  }

  .voting-teaser p {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.618;
    margin: 0;
  }

  .voting-teaser code {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent-bright);
    background: var(--surface-interactive);
    padding: 2px 8px;
    border-radius: 5px;
  }

  @media (max-width: 640px) {
    .container {
      padding: 34px 13px 21px;
    }

    .timeline {
      padding-left: 21px;
    }

    .timeline-dot {
      left: -17px;
    }

    .timeline-head {
      flex-direction: column;
      gap: 3px;
    }
  }
</style>
