---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Icon from '../../components/icons/SomaIcons.astro';
import RoadmapTimeline from '../../components/islands/RoadmapTimeline.tsx';

const upcoming: { name: string; icon: string; description: string; status: string; statusColor: string }[] = [
  {
    name: 'Identity & First Run',
    icon: 'protocols',
    description: 'soul.md replaces SOMA.md. Minimal first-run boot -- the agent discovers through use instead of loading everything at once. 11 bundled scripts, extension allowlist, distribution tiers.',
    status: 'Shipped',
    statusColor: 'var(--green-bright, #4ade80)',
  },
  {
    name: 'Doctor & Migration',
    icon: 'protocols',
    description: 'Project health check with auto-fix on boot. 13 migration phases from v0.6.1 to v0.11.0. Critical semver fix ensures upgrades actually run. Your customizations are never touched.',
    status: 'Shipped',
    statusColor: 'var(--green-bright, #4ade80)',
  },
  {
    name: 'Image & Error Guard',
    icon: 'extensions',
    description: 'Auto-strips old images when they accumulate. Human-readable API errors instead of raw JSON. Billing notices handled gracefully. Keepalive auto-pause on rate limits.',
    status: 'Shipped',
    statusColor: 'var(--green-bright, #4ade80)',
  },
  {
    name: 'Distribution Tiers',
    icon: 'scripts',
    description: 'Free scripts ship readable. Pro scripts compile to protected JavaScript. Extensions obfuscated with auth-gate. Open-source pledge: core Soma stays open forever.',
    status: 'Shipped',
    statusColor: 'var(--green-bright, #4ade80)',
  },
  {
    name: 'Somaverse',
    icon: 'extensions',
    description: 'Visual workspace at somaverse.ai — 33 plugins, 28 agent tools. soma login pairs your agent. Hub relay routes data through your machine, never stores it. Per-user isolation with Argon2 device keys. Your browser is the UI, your machine is the brain.',
    status: 'Live',
    statusColor: 'var(--green-bright, #4ade80)',
  },
  {
    name: 'Model Switching & Opus 4.7',
    icon: 'scripts',
    description: 'soma model command — switch default models from CLI with fuzzy matching. 23 providers, 842+ models. Claude Opus 4.7 with adaptive thinking. Smarter prompt caching — tool changes no longer invalidate your cache.',
    status: 'Shipped',
    statusColor: 'var(--green-bright, #4ade80)',
  },
  {
    name: 'Shipping Integrity',
    icon: 'protocols',
    description: 'Fresh `npm install -g meetsoma` now actually works (was broken since the npm/ reorg). Pi runtime is locked to the Soma version that tested it — no more silent drift. `soma update` actually updates; `soma init` is for projects. Periodic update nudge appears in the statusline so you see new releases within minutes of starting a session. Pre-publish smoke test prevents broken tarballs from shipping.',
    status: 'Shipped',
    statusColor: 'var(--green-bright, #4ade80)',
  },
  {
    name: 'Cache Stickiness',
    icon: 'protocols',
    description: '`/reload` no longer invalidates your Anthropic prompt cache. The compiled system prompt is persisted to disk and restored on reload, resume, and fork — reloads become near-free instead of costing ~$1 each. New optional `/rebuild` command forces recompile when you want mid-session body edits to apply. The old intrusive restart toast became a subtle tag on statusline line 3, with severity labels (`/reload`, `/rebuild?`, or `relaunch`) so you know what the change actually needs — and why.',
    status: 'Shipped',
    statusColor: 'var(--green-bright, #4ade80)',
  },
  {
    name: 'Recall',
    icon: 'automations',
    description: 'Persistent memory via graph store. Cross-session, cross-project knowledge that survives context windows. The agent remembers what matters and forgets what does not.',
    status: 'In Progress',
    statusColor: 'var(--promo)',
  },
];
---

<Layout
  title="Roadmap — Soma"
  description="Where Soma has been and where it's going. Timeline of shipped features and what's next."
  canonicalUrl="https://soma.gravicity.ai/roadmap"
>
  <main class="container">
    <header class="hero">
      <Breadcrumbs items={[{ label: 'Roadmap', href: '/roadmap' }]} />
      <h1 class="title">Roadmap</h1>
      <p class="subtitle">
        Where it's going. Where it's been.
      </p>
    </header>

    <!-- On the Horizon -->
    <section class="section">
      <SectionHeader title="On the Horizon" />
      <div class="upcoming-grid">
        {upcoming.map((feature, i) => (
          <div class="feature-card" style={`animation-delay: ${i * 0.08}s`}>
            <div class="feature-head">
              <span class="feature-icon"><Icon name={feature.icon as any} size={22} /></span>
              <h3 class="feature-name">{feature.name}</h3>
              <span class="feature-status" style={`color: ${feature.statusColor}; border-color: ${feature.statusColor}`}>
                {feature.status}
              </span>
            </div>
            <p class="feature-desc">{feature.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- In Progress -->
    <section class="section">
      <SectionHeader title="Shipping Soon" />
      <div class="progress-list">
        <div class="progress-item">
          <span class="progress-dot active"></span>
          <div>
            <strong>Somaverse public beta</strong>
            <p>Open registration, team workspaces, pane drag-and-drop. Visual workspace for your agent — already live at somaverse.ai.</p>
          </div>
        </div>
        <div class="progress-item">
          <span class="progress-dot active"></span>
          <div>
            <strong>Niche templates</strong>
            <p>Next.js, Rust, Python ML shipped. Go, Laravel, Astro, React Native, Monorepo planned. Each template shapes the agent for your stack.</p>
          </div>
        </div>
        <div class="progress-item">
          <span class="progress-dot active"></span>
          <div>
            <strong>CLI convergence</strong>
            <p>Reduce wrapping around the Pi engine. Let upstream flags pass through cleanly. Persistent model switching already shipped — more commands coming.</p>
          </div>
        </div>
        <div class="progress-item">
          <span class="progress-dot"></span>
          <div>
            <strong>Recall memory</strong>
            <p>Graph-backed persistent memory. Cross-session knowledge. The agent remembers patterns, decisions, and context across projects.</p>
          </div>
        </div>
        <div class="progress-item">
          <span class="progress-dot"></span>
          <div>
            <strong>Content versioning</strong>
            <p>Know when hub protocols update. Diff before upgrading. Never lose your customizations to a hub sync.</p>
          </div>
        </div>
        <div class="progress-item">
          <span class="progress-dot"></span>
          <div>
            <strong>Async agent comms</strong>
            <p>Soma reaches you when decisions are needed. File-based inbox already works. Push notifications coming.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Shipped Timeline -->
    <section class="section">
      <SectionHeader title="Shipped" />
      <RoadmapTimeline client:load />
    </section>

    <!-- Changelog link -->
    <div class="changelog-link">
      <p>
        Every commit, every fix, every feature — the full history lives in the
        <a href="/docs/changelog">changelog</a>.
      </p>
    </div>

    <!-- Voting Teaser -->
    <div class="voting-teaser">
      <p>
        <strong>Feature voting coming soon.</strong> Run <code>soma vote &lt;feature&gt;</code> to 
        shape what ships next.
      </p>
    </div>
  </main>
</Layout>

<style>
  .container {
    position: relative;
    z-index: 1;
    max-width: 890px;
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-xl) var(--space-2xl);
    min-height: 100vh;
  }

  /* ── Hero ── */
  .hero {
    text-align: center;
    margin-bottom: var(--section-gap);
    animation: fadeUp 0.8s ease-out;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(21px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 2.625rem);
    font-weight: 800;
    margin: var(--space-md) 0;
    background: linear-gradient(135deg, var(--hero-title-start) 0%, var(--hero-title-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 34rem;
    margin: var(--space-md) auto 0;
    line-height: var(--leading-relaxed);
  }

  .section {
    margin-bottom: var(--section-gap);
  }

  /* ── Upcoming Grid ── */
  .upcoming-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--grid-gap);
  }

  .feature-card {
    padding: var(--card-pad-y) var(--card-pad-x);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    backdrop-filter: blur(8px);
    transition: all 0.25s ease;
    animation: fadeUp 0.6s ease-out both;
  }

  .feature-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-3px);
    box-shadow: 0 13px 34px var(--shadow-accent-soft);
  }

  .feature-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    color: var(--accent-bright);
  }

  .feature-name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    flex: 1;
    margin: 0;
    line-height: var(--leading-tight);
  }

  .feature-status {
    font-family: var(--font-mono);
    font-size: var(--badge-text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-full);
    border: 1px solid;
    background: transparent;
    flex-shrink: 0;
  }

  .feature-desc {
    font-family: var(--font-body);
    font-size: var(--body-text);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* ── Changelog Link ── */
  .changelog-link {
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .changelog-link p {
    font-family: var(--font-body);
    font-size: var(--body-text);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .changelog-link a {
    color: var(--accent-bright);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
  }

  .changelog-link a:hover {
    border-bottom-color: var(--accent-bright);
  }

  /* ── Voting Teaser ── */
  .voting-teaser {
    margin-bottom: var(--section-gap);
    padding: var(--space-xl);
    background: var(--surface-accent-soft);
    border: 1px solid var(--border-accent);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .voting-teaser p {
    font-family: var(--font-body);
    font-size: var(--body-text);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .voting-teaser code {
    font-family: var(--font-mono);
    font-size: var(--label-text);
    color: var(--accent-bright);
    background: var(--surface-interactive);
    padding: 2px var(--space-md);
    border-radius: var(--radius-sm);
  }

  /* ── Shipping Soon ── */
  .progress-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .progress-item {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    transition: border-color 0.2s ease;
  }

  .progress-item:hover {
    border-color: var(--border-accent);
  }

  .progress-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border-subtle);
    margin-top: 8px;
    flex-shrink: 0;
  }

  .progress-dot.active {
    background: var(--accent-bright);
    box-shadow: 0 0 6px var(--accent-bright);
  }

  .progress-dot.shipped {
    background: var(--promo);
    box-shadow: 0 0 6px var(--promo);
  }

  .progress-item strong {
    font-family: var(--font-display);
    font-size: var(--body-text);
    color: var(--text-primary);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .progress-item p {
    font-size: var(--body-secondary);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  @media (max-width: 768px) {
    .upcoming-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .container { padding: var(--space-2xl) var(--space-lg) var(--space-xl); }
  }
</style>

<style is:global>
  /* ── Timeline ── */
  .timeline {
    position: relative;
    padding-left: var(--space-2xl);
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: calc(var(--space-xl) + 8px);
    bottom: 5px;
    width: 2px;
    background: linear-gradient(to bottom, var(--border-accent), var(--border-subtle));
  }

  .timeline-entry {
    position: relative;
    margin-bottom: var(--space-3xl);
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    transition: all 0.25s ease;
    animation: fadeUp 0.6s ease-out both;
  }

  .timeline-entry:hover {
    border-color: var(--border-accent);
    box-shadow: 0 8px 24px var(--shadow-accent-soft);
  }

  .timeline-entry:first-child {
    border-color: var(--border-accent);
  }

  .timeline-dot {
    position: absolute;
    left: calc(-1 * var(--space-2xl) + 1px);
    top: calc(var(--space-xl) + 3px);
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--bg-deep);
    border: 2px solid var(--accent-bright);
    z-index: 1;
  }

  .timeline-entry:first-child .timeline-dot {
    background: var(--accent-bright);
    box-shadow: 0 0 8px var(--accent-bright);
  }

  .timeline-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-lg);
    flex-wrap: wrap;
    margin-bottom: var(--space-lg);
  }

  .timeline .version {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    color: var(--accent-bright);
    font-weight: 700;
  }

  .timeline .label {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
    line-height: var(--leading-tight);
  }

  .timeline .date {
    font-family: var(--font-mono);
    font-size: var(--label-text);
    color: var(--text-muted);
    margin-left: auto;
  }

  .timeline-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-sm);
  }

  .timeline-items li {
    font-family: var(--font-body);
    font-size: var(--body-text);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    padding: var(--space-xs) 0;
    padding-left: var(--space-xl);
    position: relative;
  }

  .timeline-items li::before {
    content: '';
    position: absolute;
    left: var(--space-md);
    top: 0.7em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent-bright);
    opacity: 0.5;
  }

  .timeline-entry.latest {
    border-color: var(--border-accent);
    background: linear-gradient(135deg, var(--surface-card) 0%, rgba(104, 152, 190, 0.04) 100%);
  }

  .latest-badge {
    font-family: var(--font-mono);
    font-size: var(--badge-text);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--bg-deep);
    background: var(--accent-bright);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-full);
    line-height: 1;
  }

  .timeline-loading,
  .timeline-error {
    text-align: center;
    padding: var(--space-2xl);
    color: var(--text-muted);
    font-family: var(--font-body);
  }

  @media (max-width: 640px) {
    .timeline { padding-left: var(--space-xl); }
    .timeline-dot { left: calc(-1 * var(--space-xl) - 4px); }
    .timeline-entry { padding: var(--space-lg); }
    .timeline-head { flex-direction: column; gap: var(--space-xs); }
    .timeline .date { margin-left: 0; }
  }
</style>
