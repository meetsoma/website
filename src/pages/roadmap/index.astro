---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Icon from '../../components/icons/SomaIcons.astro';
import RoadmapTimeline from '../../components/islands/RoadmapTimeline.tsx';

const upcoming: { name: string; icon: string; description: string; status: string }[] = [
  {
    name: '/share Command',
    icon: 'protocols',
    description: 'Publish protocols, muscles, and skills from your .soma/ directly to the community hub. Validates, strips private data, opens a PR.',
    status: 'Planned',
  },
  {
    name: 'AMPS Automations',
    icon: 'extensions',
    description: 'Step-by-step procedural flows that can spawn tuned agents for end-to-end workflows. The fifth AMPS layer — shipped foundation, building out triggers and chaining.',
    status: 'In Progress',
  },
  {
    name: 'AI Content Screening',
    icon: 'skills',
    description: 'Haiku-powered review of community submissions — injection scanning, quality scoring, automatic tier classification.',
    status: 'Planned',
  },
  {
    name: 'Bundle Builder',
    icon: 'templates',
    description: 'Multi-select on the hub — pick protocols, muscles, extensions. Generate a soma-bundle.json. One command spawns a fully configured agent.',
    status: 'Exploring',
  },
  {
    name: 'Framework Compatibility',
    icon: 'extensions',
    description: 'Extensions that read CLAUDE.md, AGENTS.md, .cursorrules and layer Soma memory on top. Drop Soma into any project and it just works.',
    status: 'Exploring',
  },
];
---

<Layout
  title="Roadmap — Soma"
  description="Where Soma has been and where it's going. Timeline of shipped features and what's next."
  canonicalUrl="https://soma.gravicity.ai/roadmap"
>
  <div class="stars"></div>
  <div class="nebula"></div>

  <main class="container">
    <header class="hero">
      <Breadcrumbs items={[{ label: 'Roadmap', href: '/roadmap' }]} />
      <h1 class="title">Roadmap</h1>
      <p class="subtitle">
        Where Soma has been. Where it's going.
      </p>
    </header>

    <section class="section">
      <SectionHeader title="Shipped" />
      <RoadmapTimeline client:load />
    </section>

    <section class="section">
      <SectionHeader title="What's Next" />
      <div class="upcoming-grid">
        {upcoming.map((feature, i) => (
          <div class="feature-card" style={`animation-delay: ${i * 0.08}s`}>
            <div class="feature-head">
              <span class="feature-icon"><Icon name={feature.icon as any} size={20} /></span>
              <h3 class="feature-name">{feature.name}</h3>
              <span class="feature-status">{feature.status}</span>
            </div>
            <p class="feature-desc">{feature.description}</p>
          </div>
        ))}
      </div>

      <div class="voting-teaser">
        <p>
          <strong>Feature voting coming soon.</strong> Run <code>soma vote &lt;feature&gt;</code> to 
          shape what ships next. Requires soma installed — your agent identity is your ballot.
        </p>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Design tokens: see Layout.astro :root */

  .stars {
    position: fixed;
    inset: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 20px 30px, rgba(228,234,244,0.6), transparent),
      radial-gradient(1px 1px at 80px 60px, rgba(228,234,244,0.4), transparent),
      radial-gradient(1.5px 1.5px at 150px 100px, rgba(124,178,212,0.5), transparent),
      radial-gradient(1px 1px at 300px 80px, rgba(232,168,124,0.3), transparent);
    background-size: 400px 180px;
    animation: twinkle 10s ease-in-out infinite alternate;
    pointer-events: none;
    z-index: 0;
  }

  .nebula {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 15% 20%, rgba(104, 152, 190, 0.08), transparent 50%),
      radial-gradient(ellipse 50% 50% at 85% 30%, rgba(124, 178, 212, 0.06), transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  @keyframes twinkle {
    0% { opacity: 0.3; }
    100% { opacity: 0.6; }
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 890px;
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-xl) var(--space-2xl);
    min-height: 100vh;
  }

  /* ── Hero ── */
  .hero {
    text-align: center;
    margin-bottom: var(--section-gap);
    animation: fadeUp 0.8s ease-out;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(21px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2.625rem, 8vw, 4.25rem);
    font-weight: 700;
    margin: var(--space-md) 0;
    background: linear-gradient(135deg, var(--hero-title-start) 0%, var(--hero-title-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 34rem;
    margin: var(--space-md) auto 0;
    line-height: var(--leading-relaxed);
  }

  /* ── Sections ── */
  .section {
    margin-bottom: var(--section-gap);
  }

  /* ── Upcoming Grid ── */
  .upcoming-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .feature-card {
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    backdrop-filter: blur(8px);
    transition: all 0.25s ease;
    animation: fadeUp 0.6s ease-out both;
  }

  .feature-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-3px);
    box-shadow: 0 13px 34px var(--shadow-accent-soft);
  }

  .feature-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    color: var(--accent-bright);
  }

  .feature-name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    flex: 1;
    margin: 0;
  }

  .feature-status {
    font-family: var(--font-mono);
    font-size: var(--badge-text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    padding: var(--space-xs) 8px;
    border-radius: var(--radius-md);
    background: var(--surface-interactive);
  }

  .feature-desc {
    font-family: var(--font-body);
    font-size: var(--body-text);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* ── Voting Teaser ── */
  .voting-teaser {
    margin-top: var(--space-2xl);
    padding: var(--space-xl);
    background: var(--surface-accent-soft);
    border: 1px solid var(--border-accent);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .voting-teaser p {
    font-family: var(--font-body);
    font-size: var(--body-text);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .voting-teaser code {
    font-family: var(--font-mono);
    font-size: var(--label-text);
    color: var(--accent-bright);
    background: var(--surface-interactive);
    padding: 2px var(--space-md);
    border-radius: var(--radius-sm);
  }

  @media (max-width: 640px) {
    .container {
      padding: var(--space-2xl) 13px 21px;
    }
  }
</style>

<style is:global>
  /* ── Timeline (global for Preact island) ── */
  .timeline {
    position: relative;
    padding-left: var(--space-2xl);
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 8px;
    top: 5px;
    bottom: 5px;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--border-accent),
      var(--border-subtle)
    );
  }

  .timeline-entry {
    position: relative;
    margin-bottom: var(--space-2xl);
    animation: fadeUp 0.6s ease-out both;
  }

  .timeline-dot {
    position: absolute;
    left: -29px;
    top: 3px;
    font-size: var(--label-text);
    color: var(--accent-bright);
  }

  .timeline-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }

  .timeline .version {
    font-family: var(--font-mono);
    font-size: var(--body-secondary);
    color: var(--accent-bright);
    font-weight: 600;
  }

  .timeline .label {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }

  .timeline .date {
    font-family: var(--font-body);
    font-size: var(--label-text);
    color: var(--text-muted);
  }

  .timeline-items {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline-items li {
    font-family: var(--font-body);
    font-size: var(--list-text);
    color: var(--text-secondary);
    line-height: var(--list-leading);
    padding: var(--space-xs) 0;
  }

  .timeline-items li::before {
    content: '· ';
    color: var(--text-muted);
  }

  .timeline-loading,
  .timeline-error {
    text-align: center;
    padding: var(--space-2xl);
    color: var(--text-muted);
    font-family: var(--font-body);
  }

  @media (max-width: 640px) {
    .timeline {
      padding-left: var(--space-xl);
    }

    .timeline-dot {
      left: -17px;
    }

    .timeline-head {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
</style>
