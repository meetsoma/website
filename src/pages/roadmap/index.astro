---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Icon from '../../components/icons/SomaIcons.astro';
import RoadmapTimeline from '../../components/islands/RoadmapTimeline.tsx';

const upcoming: { name: string; icon: string; description: string; status: string; statusColor: string }[] = [
  {
    name: 'Project Navigator',
    icon: 'scripts',
    description: 'Run soma anywhere — it finds your projects, offers to set up new ones, or picks up where you left off. No arguments needed. Just type soma.',
    status: 'In Progress',
    statusColor: 'var(--warm-bright)',
  },
  {
    name: 'SomaRuntime',
    icon: 'extensions',
    description: 'Abstraction layer between Soma and the underlying engine. Extensions import from SomaRuntime instead of Pi directly — swap engines without touching your code.',
    status: 'In Progress',
    statusColor: 'var(--warm-bright)',
  },
  {
    name: 'Community Hub — Scripts & MAPs',
    icon: 'automations',
    description: 'Browse and install scripts and workflow templates from the hub. Codebase navigation, session reflection, plan management — ready to use.',
    status: 'In Progress',
    statusColor: 'var(--warm-bright)',
  },
  {
    name: 'Framework Compatibility',
    icon: 'extensions',
    description: 'Extensions that read CLAUDE.md, AGENTS.md, .cursorrules — layer Soma memory on top of any existing setup. Drop in and it just works.',
    status: 'Planned',
    statusColor: 'var(--accent-bright)',
  },
  {
    name: 'First-Run Templates',
    icon: 'templates',
    description: 'Pick your starter kit on first run — fullstack, architect, writer, devops. Protocols, muscles, and settings configured automatically.',
    status: 'Planned',
    statusColor: 'var(--accent-bright)',
  },
  {
    name: '/share Command',
    icon: 'protocols',
    description: 'Publish protocols, muscles, and skills from your .soma/ directly to the community hub. Validates, strips private data, opens a PR.',
    status: 'Exploring',
    statusColor: 'var(--text-muted)',
  },
];
---

<Layout
  title="Roadmap — Soma"
  description="Where Soma has been and where it's going. Timeline of shipped features and what's next."
  canonicalUrl="https://soma.gravicity.ai/roadmap"
>
  <main class="container">
    <header class="hero">
      <Breadcrumbs items={[{ label: 'Roadmap', href: '/roadmap' }]} />
      <h1 class="title">Roadmap</h1>
      <p class="subtitle">
        Where it's going. Where it's been.
      </p>
    </header>

    <!-- On the Horizon -->
    <section class="section">
      <SectionHeader title="On the Horizon" />
      <div class="upcoming-grid">
        {upcoming.map((feature, i) => (
          <div class="feature-card" style={`animation-delay: ${i * 0.08}s`}>
            <div class="feature-head">
              <span class="feature-icon"><Icon name={feature.icon as any} size={22} /></span>
              <h3 class="feature-name">{feature.name}</h3>
              <span class="feature-status" style={`color: ${feature.statusColor}; border-color: ${feature.statusColor}`}>
                {feature.status}
              </span>
            </div>
            <p class="feature-desc">{feature.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- In Progress -->
    <section class="section">
      <SectionHeader title="Shipping Soon" />
      <div class="progress-list">
        <div class="progress-item">
          <span class="progress-dot active"></span>
          <div>
            <strong>Heat system fixes</strong>
            <p>Muscle heat bumps on natural use, not just focus matching. Heat visibility command across all AMPS layers.</p>
          </div>
        </div>
        <div class="progress-item">
          <span class="progress-dot active"></span>
          <div>
            <strong>Hub content expansion</strong>
            <p>7 free-tier scripts and workflow MAPs coming to the community hub. 4 missing protocols to sync.</p>
          </div>
        </div>
        <div class="progress-item">
          <span class="progress-dot"></span>
          <div>
            <strong>Boot sequence extraction</strong>
            <p>Moving hardcoded behavior from TypeScript into user-editable MAPs. Configure what loads and in what order.</p>
          </div>
        </div>
        <div class="progress-item">
          <span class="progress-dot"></span>
          <div>
            <strong>Heat thresholds in settings</strong>
            <p>Cold/warm/hot boundaries and decay rate moving from hardcoded values to configurable settings.json.</p>
          </div>
        </div>
        <div class="progress-item">
          <span class="progress-dot"></span>
          <div>
            <strong>Tutorial guides</strong>
            <p>Writing your first protocol. Writing your first muscle. Hands-on walkthroughs for the AMPS system.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Shipped Timeline -->
    <section class="section">
      <SectionHeader title="Shipped" />
      <RoadmapTimeline client:load />
    </section>

    <!-- Voting Teaser -->
    <div class="voting-teaser">
      <p>
        <strong>Feature voting coming soon.</strong> Run <code>soma vote &lt;feature&gt;</code> to 
        shape what ships next.
      </p>
    </div>
  </main>
</Layout>

<style>
  .container {
    position: relative;
    z-index: 1;
    max-width: 890px;
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-xl) var(--space-2xl);
    min-height: 100vh;
  }

  /* ── Hero ── */
  .hero {
    text-align: center;
    margin-bottom: var(--section-gap);
    animation: fadeUp 0.8s ease-out;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(21px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 2.625rem);
    font-weight: 700;
    margin: var(--space-md) 0;
    background: linear-gradient(135deg, var(--hero-title-start) 0%, var(--hero-title-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 34rem;
    margin: var(--space-md) auto 0;
    line-height: var(--leading-relaxed);
  }

  .section {
    margin-bottom: var(--section-gap);
  }

  /* ── Upcoming Grid ── */
  .upcoming-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--grid-gap);
  }

  .feature-card {
    padding: var(--card-pad-y) var(--card-pad-x);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    backdrop-filter: blur(8px);
    transition: all 0.25s ease;
    animation: fadeUp 0.6s ease-out both;
  }

  .feature-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-3px);
    box-shadow: 0 13px 34px var(--shadow-accent-soft);
  }

  .feature-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    color: var(--accent-bright);
  }

  .feature-name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    flex: 1;
    margin: 0;
    line-height: var(--leading-tight);
  }

  .feature-status {
    font-family: var(--font-mono);
    font-size: var(--badge-text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-full);
    border: 1px solid;
    background: transparent;
    flex-shrink: 0;
  }

  .feature-desc {
    font-family: var(--font-body);
    font-size: var(--body-text);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* ── Voting Teaser ── */
  .voting-teaser {
    margin-bottom: var(--section-gap);
    padding: var(--space-xl);
    background: var(--surface-accent-soft);
    border: 1px solid var(--border-accent);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .voting-teaser p {
    font-family: var(--font-body);
    font-size: var(--body-text);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .voting-teaser code {
    font-family: var(--font-mono);
    font-size: var(--label-text);
    color: var(--accent-bright);
    background: var(--surface-interactive);
    padding: 2px var(--space-md);
    border-radius: var(--radius-sm);
  }

  /* ── Shipping Soon ── */
  .progress-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .progress-item {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    transition: border-color 0.2s ease;
  }

  .progress-item:hover {
    border-color: var(--border-accent);
  }

  .progress-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border-subtle);
    margin-top: 8px;
    flex-shrink: 0;
  }

  .progress-dot.active {
    background: var(--accent-bright);
    box-shadow: 0 0 6px var(--accent-bright);
  }

  .progress-item strong {
    font-family: var(--font-display);
    font-size: var(--body-text);
    color: var(--text-primary);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .progress-item p {
    font-size: var(--body-secondary);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  @media (max-width: 768px) {
    .upcoming-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .container { padding: var(--space-2xl) var(--space-lg) var(--space-xl); }
  }
</style>

<style is:global>
  /* ── Timeline ── */
  .timeline {
    position: relative;
    padding-left: var(--space-2xl);
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: calc(var(--space-xl) + 8px);
    bottom: 5px;
    width: 2px;
    background: linear-gradient(to bottom, var(--border-accent), var(--border-subtle));
  }

  .timeline-entry {
    position: relative;
    margin-bottom: var(--space-3xl);
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    transition: all 0.25s ease;
    animation: fadeUp 0.6s ease-out both;
  }

  .timeline-entry:hover {
    border-color: var(--border-accent);
    box-shadow: 0 8px 24px var(--shadow-accent-soft);
  }

  .timeline-entry:first-child {
    border-color: var(--border-accent);
  }

  .timeline-dot {
    position: absolute;
    left: calc(-1 * var(--space-2xl) + 1px);
    top: calc(var(--space-xl) + 3px);
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--bg-deep);
    border: 2px solid var(--accent-bright);
    z-index: 1;
  }

  .timeline-entry:first-child .timeline-dot {
    background: var(--accent-bright);
    box-shadow: 0 0 8px var(--accent-bright);
  }

  .timeline-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-lg);
    flex-wrap: wrap;
    margin-bottom: var(--space-lg);
  }

  .timeline .version {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    color: var(--accent-bright);
    font-weight: 700;
  }

  .timeline .label {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
    line-height: var(--leading-tight);
  }

  .timeline .date {
    font-family: var(--font-mono);
    font-size: var(--label-text);
    color: var(--text-muted);
    margin-left: auto;
  }

  .timeline-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-sm);
  }

  .timeline-items li {
    font-family: var(--font-body);
    font-size: var(--body-text);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    padding: var(--space-xs) 0;
    padding-left: var(--space-xl);
    position: relative;
  }

  .timeline-items li::before {
    content: '';
    position: absolute;
    left: var(--space-md);
    top: 0.7em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent-bright);
    opacity: 0.5;
  }

  .timeline-entry.latest {
    border-color: var(--border-accent);
    background: linear-gradient(135deg, var(--surface-card) 0%, rgba(104, 152, 190, 0.04) 100%);
  }

  .latest-badge {
    font-family: var(--font-mono);
    font-size: var(--badge-text);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--bg-deep);
    background: var(--accent-bright);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-full);
    line-height: 1;
  }

  .timeline-loading,
  .timeline-error {
    text-align: center;
    padding: var(--space-2xl);
    color: var(--text-muted);
    font-family: var(--font-body);
  }

  @media (max-width: 640px) {
    .timeline { padding-left: var(--space-xl); }
    .timeline-dot { left: calc(-1 * var(--space-xl) - 4px); }
    .timeline-entry { padding: var(--space-lg); }
    .timeline-head { flex-direction: column; gap: var(--space-xs); }
    .timeline .date { margin-left: 0; }
  }
</style>
