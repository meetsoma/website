---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const timeline = [
  {
    version: 'v0.3.x',
    label: 'Hub & Distribution',
    date: 'Mar 2026',
    items: [
      '/install — fetch protocols, muscles, skills, templates from the Soma Hub',
      '/list local and /list remote — browse installed and available content',
      'Template manifests — install a full agent config with dependencies',
      'Hub website — tier badges, version history, interactive filtering',
      'Session checkpoints — two-track version control (.soma + project code)',
      'Audit system — 11 scripts: PII, drift, stale terms, docs sync, commands, frontmatter',
      'meetsoma/core — maintained engine fork with automated upstream sync',
      'Automated publish pipeline — GitHub Actions for build → npm → tag',
    ]
  },
  {
    version: 'v0.3.0',
    label: 'Session Intelligence',
    date: 'Mar 2026',
    items: [
      '/rest command — disable keepalive + exhale for end of session',
      'Cache keepalive — auto-ping keeps prompt cache warm between turns',
      '/keepalive and /status commands — session observability',
      'PII scrub — git-filter-repo rewrote all 4 repo histories, zero personal data',
      'Install flow simplified — soma init copies bundled extensions, no symlinks',
    ]
  },
  {
    version: 'v0.2.0',
    label: 'The Engine',
    date: 'Mar 2026',
    items: [
      '9 core modules: boot, protocols, heat, muscles, search, settings, init, applies-to, exhale',
      'Heat system — adaptive protocol/muscle loading with decay',
      'Muscles — pattern memory with digest blocks and load tracking',
      'Applies-to — protocol domain scoping by project signals',
      '/breathe command — exhale + auto-continue into fresh session',
      'Parent-child memory — .soma chain resolution (project → workspace → global)',
      'Scripts: search, scan, snapshot, TL;DR, date hook',
    ]
  },
  {
    version: 'v0.1.0',
    label: 'First Breath',
    date: 'Mar 2026',
    items: [
      'Protocol architecture — four-layer plugin model',
      'Extensions: soma-boot, soma-header, soma-statusline',
      'Identity discovery — layered from project → parent → global',
      'Agent templates — shareable soma configurations',
      'npm packages: meetsoma (public CLI)',
    ]
  },
];

const upcoming = [
  {
    name: 'Rituals',
    icon: '🔮',
    description: 'Multi-step workflows — YAML-defined, composable sequences. /introspect (self-audit), custom rituals triggered by context. Muscles that crystallize into automated routines.',
    status: 'In Design',
  },
  {
    name: 'Dynamic System Prompts',
    icon: '🧠',
    description: 'System prompts that evolve over time — assembled from identity, hot protocols, session delta, and checkpoint diffs. No more static prompts.',
    status: 'In Design',
  },
  {
    name: 'AI Content Screening',
    icon: '🛡',
    description: 'Haiku-powered review of community submissions — injection scanning, quality scoring, automatic tier classification for hub contributions.',
    status: 'Planned',
  },
  {
    name: 'soma publish',
    icon: '📤',
    description: 'Publish protocols, muscles, and skills from your .soma/ directly to the community hub. Creates a PR with proper frontmatter and tier tagging.',
    status: 'Planned',
  },
  {
    name: 'Vault Sync',
    icon: '🔗',
    description: 'Auto-discover and symlink .soma/ directories across a workspace. Parent .soma sees all children — unified view for multi-project ecosystems.',
    status: 'Exploring',
  },
  {
    name: 'Voice Extension',
    icon: '⟐',
    description: 'TTS integration — /voice command for spoken responses. Agent finds its literal voice.',
    status: 'Exploring',
  },
];
---

<Layout
  title="Roadmap — Soma"
  description="Where Soma has been and where it's going. Timeline of shipped features and what's next."
  canonicalUrl="https://soma.gravicity.ai/roadmap"
>
  <div class="stars"></div>
  <div class="nebula"></div>

  <main class="container">
    <header class="hero">
      <Breadcrumbs items={[{ label: 'Roadmap', href: '/roadmap' }]} />
      <h1 class="title">Roadmap</h1>
      <p class="subtitle">
        Where Soma has been. Where it's going.
      </p>
    </header>

    <section class="section">
      <SectionHeader title="Shipped" />
      <div class="timeline">
        {timeline.map((release, i) => (
          <div class="timeline-entry" style={`animation-delay: ${i * 0.1}s`}>
            <div class="timeline-dot">◉</div>
            <div class="timeline-body">
              <div class="timeline-head">
                <span class="version">{release.version}</span>
                <span class="label">{release.label}</span>
                <span class="date">{release.date}</span>
              </div>
              <ul class="timeline-items">
                {release.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <SectionHeader title="What's Next" />
      <div class="upcoming-grid">
        {upcoming.map((feature, i) => (
          <div class="feature-card" style={`animation-delay: ${i * 0.08}s`}>
            <div class="feature-head">
              <span class="feature-icon">{feature.icon}</span>
              <span class="feature-name">{feature.name}</span>
              <span class="feature-status">{feature.status}</span>
            </div>
            <p class="feature-desc">{feature.description}</p>
          </div>
        ))}
      </div>

      <div class="voting-teaser">
        <p>
          <strong>Feature voting coming soon.</strong> Run <code>soma vote &lt;feature&gt;</code> to 
          shape what ships next. Requires soma installed — your agent identity is your ballot.
        </p>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Design tokens: see Layout.astro :root */

  .stars {
    position: fixed;
    inset: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 20px 30px, rgba(228,234,244,0.6), transparent),
      radial-gradient(1px 1px at 80px 60px, rgba(228,234,244,0.4), transparent),
      radial-gradient(1.5px 1.5px at 150px 100px, rgba(124,178,212,0.5), transparent),
      radial-gradient(1px 1px at 300px 80px, rgba(232,168,124,0.3), transparent);
    background-size: 400px 180px;
    animation: twinkle 10s ease-in-out infinite alternate;
    pointer-events: none;
    z-index: 0;
  }

  .nebula {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 15% 20%, rgba(104, 152, 190, 0.08), transparent 50%),
      radial-gradient(ellipse 50% 50% at 85% 30%, rgba(124, 178, 212, 0.06), transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  @keyframes twinkle {
    0% { opacity: 0.3; }
    100% { opacity: 0.6; }
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 890px;
    margin: 0 auto;
    padding: var(--space-3xl) 21px 34px;
    min-height: 100vh;
  }

  /* ── Hero ── */
  .hero {
    text-align: center;
    margin-bottom: var(--space-3xl);
    animation: fadeUp 0.8s ease-out;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(21px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2.625rem, 8vw, 4.25rem);
    font-weight: 700;
    margin: var(--space-md) 0;
    background: linear-gradient(135deg, var(--hero-title-start) 0%, var(--hero-title-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 34rem;
    margin: var(--space-md) auto 0;
    line-height: var(--leading-relaxed);
  }

  /* ── Sections ── */
  .section {
    margin-bottom: var(--space-3xl);
  }

  /* ── Timeline ── */
  .timeline {
    position: relative;
    padding-left: 34px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 8px;
    top: 5px;
    bottom: 5px;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--border-accent),
      var(--border-subtle)
    );
  }

  .timeline-entry {
    position: relative;
    margin-bottom: var(--space-2xl);
    animation: fadeUp 0.6s ease-out both;
  }

  .timeline-dot {
    position: absolute;
    left: -29px;
    top: 3px;
    font-size: var(--text-sm);
    color: var(--accent-bright);
  }

  .timeline-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }

  .version {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--accent-bright);
    font-weight: 600;
  }

  .label {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
  }

  .date {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .timeline-items {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline-items li {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    padding: var(--space-xs) 0;
  }

  .timeline-items li::before {
    content: '· ';
    color: var(--text-muted);
  }

  /* ── Upcoming Grid ── */
  .upcoming-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .feature-card {
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    backdrop-filter: blur(8px);
    transition: all 0.25s ease;
    animation: fadeUp 0.6s ease-out both;
  }

  .feature-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-3px);
    box-shadow: 0 13px 34px var(--shadow-accent-soft);
  }

  .feature-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .feature-icon {
    font-size: var(--text-lg);
  }

  .feature-name {
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--text-primary);
    flex: 1;
  }

  .feature-status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    padding: var(--space-xs) 8px;
    border-radius: var(--radius-md);
    background: var(--surface-interactive);
  }

  .feature-desc {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* ── Voting Teaser ── */
  .voting-teaser {
    margin-top: var(--space-2xl);
    padding: var(--space-xl);
    background: var(--surface-accent-soft);
    border: 1px solid var(--border-accent);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .voting-teaser p {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .voting-teaser code {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent-bright);
    background: var(--surface-interactive);
    padding: 2px var(--space-md);
    border-radius: var(--radius-sm);
  }

  @media (max-width: 640px) {
    .container {
      padding: var(--space-2xl) 13px 21px;
    }

    .timeline {
      padding-left: 21px;
    }

    .timeline-dot {
      left: -17px;
    }

    .timeline-head {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
</style>
