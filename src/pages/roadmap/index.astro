---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Icon from '../../components/icons/SomaIcons.astro';
import RoadmapTimeline from '../../components/islands/RoadmapTimeline.tsx';

// ─── Recently Shipped ────────────────────────────────────────────────
// Strategic landmark releases, newest first. Shown as an auto-advancing
// hero carousel (one card at a time). Cap: 10 cards. When adding the 11th,
// archive the oldest entry to a separate `archive` array (or move to the
// timeline island below) — NEVER delete. The full history lives in the
// timeline island below this section, so the carousel stays focused on the
// standout stories, not comprehensive coverage.
//
// Hero images: optional. Authoring rule lives at `media/roadmap/README.md`
// + `svg-extract-component.mjs` (extracts a hero component from a blog OG).
// Cards without an OG-paired blog post leave `image` undefined; the carousel
// still renders cleanly (see v0.20.0 / v0.22.0 / v0.24.0 / v0.26.0 below).
const upcoming: { name: string; icon: string; description: string; status: string; statusColor: string; version?: string; date?: string; blogPost?: string; image?: string }[] = [
  {
    name: 'Stop crashing on compaction',
    icon: 'protocols',
    description: 'Pi tool-runner shape fix + a transition-only preload state machine. Bare-string returns from older extensions are auto-lifted into the canonical envelope before persistence — the malformed-toolResult crash class that surfaced during compaction is closed. The preload notify goes yellow on stale (5+ tool calls since save), green on refresh — no more every-turn green spam. 42 new regression gates lock all 7 runtime patches against future Pi bumps.',
    status: 'Shipped',
    statusColor: 'var(--green-bright, #4ade80)',
    version: 'v0.26.0',
    date: '2026-05-07',
  },
  {
    name: 'The warning that meant something else',
    icon: 'protocols',
    description: 'A misfiring deprecation warning fired on every soma startup for weeks. The fix wasn\'t to remove it — it was to repurpose what it interrupted us for. v0.25.0 ships a one-screen preflight prompt: "you\'re behind, want to update?" before each session, with one-keystroke `npm install -g meetsoma@latest`. Migrations now run unconditionally so the upgrade actually lands.',
    status: 'Shipped',
    statusColor: 'var(--green-bright, #4ade80)',
    version: 'v0.25.0',
    date: '2026-05-04',
    blogPost: 'the-warning-curtis-saw-every-startup',
  },
  {
    name: 'Any GitHub repo is a local codebase',
    icon: 'extensions',
    description: 'Treat any GitHub repo as a local codebase — fetch a tarball in 1–5 seconds, then run full symbol search, blast-radius, DEF/USE classification, and structure maps against it. 12 languages (Go, Java, C/C++, Ruby, more than the API map\'s 3). Cache by SHA at `~/.soma/cache/gh/`. Plus `dev:kanban.*` audit caps that triangulate ticket status across kanban + git + code + sessions, and an upgraded `soma:docs.*` surface (`whats_new` + `guide`). v0.26.1 closed the runtime ship gap that briefly held the local-mode caps to schema-only — now functional end-to-end on every install.',
    status: 'Shipped',
    statusColor: 'var(--green-bright, #4ade80)',
    version: 'v0.24.0',
    date: '2026-05-01',
  },
  {
    name: 'Meta-tools land',
    icon: 'extensions',
    description: 'The progressive-awareness era. New family-level meta-tools — `soma:agent.*` (delegate + children collapsed), `soma:focus.*`, `soma:new.*`, `soma:terminals.*`, `soma:browser.*` (17 caps), `soma:docs.*`, `soma:body.*` — register through a cache-safe route bus instead of inflating the system prompt per cap. Iterating your tool surface no longer churns the prompt cache. `soma bridge` CLI ships alongside.',
    status: 'Shipped',
    statusColor: 'var(--green-bright, #4ade80)',
    version: 'v0.22.0',
    date: '2026-04-25',
  },
  {
    name: 'Children Control Panel + tmux',
    icon: 'automations',
    description: 'Background delegation for every user. `delegate(background:true)` spawns children in detached tmux sessions; `children list/tail/steer/kill/harvest` is the full control surface. Attach-on-demand via `tmux attach` to watch a child work. cmux stays as the dev-mode fallback.',
    status: 'Shipped',
    statusColor: 'var(--green-bright, #4ade80)',
    version: 'v0.21.1',
    date: '2026-04-22',
    blogPost: 'four-commands-after-an-update',
    image: '/images/roadmap/children-terminal.svg',
  },
  {
    name: 'Cache Economics',
    icon: 'protocols',
    description: 'Cached prompt prefix shrunk ~25% per boot. Recent Ancestry auto-injects the last three session-log entries so the next-self sees continuity without paying the cache cost. Declarative migration replay makes settings-backfill data-driven.',
    status: 'Shipped',
    statusColor: 'var(--green-bright, #4ade80)',
    version: 'v0.21.0',
    date: '2026-04-22',
    image: '/images/roadmap/cache-economics-mascot.svg',
  },
  {
    name: 'Cache Stickiness',
    icon: 'protocols',
    description: 'Iterating on your setup is free. Reload your extensions as often as you want — your session’s cached memory stays warm, so there’s no dollar cost for rapid iteration. Body edits apply on your terms with a new `/rebuild` command.',
    status: 'Shipped',
    statusColor: 'var(--green-bright, #4ade80)',
    version: 'v0.20.3',
    date: '2026-04-20',
    blogPost: 'why-your-claude-bill-spiked',
    image: '/images/roadmap/cache-stickiness-brokenclaw.svg',
  },
  {
    name: 'Model Switching & Opus 4.7',
    icon: 'scripts',
    description: '`soma model` command — switch default models from CLI with fuzzy matching. 23 providers, 842+ models. Claude Opus 4.7 with adaptive thinking. Smarter prompt caching — tool changes no longer invalidate your cache.',
    status: 'Shipped',
    statusColor: 'var(--green-bright, #4ade80)',
    version: 'v0.20.0',
    date: '2026-04-15',
  },
  {
    name: 'Somaverse',
    icon: 'extensions',
    description: 'Visual workspace at somaverse.ai — 33 plugins, 28 agent tools. `soma login` pairs your agent. Hub relay routes data through your machine, never stores it. Per-user isolation with Argon2 device keys. Your browser is the UI, your machine is the brain.',
    status: 'Live',
    statusColor: 'var(--green-bright, #4ade80)',
    version: 'v0.12.0',
    date: '2026-03-20',
    blogPost: 'the-operating-system',
    image: '/images/roadmap/somaverse-terminal.svg',
  },
  {
    name: 'Doctor & Migration',
    icon: 'protocols',
    description: 'Project health check with auto-fix on boot. Declarative migration phases from v0.6.1 onward. Critical semver fix ensures upgrades actually run. Your customizations are never touched.',
    status: 'Shipped',
    statusColor: 'var(--green-bright, #4ade80)',
    version: 'v0.11.0',
    date: '2026-03-01',
    blogPost: 'the-doctor-that-never-worked',
    image: '/images/roadmap/doctor-codecard.svg',
  },
];

function formatDate(d?: string): string {
  if (!d) return '';
  const date = new Date(d);
  if (Number.isNaN(+date)) return d;
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<Layout
  title="Roadmap — σ"
  description="Where Soma has been and where it's going. Timeline of shipped features and what's next."
  canonicalUrl="https://soma.gravicity.ai/roadmap"
  ogImage="/images/roadmap/og-roadmap.png"
>
  <main class="container">
    <header class="hero">
      <Breadcrumbs items={[{ label: 'Roadmap', href: '/roadmap' }]} />
      <h1 class="title">Roadmap</h1>
      <p class="subtitle">
        Where it's going. Where it's been.
      </p>
    </header>

    <!-- Recently Shipped (auto-advancing hero carousel) -->
    <section class="section">
      <SectionHeader title="Recently Shipped" />
      <div
        class="hero-carousel"
        data-carousel
        data-count={upcoming.length}
        aria-roledescription="carousel"
        aria-label="Recently shipped features"
      >
        <!-- Header strip: counter + nav -->
        <div class="hero-top">
          <span class="hero-counter">
            <span data-carousel-index>1</span> / <span>{upcoming.length}</span>
          </span>
          <div class="hero-nav">
            <button class="hero-btn" data-carousel-prev aria-label="Previous feature">‹</button>
            <button class="hero-btn" data-carousel-next aria-label="Next feature">›</button>
          </div>
        </div>

        <!-- Slides viewport -->
        <div class="hero-viewport" data-carousel-viewport>
          {upcoming.map((feature, i) => (
            <article
              class="hero-slide"
              data-carousel-slide
              data-index={i}
              aria-roledescription="slide"
              aria-label={`${i + 1} of ${upcoming.length}: ${feature.name}`}
              aria-hidden={i === 0 ? 'false' : 'true'}
            >
              {/* Oversized version watermark — drifts behind content */}
              {feature.version && (
                <span class="hero-watermark" aria-hidden="true">{feature.version}</span>
              )}

              {/* Decorative art layer — OG image from the related blog post, */}
              {/* clipped + faded so it tints the background without competing. */}
              {feature.image && (
                <img
                  class="hero-art"
                  src={feature.image}
                  alt=""
                  loading="lazy"
                  aria-hidden="true"
                />
              )}

              <div class="hero-content">
                <div class="hero-head">
                  <span class="hero-icon"><Icon name={feature.icon as any} size={28} /></span>
                  <div class="hero-meta">
                    {feature.version && <span class="hero-version">{feature.version}</span>}
                    {feature.date && <span class="hero-date">{formatDate(feature.date)}</span>}
                    <span
                      class="hero-status"
                      style={`color: ${feature.statusColor}; border-color: ${feature.statusColor}`}
                    >
                      {feature.status}
                    </span>
                  </div>
                </div>

                <h3 class="hero-title">{feature.name}</h3>

                <p class="hero-desc" set:html={feature.description} />

                {feature.blogPost && (
                  <a class="hero-link" href={`/blog/${feature.blogPost}`}>
                    <span aria-hidden="true">›</span>
                    <span>read the story</span>
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>

        <!-- Dot indicators -->
        <div class="hero-controls">
          <div class="hero-dots" role="tablist" aria-label="Select feature">
            {upcoming.map((feature, i) => (
              <button
                class="hero-dot"
                data-carousel-dot
                data-index={i}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-label={`Go to feature ${i + 1}: ${feature.name}`}
              ></button>
            ))}
          </div>
        </div>
      </div>
    </section>

    <script>
      // ─── Auto-advancing carousel ─────────────────────────────────────
      // One slide visible at a time; crossfade between slides. Auto-advance
      // every ADVANCE_MS (pauses on pointer hover + when document is hidden).
      // Accessible: prev/next buttons, dot tabs, ArrowLeft/ArrowRight keys
      // (when carousel is focused-within), aria-hidden on non-active slides.
      (function () {
        const ADVANCE_MS = 9000;
        const carousel = document.querySelector('[data-carousel]') as HTMLElement | null;
        if (!carousel) return;

        const slides = Array.from(carousel.querySelectorAll<HTMLElement>('[data-carousel-slide]'));
        const dots = Array.from(carousel.querySelectorAll<HTMLElement>('[data-carousel-dot]'));
        const indexEl = carousel.querySelector<HTMLElement>('[data-carousel-index]');
        const prevBtn = carousel.querySelector<HTMLElement>('[data-carousel-prev]');
        const nextBtn = carousel.querySelector<HTMLElement>('[data-carousel-next]');
        const count = slides.length;
        if (!count) return;

        let current = 0;
        let timer: number | null = null;
        let paused = false;

        function setActive(i: number) {
          current = ((i % count) + count) % count;
          slides.forEach((s, idx) => {
            const active = idx === current;
            s.classList.toggle('is-active', active);
            s.setAttribute('aria-hidden', active ? 'false' : 'true');
          });
          dots.forEach((d, idx) => {
            d.setAttribute('aria-selected', idx === current ? 'true' : 'false');
          });
          if (indexEl) indexEl.textContent = String(current + 1);
        }

        function schedule() {
          if (timer !== null) window.clearInterval(timer);
          timer = window.setInterval(() => {
            if (!paused) setActive(current + 1);
          }, ADVANCE_MS);
        }

        // ── Events ────────────────────────────────────────────────────
        dots.forEach((d) => {
          d.addEventListener('click', () => {
            const i = Number(d.getAttribute('data-index') || 0);
            setActive(i);
            schedule();
          });
        });
        prevBtn?.addEventListener('click', () => {
          setActive(current - 1);
          schedule();
        });
        nextBtn?.addEventListener('click', () => {
          setActive(current + 1);
          schedule();
        });

        // Pause on hover/focus, resume on leave/blur
        carousel.addEventListener('pointerenter', () => { paused = true; });
        carousel.addEventListener('pointerleave', () => { paused = false; });

        // Keyboard nav when the carousel or any of its children has focus
        carousel.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowLeft') { setActive(current - 1); schedule(); }
          else if (e.key === 'ArrowRight') { setActive(current + 1); schedule(); }
        });

        // Pause when the tab goes hidden (no background burn)
        document.addEventListener('visibilitychange', () => {
          paused = document.hidden;
        });

        setActive(0);
        schedule();
      })();
    </script>

    <!-- In Progress -->
    <section class="section">
      <SectionHeader title="Shipping Soon" />
      <div class="progress-list">
        <div class="progress-item">
          <span class="progress-dot active"></span>
          <div>
            <strong>Somaverse public beta</strong>
            <p>Open registration, team workspaces, pane drag-and-drop. Visual workspace for your agent — already live at somaverse.ai.</p>
          </div>
        </div>
        <div class="progress-item">
          <span class="progress-dot active"></span>
          <div>
            <strong>Niche templates</strong>
            <p>Next.js, Rust, Python ML shipped. Go, Laravel, Astro, React Native, Monorepo planned. Each template shapes the agent for your stack.</p>
          </div>
        </div>
        <div class="progress-item">
          <span class="progress-dot active"></span>
          <div>
            <strong>CLI convergence</strong>
            <p>Reduce wrapping around the Pi engine. Let upstream flags pass through cleanly. Persistent model switching already shipped — more commands coming.</p>
          </div>
        </div>
        <div class="progress-item">
          <span class="progress-dot"></span>
          <div>
            <strong>Recall memory</strong>
            <p>Graph-backed persistent memory. Cross-session knowledge. The agent remembers patterns, decisions, and context across projects.</p>
          </div>
        </div>
        <div class="progress-item">
          <span class="progress-dot"></span>
          <div>
            <strong>Content versioning</strong>
            <p>Know when hub protocols update. Diff before upgrading. Never lose your customizations to a hub sync.</p>
          </div>
        </div>
        <div class="progress-item">
          <span class="progress-dot"></span>
          <div>
            <strong>Async agent comms</strong>
            <p>Soma reaches you when decisions are needed. File-based inbox already works. Push notifications coming.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Shipped Timeline -->
    <section class="section">
      <SectionHeader title="Shipped" />
      <RoadmapTimeline client:load />
    </section>

    <!-- Changelog link -->
    <div class="changelog-link">
      <p>
        Every commit, every fix, every feature — the full history lives in the
        <a href="/docs/changelog">changelog</a>.
      </p>
    </div>

    <!-- Voting Teaser -->
    <div class="voting-teaser">
      <p>
        <strong>Feature voting coming soon.</strong> Run <code>soma vote &lt;feature&gt;</code> to 
        shape what ships next.
      </p>
    </div>
  </main>
</Layout>

<style>
  .container {
    position: relative;
    z-index: 1;
    max-width: 890px;
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-xl) var(--space-2xl);
    min-height: 100vh;
  }

  /* ── Hero ── */
  .hero {
    text-align: center;
    margin-bottom: var(--section-gap);
    animation: fadeUp 0.8s ease-out;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(21px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 2.625rem);
    font-weight: 800;
    margin: var(--space-md) 0;
    background: linear-gradient(135deg, var(--hero-title-start) 0%, var(--hero-title-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 34rem;
    margin: var(--space-md) auto 0;
    line-height: var(--leading-relaxed);
  }

  .section {
    margin-bottom: var(--section-gap);
  }

  /* ─── Hero carousel ──────────────────────────────────────────────── */
  .hero-carousel {
    position: relative;
    padding: var(--space-lg) var(--space-xl) var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    backdrop-filter: blur(8px);
    overflow: hidden;
    animation: fadeUp 0.6s ease-out both;
  }

  .hero-carousel::before {
    /* Soft accent wash on the top edge, like the "latest" feel on every slide */
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--accent-bright, #7cb2d4) 50%,
      transparent 100%
    );
    opacity: 0.55;
  }

  .hero-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-md);
    position: relative;
    z-index: 2;
  }

  .hero-counter {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-tertiary, #6e7681);
    letter-spacing: 0.06em;
  }
  .hero-counter [data-carousel-index] {
    color: var(--accent-bright, #7cb2d4);
    font-weight: 500;
  }

  .hero-nav {
    display: flex;
    gap: 0.35rem;
  }
  .hero-btn {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-subtle);
    border-radius: 6px;
    background: transparent;
    color: var(--text-secondary);
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
    transition: all 0.15s ease;
    padding: 0;
  }
  .hero-btn:hover {
    border-color: var(--accent, #7cb2d4);
    color: var(--accent-bright, #7cb2d4);
  }
  .hero-btn:active {
    transform: scale(0.94);
  }

  /* Slides viewport — stacked; active one fades in over the others */
  .hero-viewport {
    position: relative;
    min-height: 340px;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .hero-slide.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Oversized version watermark drifting behind content */
  .hero-watermark {
    position: absolute;
    right: -0.05em;
    bottom: -0.25em;
    font-family: var(--font-mono);
    font-size: clamp(7rem, 18vw, 13rem);
    font-weight: 700;
    line-height: 0.85;
    letter-spacing: -0.04em;
    color: rgba(124, 178, 212, 0.035);
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
    z-index: 0;
  }

  /* Decorative art layer — a single hero component extracted from the
   * related blog's OG SVG (via scripts/svg-extract-component.mjs).
   * Sits in the right ~40% of the card. Intentionally allowed to crop
   * past the right edge: cutoff signals this is a slice from a larger
   * story, not a contained image. Left edge fades into the prose. */
  .hero-art {
    position: absolute;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
    /* Component lives in the right pane, oversized so it crops */
    width: 52%;
    max-width: 560px;
    height: auto;
    /* Cap height so tall components (the mascot) don't blow the card */
    max-height: 88%;
    object-fit: contain;
    object-position: right center;
    opacity: 0.7;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      black 22%,
      black 100%
    );
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      black 22%,
      black 100%
    );
    filter: saturate(0.95);
    animation: artDrift 18s ease-in-out infinite;
  }
  @keyframes artDrift {
    0%, 100% { transform: translate(0, -50%); }
    50%      { transform: translate(-0.8%, -51%); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    /* Content column is full-width structurally — individual children
     * (.hero-desc, .hero-link) clamp themselves to ~3/5 so the art
     * layer on the right stays breathable. The title row escapes that
     * clamp so SHIPPED always floats right of the title. */
    width: 100%;
  }

  .hero-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .hero-icon {
    display: flex;
    align-items: center;
    color: var(--accent-bright);
  }

  .hero-meta {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    flex: 1;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    row-gap: 0.35rem;
  }

  /* (hero-titlebar removed — status moved into hero-meta) */
  .hero-version {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--accent-bright, #7cb2d4);
    letter-spacing: 0.01em;
  }
  .hero-date {
    font-size: 0.82rem;
    color: var(--text-tertiary, #6e7681);
  }
  .hero-date::before {
    content: "·";
    margin-right: var(--space-sm);
    color: var(--text-tertiary, #6e7681);
  }

  /* Status pill — small, sits inline with version · date in the meta row. */
  .hero-status {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.12em 0.6em;
    border-radius: var(--radius-full);
    border: 1px solid;
    background: transparent;
    flex-shrink: 0;
    line-height: 1.5;
  }
  /* Pill sits after date; flex gap on .hero-meta provides the visual break. */
  .hero-meta .hero-status {
    margin-left: 0.1rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
    line-height: var(--leading-tight);
    letter-spacing: -0.015em;
  }

  .hero-desc {
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 1.2vw, 1.05rem);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
    /* Prose stops at ~3/5 so the hero art has room on the right */
    max-width: 60%;
  }
  .hero-desc :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    color: var(--text-primary);
