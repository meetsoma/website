---
import Layout from '../layouts/Layout.astro';
import HeroTitle from '../components/HeroTitle.astro';
---

<Layout title="404 — σ" description="Page not found.">
  <main class="container">
    <div class="content">
      <span class="glyph">σ</span>
      <HeroTitle text="Lost in the void" align="center" />
      <p class="desc">This page doesn't exist — or hasn't been written yet.</p>
      <a href="/" class="home-link">← Back to Soma</a>
    </div>
  </main>
</Layout>

<style>
  .container {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .content {
    text-align: center;
    animation: fadeUp 0.6s ease-out;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(var(--space-xl)); }
    to { opacity: 1; transform: translateY(0); }
  }

  .glyph {
    font-family: var(--font-display);
    font-size: 5rem;
    color: var(--accent);
    opacity: 0.3;
    display: block;
    margin-bottom: var(--space-xl);
  }

  .title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    margin-bottom: var(--space-md);
  }

  .desc {
    font-size: var(--body-text);
    color: var(--ink-soft);
    margin-bottom: var(--space-2xl);
    line-height: var(--leading-relaxed);
  }

  .home-link {
    font-family: var(--font-body);
    font-size: var(--body-secondary);
    color: var(--accent);
    text-decoration: none;
    padding: var(--space-md) var(--space-xl);
    border: 1px solid var(--border-accent);
    border-radius: var(--radius-md);
    transition: all 0.2s ease;
  }

  .home-link:hover {
    background: var(--surface-accent-soft);
    transform: translateY(-2px);
  }
</style>
