---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getProtocols, getMuscles, getSkills, getTemplates } from '../../lib/hub';

const protocols = getProtocols();
const muscles = getMuscles();
const skills = getSkills();
const templates = getTemplates();
const total = protocols.length + muscles.length + skills.length + templates.length;

const typeConfig = {
  protocol: { glyph: '🧬', color: 'rgba(168, 232, 168, 0.25)', label: 'Behavioral rules' },
  muscle:   { glyph: '◎', color: 'rgba(232, 168, 124, 0.25)', label: 'Learned patterns' },
  skill:    { glyph: '◈', color: 'rgba(124, 178, 212, 0.25)', label: 'Domain expertise' },
  template: { glyph: '⟐', color: 'rgba(190, 152, 232, 0.25)', label: 'Agent configs' },
};
---

<Layout
  title="Hub — Soma"
  description="Browse and install community protocols, muscles, skills, and templates for Soma agents."
  canonicalUrl="https://soma.gravicity.ai/hub"
>
  <div class="stars"></div>

  <main class="container">
    <Breadcrumbs items={[
      { label: 'Hub', href: '/hub' },
    ]} />

    <header class="header">
      <h1 class="title">SomaHub</h1>
      <p class="subtitle">
        {total} community resources — protocols, muscles, skills, and templates. 
        Browse, copy, or install with <code>soma community install</code>.
      </p>
    </header>

    <!-- Quick install -->
    <div class="install-banner">
      <code>soma community install protocol breath-cycle</code>
      <p class="install-note">Or copy directly from <a href="https://github.com/meetsoma/community" target="_blank" rel="noopener">meetsoma/community</a></p>
    </div>

    <!-- Protocols -->
    {protocols.length > 0 && (
      <section class="hub-section">
        <div class="section-header">
          <span class="section-glyph">{typeConfig.protocol.glyph}</span>
          <div>
            <h2 class="section-title">Protocols</h2>
            <p class="section-desc">{typeConfig.protocol.label} — how your agent acts</p>
          </div>
          <span class="section-count">{protocols.length}</span>
        </div>
        <div class="card-grid">
          {protocols.map(p => (
            <a href={`/hub/${p.type}/${p.slug}`} class="hub-card" style={`--card-accent: ${typeConfig.protocol.color}`}>
              <div class="card-top">
                <h3 class="card-name">{p.name}</h3>
                <span class="card-version">v{p.version}</span>
              </div>
              <p class="card-desc">{p.breadcrumb || p.description}</p>
              <div class="card-meta">
                <span class="card-author">{p.author}</span>
                {p.heatDefault && <span class="card-heat">{p.heatDefault}</span>}
                {p.appliesTo && <span class="card-scope">{(p.appliesTo as string[]).join(', ')}</span>}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Muscles -->
    {muscles.length > 0 && (
      <section class="hub-section">
        <div class="section-header">
          <span class="section-glyph">{typeConfig.muscle.glyph}</span>
          <div>
            <h2 class="section-title">Muscles</h2>
            <p class="section-desc">{typeConfig.muscle.label} — reusable workflows</p>
          </div>
          <span class="section-count">{muscles.length}</span>
        </div>
        <div class="card-grid">
          {muscles.map(m => (
            <a href={`/hub/${m.type}/${m.slug}`} class="hub-card" style={`--card-accent: ${typeConfig.muscle.color}`}>
              <div class="card-top">
                <h3 class="card-name">{m.name}</h3>
                <span class="card-version">v{m.version}</span>
              </div>
              <p class="card-desc">{m.description}</p>
              <div class="card-meta">
                <span class="card-author">{m.author}</span>
                {m.topic && <span class="card-scope">{(m.topic as string[]).slice(0, 3).join(', ')}</span>}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Skills -->
    {skills.length > 0 && (
      <section class="hub-section">
        <div class="section-header">
          <span class="section-glyph">{typeConfig.skill.glyph}</span>
          <div>
            <h2 class="section-title">Skills</h2>
            <p class="section-desc">{typeConfig.skill.label} — task-specific knowledge</p>
          </div>
          <span class="section-count">{skills.length}</span>
        </div>
        <div class="card-grid">
          {skills.map(s => (
            <a href={`/hub/${s.type}/${s.slug}`} class="hub-card" style={`--card-accent: ${typeConfig.skill.color}`}>
              <div class="card-top">
                <h3 class="card-name">{s.name}</h3>
                <span class="card-version">v{s.version}</span>
              </div>
              <p class="card-desc">{s.description}</p>
              <div class="card-meta">
                <span class="card-author">{s.author}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Templates -->
    {templates.length > 0 && (
      <section class="hub-section">
        <div class="section-header">
          <span class="section-glyph">{typeConfig.template.glyph}</span>
          <div>
            <h2 class="section-title">Templates</h2>
            <p class="section-desc">{typeConfig.template.label} — full agent bundles</p>
          </div>
          <span class="section-count">{templates.length}</span>
        </div>
        <div class="card-grid">
          {templates.map(t => (
            <a href={`/hub/${t.type}/${t.slug}`} class="hub-card" style={`--card-accent: ${typeConfig.template.color}`}>
              <div class="card-top">
                <h3 class="card-name">{t.name}</h3>
              </div>
              <p class="card-desc">{t.body.split('\n').find((l: string) => l.trim() && !l.startsWith('#')) || ''}</p>
              <div class="card-meta">
                <code class="card-cmd">soma init --template {t.slug}</code>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Contribute CTA -->
    <section class="contribute">
      <h2>Share yours</h2>
      <p>Got a protocol your agent swears by? A muscle that saves you hours? Share it.</p>
      <a href="https://github.com/meetsoma/community" target="_blank" rel="noopener" class="contribute-link">
        Contribute on GitHub →
      </a>
    </section>

  </main>
</Layout>

<style>
  .stars {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 20px 30px, rgba(228,234,244,0.6), transparent),
      radial-gradient(1px 1px at 150px 100px, rgba(124,178,212,0.5), transparent);
    background-size: 400px 180px;
    animation: twinkle 10s ease-in-out infinite alternate;
  }
  @keyframes twinkle { 0% { opacity: 0.3; } 100% { opacity: 0.6; } }

  .container {
    position: relative; z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: 40px 24px;
    min-height: 100vh;
  }

  .header { text-align: center; margin-bottom: 32px; }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 2.8rem);
    font-weight: 700;
    margin-bottom: 12px;
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .subtitle code {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  /* Install banner */
  .install-banner {
    text-align: center;
    margin-bottom: 48px;
    padding: 20px;
    border-radius: 12px;
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
  }

  .install-banner code {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 8px 16px;
    border-radius: 6px;
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  .install-note {
    margin-top: 8px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .install-note a {
    color: var(--accent-bright);
    text-decoration: none;
  }

  .install-note a:hover { text-decoration: underline; }

  /* Sections */
  .hub-section { margin-bottom: 48px; }

  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .section-glyph {
    font-size: 1.6rem;
    line-height: 1;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
  }

  .section-desc {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .section-count {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    background: var(--surface-interactive);
    padding: 4px 10px;
    border-radius: 99px;
  }

  /* Card grid */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  .hub-card {
    display: flex;
    flex-direction: column;
    padding: 20px;
    border-radius: 12px;
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.2s ease;
    border-left: 3px solid var(--card-accent, var(--border-subtle));
  }

  .hub-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--shadow-accent-soft);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 8px;
  }

  .card-name {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    text-transform: capitalize;
  }

  .card-version {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .card-desc {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.5;
    flex: 1;
    margin-bottom: 12px;
    /* Clamp to 3 lines */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 0.72rem;
  }

  .card-author {
    color: var(--text-muted);
  }

  .card-heat {
    color: var(--warm-bright);
    font-style: italic;
  }

  .card-scope {
    color: var(--accent-bright);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .card-cmd {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  /* Contribute */
  .contribute {
    text-align: center;
    padding: 40px 24px;
    border-radius: 16px;
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    margin-bottom: 48px;
  }

  .contribute h2 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .contribute p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 16px;
  }

  .contribute-link {
    display: inline-block;
    padding: 10px 24px;
    border-radius: 8px;
    background: var(--accent-bright);
    color: var(--bg-deep);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .contribute-link:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px var(--shadow-accent-mid);
  }

  @media (max-width: 480px) {
    .container { padding: 24px 16px; }
    .card-grid { grid-template-columns: 1fr; }
    .section-header { flex-wrap: wrap; }
  }
</style>
