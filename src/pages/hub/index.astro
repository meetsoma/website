---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import HubFilters from '../../components/islands/HubFilters';
import HubGrid from '../../components/islands/HubGrid';
import { getProtocols, getMuscles, getSkills, getTemplates } from '../../lib/hub';

const protocols = getProtocols();
const muscles = getMuscles();
const skills = getSkills();
const templates = getTemplates();

// Serialize for Preact islands
const allItems = [
  ...protocols.map(p => ({ ...p, body: undefined })),
  ...muscles.map(m => ({ ...m, body: undefined })),
  ...skills.map(s => ({ ...s, body: undefined })),
  ...templates.map(t => ({ ...t, body: undefined })),
];

const total = allItems.length;
---

<Layout
  title="Hub — Soma"
  description="Browse and install community protocols, muscles, skills, and templates for Soma agents."
  canonicalUrl="https://soma.gravicity.ai/hub"
>
  <div class="stars"></div>

  <main class="container">
    <Breadcrumbs items={[
      { label: 'Hub', href: '/hub' },
    ]} />

    <header class="header">
      <h1 class="title">SomaHub</h1>
      <p class="subtitle">
        {total} community resources for Soma agents. Protocols enforce behavior.
        Muscles learn from repetition. Skills bring expertise. Templates bundle it all.
      </p>
    </header>

    <!-- Quick install -->
    <div class="install-banner">
      <code>/install protocol breath-cycle</code>
      <p class="install-note">
        Install from the hub directly in your session, or copy from
        <a href="https://github.com/meetsoma/community" target="_blank" rel="noopener">meetsoma/community</a>
      </p>
    </div>

    <!-- How they work together -->
    <div class="evolution-banner">
      <h3>How Soma content evolves</h3>
      <div class="evolution-flow">
        <div class="evo-step">
          <span class="evo-glyph">◈</span>
          <strong>Skills</strong>
          <span class="evo-desc">Plug-and-play knowledge — works across any agent framework</span>
        </div>
        <span class="evo-arrow">→</span>
        <div class="evo-step">
          <span class="evo-glyph">◎</span>
          <strong>Muscles</strong>
          <span class="evo-desc">Learned patterns — refine skills through repeated use</span>
        </div>
        <span class="evo-arrow">→</span>
        <div class="evo-step">
          <span class="evo-glyph">🧬</span>
          <strong>Protocols</strong>
          <span class="evo-desc">Behavioral rules — crystallized patterns that enforce consistency</span>
        </div>
        <span class="evo-arrow">→</span>
        <div class="evo-step">
          <span class="evo-glyph">⚙</span>
          <strong>Scripts</strong>
          <span class="evo-desc">Automation — protocols become executable, running without thinking</span>
        </div>
      </div>
      <p class="evo-note">
        Skills from Claude Code, OpenClaw, or any agent system work out of the box.
        Soma's muscles and protocols <em>refine</em> them — your agent improves each time without being asked.
      </p>
    </div>

    <!-- Filters (Preact island) -->
    <HubFilters client:load />

    <!-- Grid (Preact island, reacts to filter state) -->
    <HubGrid items={allItems} client:load />

    <!-- Contribute CTA -->
    <section class="contribute">
      <h2>Share yours</h2>
      <p>
        Got a protocol your agent swears by? A muscle that saves you hours?
        A skill from another framework that works great with Soma?
      </p>
      <a href="https://github.com/meetsoma/community" target="_blank" rel="noopener" class="contribute-link">
        Contribute on GitHub →
      </a>
    </section>

  </main>
</Layout>

<style>
  .stars {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 20px 30px, rgba(228,234,244,0.6), transparent),
      radial-gradient(1px 1px at 150px 100px, rgba(124,178,212,0.5), transparent);
    background-size: 400px 180px;
    animation: twinkle 10s ease-in-out infinite alternate;
  }
  @keyframes twinkle { 0% { opacity: 0.3; } 100% { opacity: 0.6; } }

  .container {
    position: relative; z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-xl);
    min-height: 100vh;
  }

  .header { text-align: center; margin-bottom: var(--space-2xl); }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 2.8rem);
    font-weight: 700;
    margin-bottom: var(--space-lg);
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: var(--text-md);
    max-width: 600px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  /* Install banner */
  .install-banner {
    text-align: center;
    margin-bottom: var(--space-xl);
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
  }

  .install-banner code {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-base);
    padding: var(--space-md) 16px;
    border-radius: var(--radius-md);
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  .install-note {
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .install-note a {
    color: var(--accent-bright);
    text-decoration: none;
  }

  .install-note a:hover { text-decoration: underline; }

  /* Evolution banner */
  .evolution-banner {
    margin-bottom: var(--space-2xl);
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
  }

  .evolution-banner h3 {
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: 600;
    margin-bottom: var(--space-lg);
    text-align: center;
  }

  .evolution-flow {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-lg);
  }

  .evo-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-sm);
    max-width: 140px;
  }

  .evo-glyph {
    font-size: var(--text-2xl);
    line-height: var(--leading-none);
    margin-bottom: var(--space-sm);
  }

  .evo-step strong {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .evo-desc {
    font-size: var(--text-xs);
    color: var(--text-muted);
    line-height: var(--leading-normal);
  }

  .evo-arrow {
    color: var(--text-muted);
    font-size: var(--text-xl);
    align-self: center;
    margin-top: -12px;
  }

  .evo-note {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-align: center;
    line-height: var(--leading-normal);
  }

  .evo-note em {
    color: var(--accent-bright);
    font-style: normal;
    font-weight: 500;
  }

  /* Filter styles (for the Preact island) */
  :global(.hub-filters) {
    margin-bottom: var(--space-2xl);
  }

  :global(.filter-row) {
    margin-bottom: var(--space-lg);
  }

  :global(.filter-pills) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  :global(.pill) {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-full);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    color: var(--text-secondary);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  :global(.pill:hover) {
    border-color: var(--border-accent);
    color: var(--text-primary);
  }

  :global(.pill.active) {
    background: var(--surface-accent-soft);
    border-color: var(--accent-bright);
    color: var(--accent-bright);
    font-weight: 500;
  }

  :global(.pill-glyph) {
    font-size: var(--text-base);
    line-height: var(--leading-none);
  }

  :global(.filter-row-secondary) {
    display: flex;
    gap: var(--space-md);
    align-items: center;
    flex-wrap: wrap;
  }

  :global(.tier-select) {
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    cursor: pointer;
  }

  :global(.search-wrapper) {
    position: relative;
    flex: 1;
    min-width: 180px;
  }

  :global(.search-input) {
    width: 100%;
    padding: var(--space-sm) var(--space-2xl) var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--text-sm);
  }

  :global(.search-input::placeholder) {
    color: var(--text-muted);
  }

  :global(.search-input:focus) {
    outline: none;
    border-color: var(--accent-bright);
  }

  :global(.search-clear) {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: var(--text-lg);
    cursor: pointer;
    padding: 2px;
    line-height: var(--leading-none);
  }

  :global(.reset-btn) {
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
    background: transparent;
    color: var(--text-muted);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  :global(.reset-btn:hover) {
    border-color: var(--warm-bright);
    color: var(--warm-bright);
  }

  /* Hub grid (shared between Astro fallback and Preact island) */
  :global(.hub-empty) {
    text-align: center;
    padding: var(--space-3xl) var(--space-xl);
    color: var(--text-muted);
    font-size: var(--text-base);
  }

  :global(.hub-section) { margin-bottom: var(--space-3xl); }

  :global(.section-header) {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-subtle);
  }

  :global(.section-glyph) {
    font-size: var(--text-2xl);
    line-height: var(--leading-none);
  }

  :global(.section-title) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
  }

  :global(.section-desc) {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  :global(.section-count) {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    background: var(--surface-interactive);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-full);
  }

  :global(.card-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-lg);
  }

  :global(.hub-card) {
    display: flex;
    flex-direction: column;
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.2s ease;
    border-left: 3px solid var(--card-accent, var(--border-subtle));
  }

  :global(.hub-card:hover) {
    border-color: var(--border-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--shadow-accent-soft);
  }

  :global(.card-top) {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-md);
  }

  :global(.card-name) {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    text-transform: capitalize;
  }

  :global(.card-version) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  :global(.card-desc) {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    flex: 1;
    margin-bottom: var(--space-lg);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(.card-meta) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    font-size: var(--text-xs);
  }

  :global(.card-author) { color: var(--text-muted); }
  :global(.card-heat) { color: var(--warm-bright); font-style: italic; }

  :global(.card-tag) {
    color: var(--accent-bright);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 1px var(--space-sm);
    border-radius: var(--radius-sm);
    background: var(--surface-accent-soft);
  }

  :global(.card-tier) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px var(--space-sm);
    border-radius: var(--radius-sm);
  }

  :global(.tier-core) {
    background: rgba(124, 178, 212, 0.2);
    color: var(--accent-bright);
  }

  :global(.tier-official) {
    background: rgba(168, 232, 168, 0.2);
    color: rgb(168, 232, 168);
  }

  :global(.tier-community) {
    background: rgba(168, 232, 168, 0.15);
    color: rgb(140, 200, 140);
  }

  :global(.tier-experimental) {
    background: rgba(232, 168, 124, 0.2);
    color: rgb(232, 168, 124);
  }

  /* Contribute */
  .contribute {
    text-align: center;
    padding: var(--space-2xl) var(--space-xl);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    margin-bottom: var(--space-3xl);
  }

  .contribute h2 {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    margin-bottom: var(--space-md);
  }

  .contribute p {
    color: var(--text-secondary);
    font-size: var(--text-base);
    margin-bottom: var(--space-lg);
  }

  .contribute-link {
    display: inline-block;
    padding: var(--space-md) var(--space-xl);
    border-radius: var(--radius-md);
    background: var(--accent-bright);
    color: var(--bg-deep);
    font-weight: 600;
    font-size: var(--text-base);
    text-decoration: none;
    transition: all 0.2s;
  }

  .contribute-link:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px var(--shadow-accent-mid);
  }

  @media (max-width: 480px) {
    .container { padding: var(--space-xl) var(--space-lg); }
    :global(.card-grid) { grid-template-columns: 1fr; }
    :global(.section-header) { flex-wrap: wrap; }
    .evolution-flow { flex-direction: column; align-items: center; }
    .evo-arrow { transform: rotate(90deg); }
  }
</style>
