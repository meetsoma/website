---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Icon from '../../components/icons/SomaIcons.astro';
import HubFilters from '../../components/islands/HubFilters';
import HubGrid from '../../components/islands/HubGrid';
import { getProtocols, getMuscles, getSkills, getTemplates, getAutomations, getScripts } from '../../lib/hub';
import HeroTitle from '../../components/HeroTitle.astro';

const protocols = getProtocols();
const muscles = getMuscles();
const skills = getSkills();
const templates = getTemplates();
const automations = getAutomations();
const scripts = getScripts();

// Serialize for Preact islands
const allItems = [
  ...protocols.map(p => ({ ...p, body: undefined })),
  ...muscles.map(m => ({ ...m, body: undefined })),
  ...skills.map(s => ({ ...s, body: undefined })),
  ...templates.map(t => ({ ...t, body: undefined })),
  ...automations.map(a => ({ ...a, body: undefined })),
  ...scripts.map(s => ({ ...s, body: undefined })),
];

const total = allItems.length;

const hubJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: 'Soma Hub',
      description: 'Community AMPS — Automations, Muscles, Protocols, Skills — and templates for Soma agents.',
      url: 'https://soma.gravicity.ai/hub',
      numberOfItems: total,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://soma.gravicity.ai' },
        { '@type': 'ListItem', position: 2, name: 'Hub', item: 'https://soma.gravicity.ai/hub' },
      ],
    },
  ],
};
---

<Layout
  title="Hub — σ"
  description="Browse and install community AMPS — Automations, Muscles, Protocols, Skills — and templates for Soma agents."
  canonicalUrl="https://soma.gravicity.ai/hub"
  jsonLd={hubJsonLd}
>
  <div class="stars"></div>

  <main class="container">
    <Breadcrumbs items={[
      { label: 'Hub', href: '/hub' },
    ]} />

    <header class="header">
      <HeroTitle text="SomaHub" align="center" />
      <p class="subtitle">
        {total} community AMPS for Soma agents. Skills bring expertise.
        Muscles learn from repetition. Protocols enforce behavior.
        Automations run without thinking. Templates bundle it all.
      </p>
    </header>

    <!-- Quick install -->
    <div class="install-banner">
      <code>/install protocol breath-cycle</code>
      <p class="install-note">
        Install from the hub directly in your session, or copy from
        <a href="/docs/getting-started">getting started guide</a>
      </p>
    </div>

    <!-- How they work together -->
    <div class="evolution-banner">
      <h2>How AMPS evolve</h2>
      <div class="evolution-flow">
        <div class="evo-step">
          <span class="evo-glyph"><Icon name="skills" size={21} /></span>
          <strong>Skills</strong>
          <span class="evo-desc">Plug-and-play knowledge — works across any agent framework</span>
        </div>
        <span class="evo-arrow">→</span>
        <div class="evo-step">
          <span class="evo-glyph"><Icon name="muscles" size={21} /></span>
          <strong>Muscles</strong>
          <span class="evo-desc">Learned patterns — refine skills through repeated use</span>
        </div>
        <span class="evo-arrow">→</span>
        <div class="evo-step">
          <span class="evo-glyph"><Icon name="protocols" size={21} /></span>
          <strong>Protocols</strong>
          <span class="evo-desc">Behavioral rules — crystallized patterns that enforce consistency</span>
        </div>
        <span class="evo-arrow">→</span>
        <div class="evo-step">
          <span class="evo-glyph"><Icon name="extensions" size={21} /></span>
          <strong>Automations</strong>
          <span class="evo-desc">Executable — protocols become workflows that run without thinking</span>
        </div>
      </div>
      <p class="evo-note">
        Skills from Claude Code, OpenClaw, or any agent system work out of the box.
        Soma's muscles and protocols <em>refine</em> them — your agent improves each time without being asked.
      </p>
    </div>

    <!-- Pi Ecosystem -->
    <section class="contribute">
      <h2>5,231+ extensions from the Pi ecosystem</h2>
      <p>
        Soma is built on Pi and inherits its full extension system. Every extension,
        skill, theme, and prompt published on <a href="https://pi.dev/packages">pi.dev</a>
        is cross-compatible. Same ExtensionAPI, same runtime. Install any package
        directly from npm.
      </p>
      <p><code>soma install npm:@scope/package</code></p>
      <p><code>soma:extensions.search(&#123;query:'keyword'&#125;)</code></p>
      <a href="https://pi.dev/packages" class="contribute-link">Browse 5,231+ packages →</a>
    </section>

    <!-- Filters (Preact island) -->
    <HubFilters client:load />

    <!-- Grid (Preact island, reacts to filter state) -->
    <HubGrid items={allItems} client:load />

    <!-- Contribute CTA -->
    <section class="contribute">
      <h2>Contribute</h2>
      <p>
        Got a protocol your agent swears by? A muscle that saves you hours?
        Soma is source-available — contribute to the hub.
      </p>
      <a href="/docs/extending" class="contribute-link">
        Learn how to contribute →
      </a>
    </section>

  </main>
</Layout>

<style>
  .stars {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 20px 30px, rgba(228,234,244,0.6), transparent),
      radial-gradient(1px 1px at 150px 100px, rgba(124,178,212,0.5), transparent);
    background-size: 400px 180px;
    animation: twinkle 10s ease-in-out infinite alternate;
  }
  @keyframes twinkle { 0% { opacity: 0.3; } 100% { opacity: 0.6; } }

  .container {
    position: relative; z-index: 1;
    max-width: 890px;
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-xl) var(--space-2xl);
    min-height: 100vh;
  }

  .header { text-align: center; margin-bottom: var(--section-gap); }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 2.625rem);
    font-weight: 800;
    margin-bottom: var(--space-lg);
  }

  .subtitle {
    color: var(--ink-soft);
    font-size: var(--text-lg);
    max-width: var(--content-narrow);
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  /* Install banner */
  .install-banner {
    text-align: center;
    margin-bottom: var(--space-2xl);
    padding: var(--card-pad-y) var(--card-pad-x);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--surface-card);
  }

  .install-banner code {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--body-secondary);
    padding: var(--space-md) 16px;
    border-radius: var(--radius-md);
    background: var(--surface-accent-soft);
    color: var(--accent);
  }

  .install-note {
    margin-top: var(--space-md);
    font-size: var(--body-text);
    color: var(--ink-muted);
  }

  .install-note a {
    color: var(--accent);
    text-decoration: none;
  }

  .install-note a:hover { text-decoration: underline; }

  /* Evolution banner */
  .evolution-banner {
    margin-bottom: var(--section-gap);
    padding: var(--card-pad-y) var(--card-pad-x);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--surface-card);
  }

  .evolution-banner h2 {
    font-family: var(--font-display);
    font-size: var(--body-text);
    font-weight: 600;
    margin-bottom: var(--space-lg);
    text-align: center;
  }

  .evolution-flow {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-lg);
  }

  .evo-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-sm);
    max-width: 165px;
  }

  .evo-glyph {
    font-size: var(--text-2xl);
    line-height: var(--leading-none);
    margin-bottom: var(--space-sm);
  }

  .evo-step strong {
    font-family: var(--font-display);
    font-size: var(--body-secondary);
    font-weight: 600;
  }

  .evo-desc {
    font-size: var(--body-secondary);
    color: var(--ink-soft);
    line-height: var(--leading-relaxed);
  }

  .evo-arrow {
    color: var(--ink-muted);
    font-size: var(--text-xl);
    align-self: center;
    margin-top: -12px;
  }

  .evo-note {
    font-size: var(--body-text);
    color: var(--ink-soft);
    text-align: center;
    line-height: var(--leading-normal);
  }

  .evo-note em {
    color: var(--accent);
    font-style: normal;
    font-weight: 500;
  }

  /* Filter styles (for the Preact island) */
  :global(.hub-filters) {
    margin-bottom: var(--space-2xl);
  }

  :global(.filter-row) {
    margin-bottom: var(--space-lg);
  }

  :global(.filter-pills) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  :global(.pill) {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    background: var(--surface-card);
    color: var(--ink-soft);
    font-family: var(--font-body);
    font-size: var(--label-text);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  :global(.pill:hover) {
    border-color: var(--border-accent);
    color: var(--ink);
  }

  :global(.pill.active) {
    background: var(--surface-accent-soft);
    border-color: var(--accent);
    color: var(--accent);
    font-weight: 500;
  }

  :global(.pill-glyph) {
    font-size: var(--body-secondary);
    line-height: var(--leading-none);
  }

  :global(.filter-row-secondary) {
    display: flex;
    gap: var(--space-md);
    align-items: center;
    flex-wrap: wrap;
  }

  :global(.tier-select) {
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    background: var(--surface-card);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: var(--label-text);
    cursor: pointer;
  }

  :global(.search-wrapper) {
    position: relative;
    flex: 1;
    min-width: 180px;
  }

  :global(.search-input) {
    width: 100%;
    padding: var(--space-sm) var(--space-2xl) var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    background: var(--surface-card);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: var(--label-text);
  }

  :global(.search-input::placeholder) {
    color: var(--ink-muted);
  }

  :global(.search-input:focus) {
    outline: none;
    border-color: var(--accent);
  }

  :global(.search-clear) {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--ink-muted);
    font-size: var(--text-lg);
    cursor: pointer;
    padding: 2px;
    line-height: var(--leading-none);
  }

  :global(.reset-btn) {
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    background: transparent;
    color: var(--ink-muted);
    font-family: var(--font-body);
    font-size: var(--badge-text);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  :global(.reset-btn:hover) {
    border-color: var(--promo-text);
    color: var(--promo-text);
  }

  /* Hub grid (shared between Astro fallback and Preact island) */
  :global(.hub-empty) {
    text-align: center;
    padding: var(--space-3xl) var(--space-xl);
    color: var(--ink-muted);
    font-size: var(--body-secondary);
  }

  :global(.hub-section) { margin-bottom: var(--section-gap); }

  :global(.section-header) {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border);
  }

  :global(.section-glyph) {
    font-size: var(--text-2xl);
    line-height: var(--leading-none);
  }

  :global(.section-title) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
  }

  :global(.section-desc) {
    font-size: var(--body-text);
    color: var(--ink-muted);
  }

  :global(.section-count) {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--label-text);
    color: var(--ink-muted);
    background: var(--surface-interactive);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-full);
  }

  :global(.card-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--grid-gap);
  }

  :global(.hub-card) {
    display: flex;
    flex-direction: column;
    padding: var(--card-pad-y) var(--card-pad-x);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--surface-card);
    text-decoration: none;
    color: var(--ink);
    transition: all 0.2s ease;
    border-left: 3px solid var(--card-accent, var(--border));
  }

  :global(.hub-card:hover) {
    border-color: var(--border-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--shadow-accent-soft);
  }

  :global(.card-top) {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-md);
  }

  :global(.card-name) {
    font-family: var(--font-display);
    font-size: var(--body-secondary);
    font-weight: 600;
    text-transform: capitalize;
  }

  :global(.card-version) {
    font-family: var(--font-mono);
    font-size: var(--badge-text);
    color: var(--ink-muted);
  }

  :global(.card-desc) {
    font-size: var(--body-text);
    color: var(--ink-soft);
    line-height: var(--leading-normal);
    flex: 1;
    margin-bottom: var(--space-lg);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(.card-meta) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
    font-size: var(--badge-text);
  }

  :global(.card-author) {
    color: var(--ink-muted);
    font-size: var(--badge-text);
    margin-top: var(--space-sm);
  }
  :global(.card-heat) { color: var(--promo-text); font-style: italic; }

  :global(.card-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  :global(.card-tag) {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--badge-text);
    padding: 1px var(--space-sm);
    border-radius: var(--radius-sm);
    background: var(--surface-accent-soft);
  }

  :global(.card-tier) {
    font-family: var(--font-mono);
    font-size: var(--badge-text);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px var(--space-sm);
    border-radius: var(--radius-sm);
  }

  :global(.tier-core) {
    background: rgba(124, 178, 212, 0.2);
    color: var(--accent);
  }

  :global(.tier-official) {
    background: rgba(168, 232, 168, 0.2);
    color: rgb(168, 232, 168);
  }

  :global(.tier-community) {
    background: rgba(168, 232, 168, 0.15);
    color: rgb(140, 200, 140);
  }

  :global(.tier-pro) {
    background: rgba(232, 168, 124, 0.2);
    color: rgb(232, 168, 124);
  }

  /* Contribute */
  .contribute {
    text-align: center;
    padding: var(--card-pad-y) var(--card-pad-x);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border);
    background: var(--surface-card);
    margin-bottom: var(--section-gap);
  }

  .contribute h2 {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    margin-bottom: var(--space-md);
  }

  .contribute p {
    color: var(--ink-soft);
    font-size: var(--body-text);
    margin-bottom: var(--space-lg);
  }

  .contribute-link {
    display: inline-block;
    padding: var(--space-md) var(--space-xl);
    border-radius: var(--radius-md);
    background: var(--accent);
    color: var(--bg);
    font-weight: 600;
    font-size: var(--body-secondary);
    text-decoration: none;
    transition: all 0.2s;
  }

  .contribute-link:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px var(--shadow-accent-mid);
  }

  @media (max-width: 480px) {
    .container { padding: var(--space-xl) var(--space-lg); }
    :global(.card-grid) { grid-template-columns: 1fr; }
    :global(.section-header) { flex-wrap: wrap; }
    .evolution-flow { flex-direction: column; align-items: center; }
    .evo-arrow { transform: rotate(90deg); }
  }
</style>
