---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { getAllItems, type HubItem, renderMarkdown } from '../../../lib/hub';

export function getStaticPaths() {
  const items = getAllItems();
  return items.map((item) => ({
    params: { type: item.type, slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props as { item: HubItem };

const typeLabels: Record<string, string> = {
  protocol: 'Protocol',
  muscle: 'Muscle',
  skill: 'Skill',
  template: 'Template',
};

const typeGlyphs: Record<string, string> = {
  protocol: '🧬',
  muscle: '◎',
  skill: '◈',
  template: '⟐',
};

const installCmd = item.type === 'template'
  ? `soma init --template ${item.slug}`
  : `soma community install ${item.type} ${item.slug}`;

const ghUrl = item.type === 'template'
  ? `https://github.com/meetsoma/community/tree/main/templates/${item.slug}`
  : `https://github.com/meetsoma/community/blob/main/${item.type}s/${item.slug}.md`;
---

<Layout
  title={`${item.name} — ${typeLabels[item.type]} — SomaHub`}
  description={item.breadcrumb || item.description || `${item.name} ${item.type} for Soma agents.`}
  canonicalUrl={`https://soma.gravicity.ai/hub/${item.type}/${item.slug}`}
>
  <div class="stars"></div>

  <main class="container">
    <Breadcrumbs items={[
      { label: 'Hub', href: '/hub' },
      { label: typeLabels[item.type] + 's', href: '/hub#' + item.type + 's' },
      { label: item.name, href: `/hub/${item.type}/${item.slug}` },
    ]} />

    <header class="header">
      <span class="type-badge">{typeGlyphs[item.type]} {typeLabels[item.type]}</span>
      <h1 class="title">{item.name}</h1>
      {item.breadcrumb && <p class="breadcrumb">{item.breadcrumb}</p>}
      <div class="meta-row">
        {item.tier && <span class={`tier-badge tier-${item.tier}`}>{item.tier}</span>}
        <span class="meta-item">by {item.author}</span>
        {item.version && <span class="meta-item">v{item.version}</span>}
        {item.heatDefault && <span class="meta-item heat">heat: {item.heatDefault}</span>}
      </div>
      {item.tags && item.tags.length > 0 && (
        <div class="tag-row">
          {(item.tags as string[]).map(t => <span class="tag-pill">{t}</span>)}
        </div>
      )}
    </header>

    <!-- Install -->
    <section class="install-section">
      <h2>Install</h2>
      <code class="install-cmd">{installCmd}</code>
      <p class="install-alt">
        Or copy manually from 
        <a href={ghUrl} target="_blank" rel="noopener">GitHub →</a>
      </p>
    </section>

    <!-- Tags -->
    {(item.appliesTo || item.topic || item.keywords) && (
      <section class="tags-section">
        {item.appliesTo && (
          <div class="tag-group">
            <span class="tag-label">Applies to</span>
            <div class="tags">
              {(item.appliesTo as string[]).map(t => <span class="tag">{t}</span>)}
            </div>
          </div>
        )}
        {item.topic && (
          <div class="tag-group">
            <span class="tag-label">Topics</span>
            <div class="tags">
              {(item.topic as string[]).map(t => <span class="tag">{t}</span>)}
            </div>
          </div>
        )}
        {item.keywords && (
          <div class="tag-group">
            <span class="tag-label">Keywords</span>
            <div class="tags">
              {(item.keywords as string[]).map(t => <span class="tag tag-dim">{t}</span>)}
            </div>
          </div>
        )}
      </section>
    )}

    <!-- Body -->
    <section class="body-section">
      <div class="markdown-body" set:html={renderMarkdown(item.body)} />
    </section>

    <!-- Source -->
    <section class="source-section">
      <a href={ghUrl} target="_blank" rel="noopener" class="source-link">
        View source on GitHub →
      </a>
    </section>

  </main>
</Layout>

<style>
  .stars {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 20px 30px, rgba(228,234,244,0.6), transparent),
      radial-gradient(1px 1px at 150px 100px, rgba(124,178,212,0.5), transparent);
    background-size: 400px 180px;
    animation: twinkle 10s ease-in-out infinite alternate;
  }
  @keyframes twinkle { 0% { opacity: 0.3; } 100% { opacity: 0.6; } }

  .container {
    position: relative; z-index: 1;
    max-width: 760px;
    margin: 0 auto;
    padding: 40px 24px;
    min-height: 100vh;
  }

  .header { margin-bottom: 32px; }

  .type-badge {
    display: inline-block;
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--accent-bright);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 5vw, 2.4rem);
    font-weight: 700;
    text-transform: capitalize;
    margin-bottom: 12px;
  }

  .breadcrumb {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .meta-row {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .meta-item {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .meta-item.heat { color: var(--warm-bright); }

  .tier-badge {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 8px;
    border-radius: 4px;
  }

  .tier-core {
    background: rgba(124, 178, 212, 0.2);
    color: var(--accent-bright);
  }

  .tier-official {
    background: rgba(168, 232, 168, 0.2);
    color: rgb(168, 232, 168);
  }

  .tier-community {
    background: rgba(168, 232, 168, 0.15);
    color: rgb(140, 200, 140);
  }

  .tier-experimental {
    background: rgba(232, 168, 124, 0.2);
    color: rgb(232, 168, 124);
  }

  .tag-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  .tag-pill {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  /* Install */
  .install-section {
    padding: 24px;
    border-radius: 12px;
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    margin-bottom: 24px;
  }

  .install-section h2 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .install-cmd {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    padding: 12px 16px;
    border-radius: 8px;
    background: var(--bg-elevated);
    color: var(--accent-bright);
    margin-bottom: 8px;
    overflow-x: auto;
  }

  .install-alt {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .install-alt a {
    color: var(--accent-bright);
    text-decoration: none;
  }

  .install-alt a:hover { text-decoration: underline; }

  /* Tags */
  .tags-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
  }

  .tag-group {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tag-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    min-width: 80px;
  }

  .tags { display: flex; gap: 6px; flex-wrap: wrap; }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  .tag-dim {
    background: var(--surface-interactive);
    color: var(--text-secondary);
  }

  /* Body */
  .body-section {
    padding: 32px;
    border-radius: 12px;
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    margin-bottom: 24px;
  }

  .body-section :global(h2) {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 24px 0 12px;
    padding-top: 16px;
    border-top: 1px solid var(--border-subtle);
  }

  .body-section :global(h2:first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .body-section :global(h3) {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    margin: 16px 0 8px;
  }

  .body-section :global(p) {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 12px;
    font-size: 0.92rem;
  }

  .body-section :global(ul), .body-section :global(ol) {
    color: var(--text-secondary);
    padding-left: 20px;
    margin-bottom: 12px;
    font-size: 0.92rem;
  }

  .body-section :global(li) { margin-bottom: 4px; line-height: 1.6; }

  .body-section :global(code) {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 1px 5px;
    border-radius: 4px;
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  .body-section :global(pre) {
    background: var(--bg-elevated);
    padding: 16px;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 16px;
    font-size: 0.82rem;
    line-height: 1.5;
  }

  .body-section :global(pre code) {
    background: none;
    padding: 0;
    color: var(--text-secondary);
  }

  .body-section :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 16px;
    font-size: 0.85rem;
  }

  .body-section :global(th) {
    text-align: left;
    padding: 8px;
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.82rem;
  }

  .body-section :global(td) {
    padding: 8px;
    border-bottom: 1px solid var(--border-subtle);
    color: var(--text-secondary);
  }

  .body-section :global(strong) { color: var(--text-primary); }

  .body-section :global(em) { color: var(--text-secondary); }

  .body-section :global(blockquote) {
    border-left: 3px solid var(--accent-bright);
    padding-left: 16px;
    margin: 12px 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  /* Source */
  .source-section {
    text-align: center;
    margin-bottom: 48px;
  }

  .source-link {
    font-size: 0.88rem;
    color: var(--accent-bright);
    text-decoration: none;
  }

  .source-link:hover { text-decoration: underline; }

  @media (max-width: 480px) {
    .container { padding: 24px 16px; }
    .body-section { padding: 20px; }
  }
</style>
