---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Icon from '../../../components/icons/SomaIcons.astro';
import { getAllItems, getVersionHistory, resolveTemplateRequires, getCoreProtocols, type HubItem, type VersionEntry, renderMarkdown } from '../../../lib/hub';

export async function getStaticPaths() {
  const items = getAllItems();
  const paths = [];
  for (const item of items) {
    const versions = await getVersionHistory(item);
    // For templates, resolve their requirements
    const templateData = item.type === 'template'
      ? { ...resolveTemplateRequires(item), coreProtocols: getCoreProtocols() }
      : null;
    paths.push({
      params: { type: item.type, slug: item.slug },
      props: { item, versions, templateData },
    });
  }
  return paths;
}

interface TemplateData {
  required: HubItem[];
  missing: string[];
  coreProtocols: HubItem[];
}

const { item, versions, templateData } = Astro.props as {
  item: HubItem;
  versions: VersionEntry[];
  templateData: TemplateData | null;
};
const hasVersions = versions.length > 0;
const isTemplate = item.type === 'template' && templateData !== null;

const typeLabels: Record<string, string> = {
  protocol: 'Protocol',
  muscle: 'Muscle',
  skill: 'Skill',
  template: 'Template',
  automation: 'Automation',
};

const typeIconNames: Record<string, string> = {
  protocol: 'protocols',
  muscle: 'muscles',
  skill: 'skills',
  template: 'extensions',
  automation: 'extensions',
};

const installCmd = item.type === 'template'
  ? `soma init --template ${item.slug}`
  : `/install ${item.type} ${item.slug}`;

const ghUrl = item.type === 'template'
  ? `https://github.com/meetsoma/community/tree/main/templates/${item.slug}`
  : `https://github.com/meetsoma/community/blob/main/${item.type}s/${item.slug}.md`;
---

<Layout
  title={`${item.name} — ${typeLabels[item.type]} — SomaHub`}
  description={item.breadcrumb || item.description || `${item.name} ${item.type} for Soma agents.`}
  canonicalUrl={`https://soma.gravicity.ai/hub/${item.type}/${item.slug}`}
>
  <div class="stars"></div>

  <main class="container">
    <Breadcrumbs items={[
      { label: 'Hub', href: '/hub' },
      { label: typeLabels[item.type] + 's', href: '/hub#' + item.type + 's' },
      { label: item.name, href: `/hub/${item.type}/${item.slug}` },
    ]} />

    <header class="header">
      <span class="type-badge"><Icon name={typeIconNames[item.type] as any} size={16} /> {typeLabels[item.type]}</span>
      <h1 class="title">{item.name}</h1>
      {item.breadcrumb && <p class="breadcrumb">{item.breadcrumb}</p>}
      <div class="meta-row">
        {item.tier && <span class={`tier-badge tier-${item.tier}`}>{item.tier}</span>}
        <span class="meta-item">by {item.author}</span>
        {item.version && <span class="meta-item">v{item.version}</span>}
        {item.heatDefault && <span class="meta-item heat">heat: {item.heatDefault}</span>}
      </div>
      {item.tags && item.tags.length > 0 && (
        <div class="tag-row">
          {(item.tags as string[]).map(t => <span class="tag-pill">{t}</span>)}
        </div>
      )}
    </header>

    <!-- Install -->
    <section class="install-section">
      <h2>Install</h2>
      <code class="install-cmd">{installCmd}</code>
      <p class="install-alt">
        Or copy manually from 
        <a href={ghUrl} target="_blank" rel="noopener">GitHub →</a>
      </p>
    </section>

    <!-- Template Includes -->
    {isTemplate && (templateData!.required.length > 0 || templateData!.coreProtocols.length > 0) && (
      <section class="includes-section">
        <h2>What's Included</h2>
        
        {templateData!.required.length > 0 && (
          <div class="includes-grid">
            {templateData!.required.map(req => (
              <a href={`/hub/${req.type}/${req.slug}`} class="include-card" data-expanded="false">
                <div class="include-card-header">
                  <span class="include-type-icon"><Icon name={typeIconNames[req.type] as any} size={14} /></span>
                  <span class="include-name">{req.name}</span>
                  <span class={`include-tier tier-${req.tier || 'community'}`}>{req.tier || 'community'}</span>
                </div>
                {req.breadcrumb && (
                  <p class="include-desc">{req.breadcrumb}</p>
                )}
                {req.tags && req.tags.length > 0 && (
                  <div class="include-tags">
                    {(req.tags as string[]).slice(0, 4).map(t => <span class="include-tag">{t}</span>)}
                  </div>
                )}
              </a>
            ))}
          </div>
        )}

        {templateData!.missing.length > 0 && (
          <p class="include-missing">
            ⚠ Not found in hub: {templateData!.missing.join(', ')}
          </p>
        )}

        {templateData!.coreProtocols.length > 0 && (
          <div class="core-section">
            <h3 class="core-heading">Ships with Soma</h3>
            <p class="core-subtext">These core protocols are always available — no install needed.</p>
            <div class="includes-grid includes-grid-core">
              {templateData!.coreProtocols.map(cp => (
                <a href={`/hub/${cp.type}/${cp.slug}`} class="include-card include-card-core">
                  <div class="include-card-header">
                    <span class="include-type-icon"><Icon name="protocols" size={14} /></span>
                    <span class="include-name">{cp.name}</span>
                    <span class="include-tier tier-core">core</span>
                  </div>
                  {cp.breadcrumb && (
                    <p class="include-desc">{cp.breadcrumb}</p>
                  )}
                </a>
              ))}
            </div>
          </div>
        )}
      </section>
    )}

    <!-- Tags -->
    {(item.appliesTo || item.topic || item.keywords) && (
      <section class="tags-section">
        <h2 class="sr-only">Tags</h2>
        {item.appliesTo && (
          <div class="tag-group">
            <span class="tag-label">Applies to</span>
            <div class="tags">
              {(item.appliesTo as string[]).map(t => <span class="tag">{t}</span>)}
            </div>
          </div>
        )}
        {item.topic && (
          <div class="tag-group">
            <span class="tag-label">Topics</span>
            <div class="tags">
              {(item.topic as string[]).map(t => <span class="tag">{t}</span>)}
            </div>
          </div>
        )}
        {item.keywords && (
          <div class="tag-group">
            <span class="tag-label">Keywords</span>
            <div class="tags">
              {(item.keywords as string[]).map(t => <span class="tag tag-dim">{t}</span>)}
            </div>
          </div>
        )}
      </section>
    )}

    <!-- Body -->
    <section class="body-section">
      <h2>Details</h2>
      {hasVersions && (
        <div class="version-selector">
          <label for="version-select">Version</label>
          <select id="version-select">
            <option value="current" selected>v{item.version} (latest)</option>
            {versions.map(v => (
              <option value={v.sha}>v{v.version} — {v.date}</option>
            ))}
          </select>
        </div>
      )}

      <div class="markdown-body version-content" data-version="current" set:html={renderMarkdown(item.body)} />

      {versions.map(v => (
        <div class="markdown-body version-content" data-version={v.sha} style="display:none" set:html={renderMarkdown(v.body)} />
      ))}
    </section>

    <!-- Source -->
    <section class="source-section">
      <a href={ghUrl} target="_blank" rel="noopener" class="source-link">
        View source on GitHub →
      </a>
    </section>

    {hasVersions && (
      <script>
        document.getElementById('version-select')?.addEventListener('change', (e) => {
          const selected = (e.target as HTMLSelectElement).value;
          document.querySelectorAll('.version-content').forEach(el => {
            (el as HTMLElement).style.display = el.getAttribute('data-version') === selected ? '' : 'none';
          });
        });
      </script>
    )}

  </main>
</Layout>

<style>
  .stars {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 20px 30px, rgba(228,234,244,0.6), transparent),
      radial-gradient(1px 1px at 150px 100px, rgba(124,178,212,0.5), transparent);
    background-size: 400px 180px;
    animation: twinkle 10s ease-in-out infinite alternate;
  }
  @keyframes twinkle { 0% { opacity: 0.3; } 100% { opacity: 0.6; } }

  .container {
    position: relative; z-index: 1;
    max-width: 760px;
    margin: 0 auto;
    padding: var(--card-pad-y) var(--card-pad-x);
    min-height: 100vh;
  }

  .header { margin-bottom: var(--space-2xl); }

  .type-badge {
    display: inline-block;
    font-size: var(--label-text);
    font-family: var(--font-mono);
    color: var(--accent-bright);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-md);
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 5vw, 2.4rem);
    font-weight: 700;
    text-transform: capitalize;
    margin-bottom: var(--space-lg);
  }

  .breadcrumb {
    color: var(--text-secondary);
    font-size: var(--body-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-lg);
  }

  .meta-row {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .meta-item {
    font-family: var(--font-mono);
    font-size: var(--badge-text);
    color: var(--text-muted);
  }

  .meta-item.heat { color: var(--warm-bright); }

  .tier-badge {
    font-family: var(--font-mono);
    font-size: var(--badge-text);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px var(--space-md);
    border-radius: var(--radius-sm);
  }

  .tier-core {
    background: rgba(124, 178, 212, 0.2);
    color: var(--accent-bright);
  }

  .tier-official {
    background: rgba(168, 232, 168, 0.2);
    color: rgb(168, 232, 168);
  }

  .tier-community {
    background: rgba(168, 232, 168, 0.15);
    color: rgb(140, 200, 140);
  }

  .tier-experimental {
    background: rgba(232, 168, 124, 0.2);
    color: rgb(232, 168, 124);
  }

  .tag-row {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-md);
  }

  .tag-pill {
    font-family: var(--font-mono);
    font-size: var(--badge-text);
    padding: 2px var(--space-md);
    border-radius: var(--radius-sm);
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  /* Install */
  .install-section {
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    margin-bottom: var(--space-xl);
  }

  .install-section h2 {
    font-family: var(--font-display);
    font-size: var(--body-text);
    font-weight: 600;
    margin-bottom: var(--space-lg);
  }

  .install-cmd {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--body-secondary);
    padding: var(--space-lg);
    border-radius: var(--radius-md);
    background: var(--bg-elevated);
    color: var(--accent-bright);
    margin-bottom: var(--space-md);
    overflow-x: auto;
  }

  .install-alt {
    font-size: var(--label-text);
    color: var(--text-muted);
  }

  .install-alt a {
    color: var(--accent-bright);
    text-decoration: none;
  }

  .install-alt a:hover { text-decoration: underline; }

  /* Tags */
  .tags-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .tag-group {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .tag-label {
    font-family: var(--font-mono);
    font-size: var(--badge-text);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    min-width: 80px;
  }

  .tags { display: flex; gap: var(--space-sm); flex-wrap: wrap; }

  .tag {
    font-family: var(--font-mono);
    font-size: var(--badge-text);
    padding: 2px var(--space-md);
    border-radius: var(--radius-sm);
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  .tag-dim {
    background: var(--surface-interactive);
    color: var(--text-secondary);
  }

  /* Version selector */
  .version-selector {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: 20px;
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border-subtle);
  }

  .version-selector label {
    font-family: var(--font-mono);
    font-size: var(--badge-text);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .version-selector select {
    font-family: var(--font-mono);
    font-size: var(--label-text);
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
    background: var(--bg-elevated);
    color: var(--text-primary);
    cursor: pointer;
    outline: none;
  }

  .version-selector select:hover {
    border-color: var(--border-accent);
  }

  .version-selector select:focus {
    border-color: var(--accent-bright);
    box-shadow: 0 0 0 2px var(--shadow-accent-soft);
  }

  /* Body */
  .body-section {
    padding: var(--space-2xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    margin-bottom: var(--space-xl);
  }

  .body-section :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    margin: var(--space-xl) 0 var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border-subtle);
  }

  .body-section :global(h2:first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .body-section :global(h3) {
    font-family: var(--font-display);
    font-size: var(--body-text);
    font-weight: 600;
    margin: var(--space-lg) 0 var(--space-md);
  }

  .body-section :global(p) {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-lg);
    font-size: var(--body-secondary);
  }

  .body-section :global(ul), .body-section :global(ol) {
    color: var(--text-secondary);
    padding-left: 20px;
    margin-bottom: var(--space-lg);
    font-size: var(--body-secondary);
  }

  .body-section :global(li) { margin-bottom: var(--space-sm); line-height: var(--leading-relaxed); }

  .body-section :global(code) {
    font-family: var(--font-mono);
    font-size: var(--label-text);
    padding: 1px var(--space-sm);
    border-radius: var(--radius-sm);
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  .body-section :global(pre) {
    background: var(--bg-elevated);
    padding: var(--space-lg);
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin-bottom: var(--space-lg);
    font-size: var(--label-text);
    line-height: var(--leading-normal);
  }

  .body-section :global(pre code) {
    background: none;
    padding: 0;
    color: var(--text-secondary);
  }

  .body-section :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--space-lg);
    font-size: var(--label-text);
  }

  .body-section :global(th) {
    text-align: left;
    padding: var(--space-md);
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--label-text);
  }

  .body-section :global(td) {
    padding: var(--space-md);
    border-bottom: 1px solid var(--border-subtle);
    color: var(--text-secondary);
  }

  .body-section :global(strong) { color: var(--text-primary); }

  .body-section :global(em) { color: var(--text-secondary); }

  .body-section :global(blockquote) {
    border-left: 3px solid var(--accent-bright);
    padding-left: 16px;
    margin: var(--space-lg) 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  /* Source */
  .source-section {
    text-align: center;
    margin-bottom: var(--section-gap);
  }

  .source-link {
    font-size: var(--body-secondary);
    color: var(--accent-bright);
    text-decoration: none;
  }

  .source-link:hover { text-decoration: underline; }

  /* Template Includes */
  .includes-section {
    margin-bottom: var(--space-xl);
  }

  .includes-section h2 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-xl);
  }

  .includes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .include-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg) var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .include-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--shadow-accent-soft);
  }

  .include-card-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .include-type-icon {
    color: var(--accent-bright);
    display: flex;
    align-items: center;
  }

  .include-name {
    font-family: var(--font-display);
    font-size: var(--body-secondary);
    font-weight: 600;
    text-transform: capitalize;
    flex: 1;
  }

  .include-tier {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1px var(--space-sm);
    border-radius: var(--radius-sm);
  }

  .include-desc {
    font-size: var(--label-text);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: var(--space-sm) 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .include-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs, 4px);
    margin-top: var(--space-sm);
  }

  .include-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 1px var(--space-sm);
    border-radius: var(--radius-sm);
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  .include-missing {
    font-size: var(--label-text);
    color: var(--warm-bright);
    margin-bottom: var(--space-lg);
  }

  .core-section {
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--space-xl);
  }

  .core-heading {
    font-family: var(--font-display);
    font-size: var(--body-text);
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: var(--space-sm);
  }

  .core-subtext {
    font-size: var(--label-text);
    color: var(--text-muted);
    margin-bottom: var(--space-lg);
  }

  .includes-grid-core .include-card {
    background: transparent;
    border-color: var(--border-subtle);
    opacity: 0.8;
  }

  .includes-grid-core .include-card:hover {
    opacity: 1;
    background: var(--surface-card);
  }

  .include-card-core .include-desc {
    -webkit-line-clamp: 2;
  }

  @media (max-width: 480px) {
    .container { padding: var(--space-xl) var(--space-lg); }
    .body-section { padding: var(--space-xl); }
    .includes-grid { grid-template-columns: 1fr; }
  }
</style>
