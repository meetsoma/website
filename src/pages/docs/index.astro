---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Docs — Soma" description="Getting started with Soma — installation, memory layout, extensions, and more.">
  <div class="stars"></div>

  <main class="container">
    <a href="/" class="back-link">← Home</a>

    <header class="header">
      <h1 class="title">Documentation</h1>
      <p class="subtitle">Everything you need to install, configure, and extend Soma.</p>
    </header>

    <div class="docs-grid">
      <a href="https://github.com/meetsoma/agent/blob/main/docs/getting-started.md" target="_blank" rel="noopener" class="doc-card">
        <span class="doc-icon">▸</span>
        <h3>Getting Started</h3>
        <p>Install Soma, run your first session, understand the basics.</p>
      </a>

      <a href="https://github.com/meetsoma/agent/blob/main/docs/how-it-works.md" target="_blank" rel="noopener" class="doc-card">
        <span class="doc-icon">⟐</span>
        <h3>How It Works</h3>
        <p>Architecture overview — pi, extensions, memory lifecycle, session modes.</p>
      </a>

      <a href="https://github.com/meetsoma/agent/blob/main/docs/memory-layout.md" target="_blank" rel="noopener" class="doc-card">
        <span class="doc-icon">⟡</span>
        <h3>Memory Layout</h3>
        <p>Preloads, muscles, identity files — how Soma remembers.</p>
      </a>

      <a href="https://github.com/meetsoma/agent/blob/main/docs/extending.md" target="_blank" rel="noopener" class="doc-card">
        <span class="doc-icon">◈</span>
        <h3>Extending Soma</h3>
        <p>Write your own extensions, skills, and rituals.</p>
      </a>

      <a href="/ecosystem" class="doc-card">
        <span class="doc-icon">◎</span>
        <h3>Ecosystem</h3>
        <p>How extensions, skills, and rituals fit together.</p>
      </a>

      <a href="https://github.com/meetsoma/agent/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener" class="doc-card">
        <span class="doc-icon">◉</span>
        <h3>Contributing</h3>
        <p>Code style, PR workflow, skill authoring guidelines.</p>
      </a>
    </div>

    <footer class="footer">
      <nav class="footer-nav">
        <a href="/">Home</a>
        <span class="sep">·</span>
        <a href="/blog">Blog</a>
        <span class="sep">·</span>
        <a href="/ecosystem">Ecosystem</a>
        <span class="sep">·</span>
        <a href="https://github.com/meetsoma" target="_blank" rel="noopener">GitHub</a>
      </nav>
    </footer>
  </main>
</Layout>

<style>
  .stars {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 20px 30px, rgba(228,234,244,0.6), transparent),
      radial-gradient(1px 1px at 150px 100px, rgba(124,178,212,0.5), transparent);
    background-size: 400px 180px;
    animation: twinkle 10s ease-in-out infinite alternate;
  }
  @keyframes twinkle { 0% { opacity: 0.3; } 100% { opacity: 0.6; } }

  .container {
    position: relative; z-index: 1;
    max-width: 860px; margin: 0 auto; padding: 40px 24px;
    min-height: 100vh; display: flex; flex-direction: column;
  }

  .back-link {
    display: inline-block; margin-bottom: 20px;
    color: var(--text-muted); text-decoration: none; font-size: 0.9rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--accent-bright); }

  .header { text-align: center; margin-bottom: 48px; }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 2.8rem);
    font-weight: 700; margin-bottom: 12px;
  }

  .subtitle { color: var(--text-secondary); font-size: 1.05rem; }

  .docs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 56px;
  }

  .doc-card {
    padding: 28px;
    border-radius: 16px;
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.25s ease;
  }

  .doc-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px var(--shadow-accent-soft);
  }

  .doc-icon {
    display: block;
    font-size: 1.4rem;
    color: var(--accent-bright);
    margin-bottom: 12px;
  }

  .doc-card h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .doc-card:hover h3 { color: var(--accent-bright); }

  .doc-card p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .footer {
    margin-top: auto; padding-top: 48px; text-align: center;
    font-size: 0.9rem; color: var(--text-muted);
  }
  .footer-nav { display: flex; justify-content: center; gap: 8px; }
  .sep { color: var(--text-muted); }
  .footer a { color: var(--accent-bright); text-decoration: none; }
  .footer a:hover { color: var(--moon-bright); }

  @media (max-width: 640px) {
    .docs-grid { grid-template-columns: 1fr; }
  }
</style>
