---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { getCollection } from 'astro:content';
import { docUrl } from '../../lib/blog';

const allDocs = (await getCollection('docs'))
  .filter(doc => !doc.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

// Group by section
const sections = new Map<string, typeof allDocs>();
for (const doc of allDocs) {
  const section = doc.data.section;
  if (!sections.has(section)) sections.set(section, []);
  sections.get(section)!.push(doc);
}

const sectionMeta: Record<string, { glyph: string; desc: string }> = {
  'First Steps': {
    glyph: '▸',
    desc: 'Install Soma and run your first session.',
  },
  'Core Concepts': {
    glyph: 'σ',
    desc: 'How Soma thinks — breath cycle, identity, heat, memory, workspaces.',
  },
  'Reference': {
    glyph: '⟐',
    desc: 'Commands, configuration, scripts, and the full changelog.',
  },
  'Extending': {
    glyph: '◈',
    desc: 'Build your own skills, extensions, and tools.',
  },
};
---

<Layout
  title="Documentation — Soma"
  description="Learn how Soma works — persistent memory, evolving identity, heat-tracked protocols, workspace inheritance."
  canonicalUrl="https://soma.gravicity.ai/docs"
>
  <div class="stars"></div>

  <main class="container">
    <Breadcrumbs items={[
      { label: 'Docs', href: '/docs' },
    ]} />

    <header class="header">
      <h1 class="title">Documentation</h1>
      <p class="subtitle">
        Everything you need to use Soma — from first install to building custom extensions.
      </p>
    </header>

    <!-- Quick links -->
    <div class="quick-links">
      <a href="/docs/getting-started" class="quick-link primary">
        <span class="ql-glyph">▸</span>
        <span class="ql-text">
          <strong>Get Started</strong>
          <span>Install and first session</span>
        </span>
      </a>
      <a href="/docs/how-it-works" class="quick-link">
        <span class="ql-glyph">σ</span>
        <span class="ql-text">
          <strong>How It Works</strong>
          <span>The breath cycle</span>
        </span>
      </a>
      <a href="/docs/configuration" class="quick-link">
        <span class="ql-glyph">⟐</span>
        <span class="ql-text">
          <strong>Configuration</strong>
          <span>All settings</span>
        </span>
      </a>
      <a href="/docs/workspaces" class="quick-link">
        <span class="ql-glyph">⊕</span>
        <span class="ql-text">
          <strong>Workspaces</strong>
          <span>Monorepo patterns</span>
        </span>
      </a>
    </div>

    <!-- Section cards -->
    {[...sections.entries()].map(([sectionName, docs]) => {
      const meta = sectionMeta[sectionName] || { glyph: '·', desc: '' };
      return (
        <section class="doc-section">
          <div class="section-header">
            <span class="section-glyph">{meta.glyph}</span>
            <div>
              <h2 class="section-name">{sectionName}</h2>
              {meta.desc && <p class="section-desc">{meta.desc}</p>}
            </div>
          </div>
          <div class="doc-grid">
            {docs.map(doc => (
              <a href={docUrl(doc)} class="doc-card">
                <h3 class="doc-title">{doc.data.title}</h3>
                {doc.data.description && (
                  <p class="doc-desc">{doc.data.description}</p>
                )}
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </main>
</Layout>

<style>
  .stars {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 20px 30px, rgba(228,234,244,0.6), transparent),
      radial-gradient(1px 1px at 150px 100px, rgba(124,178,212,0.5), transparent);
    background-size: 400px 180px;
    animation: twinkle 10s ease-in-out infinite alternate;
  }
  @keyframes twinkle { 0% { opacity: 0.3; } 100% { opacity: 0.6; } }

  .container {
    position: relative; z-index: 1;
    max-width: 860px;
    margin: 0 auto;
    padding: 40px 24px 80px;
    min-height: 100vh;
  }

  .header {
    margin-bottom: 36px;
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.6rem);
    font-weight: 700;
    margin-bottom: 8px;
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  /* Quick links */
  .quick-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
    margin-bottom: 48px;
  }

  .quick-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 18px;
    border-radius: 12px;
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.2s;
  }

  .quick-link:hover {
    border-color: var(--border-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--shadow-accent-soft);
  }

  .quick-link.primary {
    border-color: var(--border-accent);
    background: var(--surface-accent-soft);
  }

  .ql-glyph {
    font-size: 1.4rem;
    color: var(--accent-bright);
    flex-shrink: 0;
    width: 32px;
    text-align: center;
  }

  .ql-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ql-text strong {
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 600;
  }

  .ql-text span:last-child {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  /* Section cards */
  .doc-section {
    margin-bottom: 40px;
  }

  .section-header {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 16px;
  }

  .section-glyph {
    font-size: 1.4rem;
    color: var(--accent-bright);
    font-weight: 700;
    line-height: 1.4;
    flex-shrink: 0;
  }

  .section-name {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 2px;
  }

  .section-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .doc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 12px;
  }

  .doc-card {
    padding: 18px 20px;
    border-radius: 10px;
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.2s;
  }

  .doc-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px var(--shadow-accent-soft);
  }

  .doc-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 4px;
    color: var(--accent-bright);
  }

  .doc-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 480px) {
    .quick-links { grid-template-columns: 1fr; }
    .doc-grid { grid-template-columns: 1fr; }
  }
</style>
