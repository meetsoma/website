---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { getCollection } from 'astro:content';
import { docUrl } from '../../lib/blog';

const allDocs = (await getCollection('docs'))
  .filter(doc => !doc.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

// Group by section
const sections = new Map<string, typeof allDocs>();
for (const doc of allDocs) {
  const section = doc.data.section;
  if (!sections.has(section)) sections.set(section, []);
  sections.get(section)!.push(doc);
}

const sectionMeta: Record<string, { glyph: string; desc: string }> = {
  'First Steps': {
    glyph: '▸',
    desc: 'Install Soma and run your first session.',
  },
  'Core Concepts': {
    glyph: 'σ',
    desc: 'How Soma thinks — breath cycle, identity, heat, memory, workspaces.',
  },
  'Reference': {
    glyph: '⟐',
    desc: 'Commands, configuration, scripts, and the full changelog.',
  },
  'Extending': {
    glyph: '◈',
    desc: 'Build your own skills, extensions, and tools.',
  },
};
---

<Layout
  title="Documentation — Soma"
  description="Learn how Soma works — persistent memory, evolving identity, heat-tracked protocols, workspace inheritance."
  canonicalUrl="https://soma.gravicity.ai/docs"
>
  <main class="container">
    <Breadcrumbs items={[
      { label: 'Docs', href: '/docs' },
    ]} />

    <header class="header">
      <h1 class="title">Documentation</h1>
      <p class="subtitle">
        Everything you need to use Soma — from first install to building custom extensions.
      </p>
    </header>

    <!-- Quick links -->
    <div class="quick-links">
      <a href="/docs/getting-started" class="quick-link primary">
        <span class="ql-glyph">▸</span>
        <span class="ql-text">
          <strong>Get Started</strong>
          <span>Install and first session</span>
        </span>
      </a>
      <a href="/docs/how-it-works" class="quick-link">
        <span class="ql-glyph">σ</span>
        <span class="ql-text">
          <strong>How It Works</strong>
          <span>The breath cycle</span>
        </span>
      </a>
      <a href="/docs/configuration" class="quick-link">
        <span class="ql-glyph">⟐</span>
        <span class="ql-text">
          <strong>Configuration</strong>
          <span>All settings</span>
        </span>
      </a>
      <a href="/docs/workspaces" class="quick-link">
        <span class="ql-glyph">⊕</span>
        <span class="ql-text">
          <strong>Workspaces</strong>
          <span>Monorepo patterns</span>
        </span>
      </a>
    </div>

    <!-- Section cards -->
    {[...sections.entries()].map(([sectionName, docs]) => {
      const meta = sectionMeta[sectionName] || { glyph: '·', desc: '' };
      return (
        <section class="doc-section">
          <div class="section-header">
            <span class="section-glyph">{meta.glyph}</span>
            <div>
              <h2 class="section-name">{sectionName}</h2>
              {meta.desc && <p class="section-desc">{meta.desc}</p>}
            </div>
          </div>
          <div class="doc-grid">
            {docs.map(doc => (
              <a href={docUrl(doc)} class="doc-card">
                <h3 class="doc-title">{doc.data.title}</h3>
                {doc.data.description && (
                  <p class="doc-desc">{doc.data.description}</p>
                )}
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </main>
</Layout>

<style>
  /* ═══════════════════════════════════════════════════════
     Docs Index — Fibonacci Design System
     ═══════════════════════════════════════════════════════
     TYPE: f-xs=0.813rem  f-sm=0.875rem  f-base=1rem  f-md=1.125rem  f-lg=1.313rem  f-xl=1.625rem
     SPACING: 8, 13, 21, 34, 55, 89
     LINE-HEIGHT: headings=1.2  body=1.618(φ)
  ═══════════════════════════════════════════════════════ */

  .container {
    position: relative; z-index: 1;
    max-width: 890px;              /* ~55 * φ^4 — matches landing page */
    margin: 0 auto;
    padding: 55px 21px 55px;       /* fib: 55, 21, 55 */
    min-height: 100vh;
  }

  .header {
    margin-bottom: 34px;           /* fib */
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.625rem); /* f-2xl */
    font-weight: 700;
    margin-bottom: 8px;            /* fib */
    line-height: 1.2;
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: 1.125rem;          /* f-md */
    line-height: 1.618;           /* φ */
  }

  /* ── Quick links ── */
  .quick-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 13px;                    /* fib */
    margin-bottom: 55px;          /* fib */
  }

  .quick-link {
    display: flex;
    align-items: center;
    gap: 13px;                    /* fib */
    padding: 13px 21px;           /* fib */
    border-radius: 13px;          /* fib */
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.25s ease;
  }

  .quick-link:hover {
    border-color: var(--border-accent);
    transform: translateY(-3px);
    box-shadow: 0 8px 21px var(--shadow-accent-soft);
  }

  .quick-link.primary {
    border-color: var(--border-accent);
    background: var(--surface-accent-soft);
  }

  .ql-glyph {
    font-size: 1.313rem;          /* f-lg */
    color: var(--accent-bright);
    flex-shrink: 0;
    width: 34px;                  /* fib */
    text-align: center;
  }

  .ql-text {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .ql-text strong {
    font-family: var(--font-display);
    font-size: 1rem;              /* f-base — was 0.92 */
    font-weight: 600;
    line-height: 1.2;
  }

  .ql-text span:last-child {
    font-size: 0.875rem;          /* f-sm — was 0.78 */
    color: var(--text-muted);
    line-height: 1.4;
  }

  /* ── Section cards ── */
  .doc-section {
    margin-bottom: 55px;          /* fib */
  }

  .section-header {
    display: flex;
    align-items: flex-start;
    gap: 13px;                    /* fib */
    margin-bottom: 21px;          /* fib */
  }

  .section-glyph {
    font-size: 1.625rem;          /* f-xl */
    color: var(--accent-bright);
    font-weight: 700;
    line-height: 1.2;
    flex-shrink: 0;
  }

  .section-name {
    font-family: var(--font-display);
    font-size: 1.313rem;          /* f-lg — was 1.2 */
    font-weight: 600;
    margin-bottom: 3px;
    line-height: 1.2;
  }

  .section-desc {
    font-size: 1rem;              /* f-base — was 0.85 */
    color: var(--text-muted);
    line-height: 1.618;           /* φ */
  }

  .doc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 13px;                    /* fib */
  }

  .doc-card {
    padding: 21px;                /* fib */
    border-radius: 13px;          /* fib */
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.25s ease;
  }

  .doc-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-3px);
    box-shadow: 0 8px 21px var(--shadow-accent-soft);
  }

  .doc-title {
    font-family: var(--font-display);
    font-size: 1.125rem;          /* f-md — was 0.95 */
    font-weight: 600;
    margin-bottom: 8px;           /* fib */
    color: var(--accent-bright);
    line-height: 1.2;
  }

  .doc-desc {
    font-size: 0.875rem;          /* f-sm — was 0.8 */
    color: var(--text-secondary);
    line-height: 1.618;           /* φ */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 480px) {
    .container { padding: 34px 13px; }
    .quick-links { grid-template-columns: 1fr; }
    .doc-grid { grid-template-columns: 1fr; }
  }
</style>
