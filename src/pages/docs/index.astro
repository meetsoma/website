---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Icon from '../../components/icons/SomaIcons.astro';
import { getCollection } from 'astro:content';
import { docUrl } from '../../lib/blog';

const allDocs = (await getCollection('docs'))
  .filter(doc => !doc.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

// Group by section
const sections = new Map<string, typeof allDocs>();
for (const doc of allDocs) {
  const section = doc.data.section;
  if (!sections.has(section)) sections.set(section, []);
  sections.get(section)!.push(doc);
}

const sectionMeta: Record<string, { icon: string; desc: string }> = {
  'First Steps': {
    icon: 'arrow-right',
    desc: 'Install Soma and run your first session.',
  },
  'Core Concepts': {
    icon: 'sigma',
    desc: 'How Soma thinks — breath cycle, identity, heat, memory, workspaces.',
  },
  'Reference': {
    icon: 'settings',
    desc: 'Commands, configuration, scripts, and the full changelog.',
  },
  'Extending': {
    icon: 'extensions',
    desc: 'Build your own skills, extensions, and tools.',
  },
};
---

<Layout
  title="Documentation — Soma"
  description="Learn how Soma works — persistent memory, evolving identity, heat-tracked protocols, workspace inheritance."
  canonicalUrl="https://soma.gravicity.ai/docs"
>
  <main class="container">
    <Breadcrumbs items={[
      { label: 'Docs', href: '/docs' },
    ]} />

    <header class="header">
      <h1 class="title">Documentation</h1>
      <p class="subtitle">
        Everything you need to use Soma — from first install to building custom extensions.
      </p>
    </header>

    <!-- Quick links -->
    <div class="quick-links">
      <a href="/docs/getting-started" class="quick-link primary">
        <span class="ql-glyph"><Icon name="arrow-right" size={20} /></span>
        <span class="ql-text">
          <strong>Get Started</strong>
          <span>Install and first session</span>
        </span>
      </a>
      <a href="/docs/how-it-works" class="quick-link">
        <span class="ql-glyph"><Icon name="sigma" size={20} /></span>
        <span class="ql-text">
          <strong>How It Works</strong>
          <span>The breath cycle</span>
        </span>
      </a>
      <a href="/docs/configuration" class="quick-link">
        <span class="ql-glyph"><Icon name="settings" size={20} /></span>
        <span class="ql-text">
          <strong>Configuration</strong>
          <span>All settings</span>
        </span>
      </a>
      <a href="/docs/workspaces" class="quick-link">
        <span class="ql-glyph"><Icon name="layers" size={20} /></span>
        <span class="ql-text">
          <strong>Workspaces</strong>
          <span>Monorepo patterns</span>
        </span>
      </a>
    </div>

    <!-- Section cards -->
    {[...sections.entries()].map(([sectionName, docs]) => {
      const meta = sectionMeta[sectionName] || { icon: 'circle-dot', desc: '' };
      return (
        <section class="doc-section">
          <div class="section-header">
            <span class="section-glyph"><Icon name={meta.icon as any} size={24} /></span>
            <div>
              <h2 class="section-name">{sectionName}</h2>
              {meta.desc && <p class="section-desc">{meta.desc}</p>}
            </div>
          </div>
          <div class="doc-grid">
            {docs.map(doc => (
              <a href={docUrl(doc)} class="doc-card">
                <h3 class="doc-title">{doc.data.title}</h3>
                {doc.data.description && (
                  <p class="doc-desc">{doc.data.description}</p>
                )}
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </main>
</Layout>

<style>
  /* Design tokens: see Layout.astro :root */

  .container {
    position: relative; z-index: 1;
    max-width: 890px;              /* ~55 * φ^4 — matches landing page */
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-xl) var(--space-3xl);
    min-height: 100vh;
  }

  .header {
    margin-bottom: var(--space-2xl);
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 2.625rem);
    font-weight: 700;
    margin-bottom: var(--space-md);
    line-height: var(--leading-tight);
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }

  /* ── Quick links ── */
  .quick-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--grid-gap);
    margin-bottom: var(--section-gap);
  }

  .quick-link {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.25s ease;
  }

  .quick-link:hover {
    border-color: var(--border-accent);
    transform: translateY(-3px);
    box-shadow: 0 var(--space-md) var(--space-xl) var(--shadow-accent-soft);
  }

  .quick-link.primary {
    border-color: var(--border-accent);
    background: var(--surface-accent-soft);
  }

  .ql-glyph {
    color: var(--accent-bright);
    flex-shrink: 0;
    width: var(--space-2xl);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ql-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .ql-text strong {
    font-family: var(--font-display);
    font-size: var(--body-text);
    font-weight: 600;
    line-height: var(--leading-tight);
  }

  .ql-text span:last-child {
    font-size: var(--body-text);
    color: var(--text-muted);
    line-height: var(--leading-normal);
  }

  /* ── Section cards ── */
  .doc-section {
    margin-bottom: var(--section-gap);
  }

  .section-header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .section-glyph {
    color: var(--accent-bright);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .section-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-xs);
    line-height: var(--leading-tight);
  }

  .section-desc {
    font-size: var(--body-text);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
  }

  .doc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--grid-gap);
  }

  .doc-card {
    padding: var(--card-pad-y) var(--card-pad-x);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.25s ease;
  }

  .doc-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-3px);
    box-shadow: 0 var(--space-md) var(--space-xl) var(--shadow-accent-soft);
  }

  .doc-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-md);
    color: var(--accent-bright);
    line-height: var(--leading-tight);
  }

  .doc-desc {
    font-size: var(--body-text);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 480px) {
    .container { padding: var(--space-2xl) var(--space-lg); }
    .quick-links { grid-template-columns: 1fr; }
    .doc-grid { grid-template-columns: 1fr; }
  }
</style>
