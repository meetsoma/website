---
import Layout from '../../layouts/Layout.astro';
import SomaVerse from '../../components/islands/SomaVerse.tsx';
---

<Layout
  title="SomaVerse — Explore the Bodies"
  description="An infinite procedural space of Soma bodies. Each one unique. Some legendary."
  canonicalUrl="https://soma.gravicity.ai/verse"
>
  <main class="verse-page">
    <header class="verse-header">
      <h1 class="verse-title">SomaVerse</h1>
      <p class="verse-subtitle">
        Every soma is unique — generated from a genome seed. Drift through space. 
        Find the legendaries.
      </p>
    </header>

    <div class="verse-container">
      <SomaVerse client:load />
    </div>
  </main>
</Layout>

<style>
  .verse-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-xl) var(--space-3xl);
    min-height: 100vh;
  }

  .verse-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .verse-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 2.625rem);
    font-weight: 700;
    margin-bottom: var(--space-md);
    line-height: var(--leading-tight);
  }

  .verse-subtitle {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    max-width: var(--content-narrow);
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  .verse-container {
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .verse-page {
      padding: var(--space-xl) var(--space-lg);
    }
  }
</style>
