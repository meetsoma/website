---
import { ViewTransitions } from 'astro:transitions';
import SomaVerse from '../../components/islands/SomaVerse.tsx';
import Nav from '../../components/Nav.astro';

const title = "SomaVerse — Explore the Bodies";
const description = "An infinite procedural space of Soma bodies. Each one unique. Some legendary.";
const canonicalUrl = "https://soma.gravicity.ai/verse";
---

<!doctype html>
<html lang="en" data-theme="dark" data-surface="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content="https://soma.gravicity.ai/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://api.fontshare.com">
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin>
    <link href="https://api.fontshare.com/v2/css?f[]=clash-display@700,600,500&f[]=satoshi@400,500,700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet">

    <title>{title}</title>
    <ViewTransitions />

    <script is:inline>
      (() => {
        const saved = localStorage.getItem('soma-theme');
        const theme = saved === 'light' || saved === 'dark' ? saved : 'dark';
        document.documentElement.classList.add('no-transition');
        document.documentElement.dataset.theme = theme;
        document.documentElement.dataset.surface = theme;
        document.documentElement.style.colorScheme = theme;
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            document.documentElement.classList.remove('no-transition');
          });
        });
      })();

      // Preserve theme across View Transitions (matching Layout.astro)
      document.addEventListener('astro:before-swap', (e) => {
        const theme = document.documentElement.dataset.theme || 'dark';
        const surface = document.documentElement.dataset.surface || 'dark';
        e.newDocument.documentElement.dataset.theme = theme;
        e.newDocument.documentElement.dataset.surface = surface;
        e.newDocument.documentElement.style.colorScheme = theme;
      });
    </script>

    <style is:global>
      @import '../../styles/tincture/_generated/foundation.css';
    </style>
  </head>
  <body>
    <SomaVerse client:load fullPage={true} />
    <Nav centeredTitle="SomaVerse">
      <Fragment slot="nav-right-extra">
        <!-- Soma Radio toggle — dispatches to SomaVerse island -->
        <button
          class="verse-audio-btn"
          id="verse-audio-btn"
          type="button"
          aria-label="Enable Soma Radio"
          title="Soma Radio"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
            <path d="M15.54 8.46a5 5 0 0 1 0 7.07" />
            <path d="M19.07 4.93a10 10 0 0 1 0 14.14" />
          </svg>
        </button>
      </Fragment>
    </Nav>

    <div class="verse-hint">
      steer to explore · scroll to zoom · hover to identify · 🔊 enable soma radio
    </div>

    <script>
      import { inject } from '@vercel/analytics';
      inject();

      // Audio toggle wiring (reconnect for the slot button
      const audioBtn = document.getElementById('verse-audio-btn');
      if (audioBtn) {
        audioBtn.addEventListener('click', () => {
          window.dispatchEvent(new Event('soma-audio-toggle'));
        });
        window.addEventListener('soma-audio-state', (e) => {
          const enabled = e.detail.enabled;
          audioBtn.classList.toggle('is-active', enabled);
          audioBtn.setAttribute('aria-label', enabled ? 'Mute Soma Radio' : 'Enable Soma Radio');
          audioBtn.setAttribute('title', enabled ? 'Soma Radio: On' : 'Soma Radio: Off');
        });
      }
    </script>
  </body>
</html>

<style is:global>
  /* ── Verse page: full immersion ── */
  :root {
    /* Keep Clash Display for SomaVerse canvas — Nav uses Manrope via foundation.css */
    --font-display: 'Clash Display', system-ui, sans-serif;
    --font-body: 'Satoshi', system-ui, sans-serif;
    --font-mono: 'SF Mono', 'Fira Code', 'JetBrains Mono', monospace;

    --accent-bright: #6898be;
    --moon-bright: #7cb2d4;
    --moon-glow: rgba(124, 178, 212, 0.4);
    --text-primary: #e4eaf4;
    --text-secondary: #8494aa;
  }

  html[data-theme='light'] {
    --accent-bright: #2e6094;
    --moon-bright: #3878a0;
    --moon-glow: rgba(46, 96, 148, 0.2);
    --text-primary: #0a0f1a;
    --text-secondary: #2a3648;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #050810;
  }

  body {
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
  }

  html.no-transition,
  html.no-transition *::before,
  html.no-transition *::after {
    transition: none !important;
  }

  /* ── Verse audio button in Nav slot ── */
  .verse-audio-btn {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    border: none;
    background: transparent;
    cursor: pointer;
    color: var(--ink-soft, #8494aa);
    transition: color 0.15s, background 0.15s;
    flex-shrink: 0;
  }

  .verse-audio-btn:hover {
    color: var(--ink, #e4eaf4);
    background: var(--surface-interactive, rgba(255,255,255,0.06));
  }

  .verse-audio-btn.is-active {
    color: var(--accent, #7cb2d4);
    background: rgba(104, 152, 190, 0.15);
  }

  /* Bottom hint — fades out after a few seconds */
  .verse-hint {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: rgba(132, 148, 170, 0.35);
    pointer-events: none;
    white-space: nowrap;
    z-index: 50;
    animation: hintFade 6s ease-in-out forwards;
  }

  @keyframes hintFade {
    0%, 60% { opacity: 1; }
    100% { opacity: 0; }
  }
</style>