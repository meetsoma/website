---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ChangelogIsland from '../../components/islands/ChangelogIsland.tsx';
---

<Layout
  title="Changelog — Soma"
  description="What shipped, what changed, what got fixed. Full version history for the Soma agent."
  canonicalUrl="https://soma.gravicity.ai/changelog"
>
  <main class="container">
    <header class="hero">
      <Breadcrumbs items={[{ label: 'Changelog', href: '/changelog' }]} />
      <h1 class="title">Changelog</h1>
      <p class="subtitle">
        What shipped, what changed, what got fixed.
      </p>
    </header>

    <section class="section">
      <ChangelogIsland client:load />
    </section>
  </main>
</Layout>

<style>
  .container {
    position: relative;
    z-index: 1;
    max-width: 890px;
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-xl) var(--space-2xl);
    min-height: 100vh;
  }

  .hero {
    text-align: center;
    margin-bottom: var(--section-gap);
    animation: fadeUp 0.8s ease-out;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(21px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 2.625rem);
    font-weight: 700;
    margin: var(--space-md) 0;
    background: linear-gradient(135deg, var(--hero-title-start) 0%, var(--hero-title-end) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 34rem;
    margin: var(--space-md) auto 0;
    line-height: var(--leading-relaxed);
  }

  .section {
    margin-bottom: var(--section-gap);
  }

  @media (max-width: 640px) {
    .container { padding: var(--space-2xl) var(--space-lg) var(--space-xl); }
  }
</style>

<style is:global>
  /* ── Changelog ── */
  .changelog-loading,
  .changelog-error {
    text-align: center;
    padding: var(--space-2xl);
    color: var(--text-muted);
    font-family: var(--font-body);
  }

  .changelog-error { color: var(--warm-bright); }

  .changelog-version {
    margin-bottom: var(--space-3xl);
    padding: var(--space-2xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    transition: all 0.25s ease;
    animation: fadeUp 0.6s ease-out both;
  }

  .changelog-version:hover {
    border-color: var(--border-accent);
    box-shadow: 0 8px 24px var(--shadow-accent-soft);
  }

  .changelog-version:first-child {
    border-color: var(--border-accent);
    background: linear-gradient(135deg, var(--surface-card) 0%, rgba(104, 152, 190, 0.04) 100%);
  }

  .version-header {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border-subtle);
  }

  .version-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--accent-bright);
  }

  .version-label {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    flex: 1;
  }

  .version-date {
    font-family: var(--font-mono);
    font-size: var(--label-text);
    color: var(--text-muted);
    margin-left: auto;
  }

  .version-latest {
    font-family: var(--font-mono);
    font-size: var(--badge-text);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--bg-deep);
    background: var(--accent-bright);
    padding: var(--space-xs) var(--space-md);
    border-radius: 9999px;
  }

  .version-stats {
    display: flex;
    gap: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  .stat {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--label-text);
  }

  .stat-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .stat-count {
    font-weight: 600;
    color: var(--text-primary);
  }

  .stat-label {
    color: var(--text-muted);
  }

  .changelog-section {
    margin-bottom: var(--space-xl);
  }

  .changelog-section:last-child {
    margin-bottom: 0;
  }

  .section-label {
    font-family: var(--font-display);
    font-size: var(--body-text);
    font-weight: 600;
    margin: 0 0 var(--space-lg) 0;
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .section-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .section-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-sm);
  }

  .section-items li {
    font-family: var(--font-body);
    font-size: var(--body-text);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    padding: var(--space-xs) 0;
    padding-left: var(--space-xl);
    position: relative;
  }

  .section-items li::before {
    content: '';
    position: absolute;
    left: var(--space-md);
    top: 0.75em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    opacity: 0.4;
  }

  .section-added li::before { background: #a8e8a8; }
  .section-changed li::before { background: var(--accent-bright); }
  .section-fixed li::before { background: var(--warm-bright); }
  .section-born li::before { background: var(--accent-bright); }

  .section-items code {
    font-family: var(--font-mono);
    font-size: var(--label-text);
    color: var(--accent-bright);
    background: var(--surface-interactive);
    padding: 1px 5px;
    border-radius: var(--radius-sm);
  }

  .changelog-meta {
    font-family: var(--font-mono);
    font-size: var(--label-text);
    color: var(--text-muted);
    text-align: center;
    margin-top: var(--space-xl);
    opacity: 0.6;
  }

  @media (max-width: 640px) {
    .changelog-version { padding: var(--space-xl); }
    .version-header { flex-wrap: wrap; }
    .version-date { margin-left: 0; }
    .version-stats { flex-wrap: wrap; gap: var(--space-lg); }
  }
</style>
