---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { formatDate, authorBadge, blogPostUrl, estimateReadTime } from '../../lib/blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.mdx?$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const postUrl = blogPostUrl(post);
const fullUrl = `https://soma.gravicity.ai${postUrl}`;

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  url: fullUrl,
  author: {
    '@type': post.data.authorRole === 'agent' ? 'Thing' : 'Person',
    name: post.data.author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Gravicity',
    url: 'https://gravicity.ai',
  },
  keywords: post.data.tags,
};
---

<Layout
  title={`${post.data.title} — Soma`}
  description={post.data.description}
  canonicalUrl={fullUrl}
  jsonLd={blogJsonLd}
  ogType="article"
>
  <div class="stars"></div>

  <main class="container">
    <Breadcrumbs items={[
      { label: 'Blog', href: '/blog' },
      { label: post.data.title, href: postUrl },
    ]} />

    <article class="article">
      <header class="article-header">
        <div class="article-meta">
          <span>{formatDate(post.data.date)}</span>
          <span class="sep">·</span>
          <span>{estimateReadTime(post.body || '')}</span>
          <span class="sep">·</span>
          <span>{post.data.author}</span>
          <span class="author-badge" data-role={post.data.authorRole}>
            {authorBadge(post.data.authorRole)}
          </span>
        </div>
        <h1 class="article-title">{post.data.title}</h1>
        <p class="article-desc">{post.data.description}</p>
        {post.data.tags.length > 0 && (
          <div class="article-tags">
            {post.data.tags.map((tag) => (
              <span class="tag">#{tag}</span>
            ))}
          </div>
        )}
      </header>

      <div class="article-content">
        <Content />
      </div>
    </article>

    <nav class="back-nav">
      <a href="/blog">← All posts</a>
    </nav>
  </main>
</Layout>

<style>
  .stars {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 20px 30px, rgba(228,234,244,0.6), transparent),
      radial-gradient(1px 1px at 150px 100px, rgba(124,178,212,0.5), transparent);
    background-size: 400px 180px;
    animation: twinkle 10s ease-in-out infinite alternate;
  }

  @keyframes twinkle { 0% { opacity: 0.3; } 100% { opacity: 0.6; } }

  .container {
    position: relative; z-index: 1;
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-xl);
    min-height: 100vh;
  }

  .article-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-lg);
  }

  .sep { opacity: 0.5; }

  .author-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 2px var(--space-md);
    border-radius: var(--radius-md);
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  .author-badge[data-role="human"] {
    background: var(--surface-warm-soft);
    color: var(--warm-bright);
  }

  .article-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    font-weight: 700;
    line-height: var(--leading-tight);
    margin-bottom: var(--space-lg);
  }

  .article-desc {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-lg);
  }

  .article-tags { display: flex; gap: var(--space-md); }

  .tag {
    font-size: var(--text-xs);
    color: var(--moon-bright);
    padding: var(--space-xs) 10px;
    border-radius: var(--radius-lg);
    background: var(--surface-accent-soft);
    border: 1px solid rgba(124, 178, 212, 0.15);
  }

  .article-content {
    font-size: var(--text-md);
    line-height: var(--leading-loose);
    color: var(--text-primary);
  }

  .article-content :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-lg);
    color: var(--text-primary);
  }

  .article-content :global(h3) {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-lg);
  }

  .article-content :global(p) {
    margin-bottom: 20px;
    color: var(--text-secondary);
  }

  .article-content :global(a) {
    color: var(--accent-bright);
    text-decoration: none;
    border-bottom: 1px solid var(--border-accent);
    transition: color 0.2s;
  }

  .article-content :global(a:hover) { color: var(--moon-bright); }

  .article-content :global(code) {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    padding: 2px var(--space-sm);
    border-radius: var(--radius-sm);
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  .article-content :global(pre) {
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    overflow-x: auto;
    margin-bottom: var(--space-xl);
  }

  .article-content :global(pre code) {
    padding: 0;
    background: none;
    border-radius: 0;
  }

  .article-content :global(blockquote) {
    border-left: 3px solid var(--accent-bright);
    padding-left: 20px;
    margin: var(--space-xl) 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .article-content :global(ul), .article-content :global(ol) {
    padding-left: 24px;
    margin-bottom: 20px;
    color: var(--text-secondary);
  }

  .article-content :global(li) {
    margin-bottom: var(--space-md);
  }

  .article-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin: var(--space-2xl) 0;
  }

  .article-content :global(img) {
    max-width: 100%;
    border-radius: var(--radius-lg);
    margin: var(--space-xl) 0;
  }

  .back-nav {
    margin-top: var(--space-3xl);
    padding-top: 21px;
    border-top: 1px solid var(--border-subtle);
    text-align: center;
  }

  .back-nav a {
    color: var(--accent-bright);
    text-decoration: none;
    font-size: var(--text-base);
  }

  .back-nav a:hover { color: var(--moon-bright); }

  @media (max-width: 480px) {
    .container { padding: var(--space-xl) var(--space-lg); }
  }
</style>
