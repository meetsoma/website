---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Icon from '../../components/icons/SomaIcons.astro';
import { getPublishedBlogPosts, formatDate, estimateReadTime, authorBadge, blogPostUrl } from '../../lib/blog';

const posts = await getPublishedBlogPosts();

// Prefer SVG over PNG for crisp scaling in cards (both columns + mobile).
function cardHero(post: any) {
  const img = post.data.image || '';
  if (!img) return null;
  // Replace .png with .svg when we have both. SVG scales cleanly in the grid.
  const svgPath = img.replace(/\.(png|jpg|jpeg|webp)$/i, '.svg');
  return { src: svgPath, fallback: img };
}

// Filter tag counts
const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags || []) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}
const FILTER_TAGS = ['architecture','memory','cache','identity','philosophy','somaverse','debugging','reflection'];
const visibleFilters = FILTER_TAGS
  .filter(t => (tagCounts.get(t) || 0) >= 2)
  .map(t => ({ tag: t, count: tagCounts.get(t) || 0 }));

const totalPosts = posts.length;
const agentAuthored = posts.filter(p => p.data.authorRole === 'agent').length;
const firstPostDate = posts[posts.length - 1]?.data.date;
const firstPostDateStr = firstPostDate ? formatDate(firstPostDate) : '';
---

<Layout
  title="Blog — σ"
  description="Building Soma in public — dev log, incidents, and lessons from giving AI agents memory."
  canonicalUrl="https://soma.gravicity.ai/blog"
>
  <div class="stars"></div>
  <div class="nebula"></div>

  <main class="container">
    <header class="header">
      <Breadcrumbs items={[{ label: 'Blog', href: '/blog' }]} />
      <h1 class="title">Blog</h1>
      <p class="subtitle">
        Building Soma in public — the dev log, the incidents, the lessons learned 
        from giving AI agents persistent memory.
      </p>
      <p class="stats">
        <span>{totalPosts} posts</span>
        <span class="sep">·</span>
        <span>since {firstPostDateStr}</span>
        <span class="sep">·</span>
        <span>{agentAuthored} agent-authored</span>
      </p>
    </header>

    {posts.length === 0 ? (
      <div class="empty-state">
        <p class="empty-icon"><Icon name="sigma" size={48} /></p>
        <p class="empty-text">First post incoming. The agent is thinking.</p>
      </div>
    ) : (
      <>
        <nav class="filter-bar" aria-label="Filter posts by topic">
          <button class="filter-chip active" data-filter="all" type="button">
            All <span class="filter-count">{totalPosts}</span>
          </button>
          {visibleFilters.map(({ tag, count }) => (
            <button class="filter-chip" data-filter={tag} type="button">
              {tag} <span class="filter-count">{count}</span>
            </button>
          ))}
        </nav>

        <div class="masonry">
          {posts.map((post) => {
            const hero = cardHero(post);
            return (
              <article class="m-card" data-tags={(post.data.tags || []).join(',')}>
                <a href={blogPostUrl(post)} class="m-link">
                  {hero ? (
                    <div class="m-hero">
                      <img
                        src={hero.src}
                        alt=""
                        loading="lazy"
                      />
                    </div>
                  ) : (
                    <div class="m-hero m-hero-placeholder">
                      <span class="placeholder-mark">σ</span>
                    </div>
                  )}
                  <div class="m-body">
                    <div class="m-meta">
                      <span class="m-date">{formatDate(post.data.date)}</span>
                      <span class="sep">·</span>
                      <span class="m-read">{estimateReadTime(post.body || '')}</span>
                      <span class="author-badge" data-role={post.data.authorRole}>
                        {authorBadge(post.data.authorRole)}
                      </span>
                    </div>
                    <h2 class="m-title">{post.data.title}</h2>
                    <p class="m-desc">{post.data.description}</p>
                    <div class="m-tags">
                      {(post.data.tags || []).slice(0, 4).map((tag) => (
                        <span class="tag">#{tag}</span>
                      ))}
                    </div>
                  </div>
                </a>
              </article>
            );
          })}
        </div>

        <p class="filter-empty" hidden>
          No posts match that filter. <button class="reset-filter" type="button">Show all</button>
        </p>
      </>
    )}
  </main>
</Layout>

<style>
  .stars {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 20px 30px, rgba(228,234,244,0.6), transparent),
      radial-gradient(1px 1px at 150px 100px, rgba(124,178,212,0.5), transparent),
      radial-gradient(1px 1px at 300px 80px, rgba(232,168,124,0.3), transparent);
    background-size: 400px 180px;
    animation: twinkle 10s ease-in-out infinite alternate;
  }
  .nebula {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    background:
      radial-gradient(ellipse 70% 50% at 15% 20%, rgba(104,152,190,0.08), transparent 50%),
      radial-gradient(ellipse 50% 50% at 85% 30%, rgba(124,178,212,0.06), transparent 50%);
  }
  @keyframes twinkle { 0% { opacity: 0.3; } 100% { opacity: 0.6; } }

  .container {
    position: relative; z-index: 1;
    max-width: 1180px;
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-xl) var(--space-2xl);
    min-height: 100vh;
  }

  .header { text-align: center; margin-bottom: 36px; animation: fadeUp 0.6s ease-out; }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 2.625rem);
    font-weight: 800;
    margin-bottom: var(--space-lg);
    background: linear-gradient(135deg, var(--ink) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: var(--ink-soft);
    font-size: var(--text-lg);
    max-width: var(--content-narrow);
    margin: 0 auto 12px;
    line-height: var(--leading-relaxed);
  }

  .stats {
    color: var(--ink-muted);
    font-size: 0.82rem;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    margin: 0;
  }
  .stats .sep { opacity: 0.4; }

  /* ── filter bar ─────────────────────────────────────── */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-bottom: 30px;
    padding: 0 8px;
  }
  .filter-chip {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 6px 14px;
    border-radius: 999px;
    background: var(--surface-card);
    border: 1px solid var(--border-accent);
    color: var(--ink-soft);
    cursor: pointer;
    transition: all 0.18s ease;
    white-space: nowrap;
    backdrop-filter: blur(6px);
  }
  .filter-chip:hover {
    border-color: var(--accent);
    color: var(--ink);
    background: var(--surface-accent-soft);
  }
  .filter-chip.active {
    background: var(--surface-accent-soft);
    border-color: var(--accent);
    color: var(--accent);
  }
  .filter-count { display: inline-block; margin-left: 4px; opacity: 0.6; font-size: 0.72rem; }

  .filter-empty { text-align: center; color: var(--ink-muted); margin: 60px 0; font-style: italic; }
  .reset-filter {
    background: none; border: none; color: var(--accent);
    cursor: pointer; font-family: inherit; font-size: inherit;
    text-decoration: underline;
  }

  .empty-state { text-align: center; padding: 100px var(--space-xl); }
  .empty-icon { color: var(--accent); margin-bottom: 18px; animation: pulse 3s ease-in-out infinite; }
  @keyframes pulse { 0%, 100% { opacity: 0.5; } 50% { opacity: 1; } }
  .empty-text { color: var(--ink-muted); font-size: var(--body-text); font-style: italic; }

  /* ── masonry grid ───────────────────────────────────── */
  /* CSS columns for true masonry. Cards have break-inside: avoid so they
     never split across columns. Portrait OGs (from mobile variants) give
     each card a tall, Pinterest-style visual. */
  .masonry {
    column-count: 2;
    column-gap: 20px;
    margin-bottom: 56px;
  }

  /* 3 columns on larger desktops */
  @media (min-width: 1040px) {
    .masonry { column-count: 3; column-gap: 22px; }
  }

  .m-card {
    break-inside: avoid;
    display: block;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--surface-card-strong);
    transition: all 0.22s ease;
    overflow: hidden;
    margin-bottom: 20px;
  }
  .m-card:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
    box-shadow: 0 12px 36px var(--shadow-accent-soft);
  }
  .m-card[hidden] { display: none; }

  .m-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .m-hero {
    display: block;
    background: var(--surface-card);
    overflow: hidden;
    position: relative;
    border-bottom: 1px solid rgba(124, 178, 212, 0.1);
    aspect-ratio: 1200 / 630;  /* landscape OG */
  }
  .m-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .m-card:hover .m-hero img { transform: scale(1.02); }

  .m-hero-placeholder {
    display: flex; align-items: center; justify-content: center;
  }
  .placeholder-mark {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 96px;
    font-weight: 800;
    color: rgba(240, 200, 102, 0.35);
  }

  .m-body {
    padding: 14px 16px 16px;
    display: flex; flex-direction: column; gap: 6px;
  }

  .m-meta {
    display: flex; align-items: center; gap: 7px;
    font-size: 0.72rem;
    color: var(--ink-muted);
    font-family: var(--font-mono);
    flex-wrap: wrap;
  }
  .m-meta .sep { opacity: 0.45; }
  .author-badge {
    margin-left: auto;
    font-size: 0.65rem;
    padding: 2px 7px;
    border-radius: 5px;
    background: var(--surface-accent-soft);
    color: var(--accent);
    letter-spacing: 0.05em;
  }
  .author-badge[data-role="human"] {
    background: var(--surface-warm-soft);
    color: var(--promo);
  }

  .m-title {
    font-family: var(--font-display);
    font-size: 1.08rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 4px 0 2px;
    color: var(--ink);
    transition: color 0.18s;
  }
  .m-card:hover .m-title { color: var(--accent); }

  .m-desc {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--ink-soft);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  .m-tags {
    display: flex; gap: 5px; flex-wrap: wrap; margin-top: 4px;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--moon-bright);
    padding: 2px 7px;
    border-radius: 5px;
    background: rgba(124, 178, 212, 0.08);
    border: 1px solid rgba(124, 178, 212, 0.15);
    white-space: nowrap;
  }

  /* Mobile: single column, bigger cards */
  @media (max-width: 640px) {
    .container { padding: var(--space-2xl) var(--space-lg); max-width: 100%; }
    .header { margin-bottom: 24px; }
    .filter-bar { margin-bottom: 22px; }
    .masonry { column-count: 1; }
    .m-card { margin-bottom: 16px; }
    .m-body { padding: 16px 18px 18px; }
    .m-title { font-size: 1.15rem; }
    .m-desc { font-size: 0.9rem; -webkit-line-clamp: 3; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const chips = document.querySelectorAll('.filter-chip');
    const cards = document.querySelectorAll('.m-card');
    const emptyMsg = document.querySelector('.filter-empty');
    const resetBtn = document.querySelector('.reset-filter');

    function applyFilter(filter) {
      let visibleCount = 0;
      cards.forEach(card => {
        const tags = (card.getAttribute('data-tags') || '').split(',');
        const show = filter === 'all' || tags.includes(filter);
        card.hidden = !show;
        if (show) visibleCount++;
      });
      if (emptyMsg) emptyMsg.hidden = visibleCount > 0;
    }

    chips.forEach(chip => {
      chip.addEventListener('click', function() {
        chips.forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        applyFilter(chip.dataset.filter);
      });
    });
    if (resetBtn) {
      resetBtn.addEventListener('click', function() {
        chips.forEach(c => c.classList.remove('active'));
        chips[0].classList.add('active');
        applyFilter('all');
      });
    }
  });
</script>
