---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Icon from '../components/icons/SomaIcons.astro';
import { getPublishedBlogPosts, blogPostUrl } from '../lib/blog';

const posts = await getPublishedBlogPosts();
const recentPosts = posts.slice(0, 3);
---

<Layout
  title="Soma — An AI agent that grows with you"
  description="An AI coding agent with persistent memory, evolving identity, and the AMPS content system — automations, muscles, protocols, and scripts. Built on Pi. Open source."
  canonicalUrl="https://soma.gravicity.ai"
>
  <main class="container">
    <!-- Hero -->
    <header class="hero">
      <div class="hero-icon">
        <img src="/media/soma-logo-animated.svg" alt="Soma" width="144" height="144" />
      </div>

      <h1 class="title">
        <span class="title-main">Soma</span>
        <span class="beta-badge">beta</span>
      </h1>

      <p class="tagline">An AI agent that grows with you</p>

      <p class="description">
        Memory that persists across sessions. Identity that evolves through use.<br/>
        Built on <a href="https://github.com/badlogic/pi-mono" target="_blank" rel="noopener">Pi</a>. Extended with automations, muscles, protocols, and scripts. Yours to shape.
      </p>
    </header>

    <!-- Recent Posts -->
    {recentPosts.length > 0 && (
      <section class="recent-posts">
        {recentPosts.map((post, i) => (
          <a href={blogPostUrl(post)} class="recent-post-card">
            {i === 0 && <span class="recent-post-badge">New</span>}
            <span class="recent-post-title">{post.data.title}</span>
            <span class="recent-post-arrow">→</span>
          </a>
        ))}
      </section>
    )}

    <!-- Quick Start -->
    <section class="quickstart">
      <SectionHeader title="Get Started" />
      <div class="code-block">
        <div class="code-header">
          <span class="code-dot"></span>
          <span class="code-dot"></span>
          <span class="code-dot"></span>
          <span class="code-label">terminal</span>
        </div>
        <div class="code-body">
          <div class="code-line">
            <span class="code-comment"># Install Soma globally</span>
          </div>
          <div class="code-line">
            <span class="code-prompt">$</span>
            <span class="code-cmd">npm i -g meetsoma</span>
            <button class="copy-btn" data-copy="npm i -g meetsoma" title="Copy">
              <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
            </button>
          </div>
          <div class="code-line">
            <span class="code-comment"># Start a session</span>
          </div>
          <div class="code-line">
            <span class="code-prompt">$</span>
            <span class="code-cmd">soma</span>
            <button class="copy-btn" data-copy="soma" title="Copy">
              <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
            </button>
          </div>
          <div class="code-line">
            <span class="code-comment"># Continue where you left off</span>
          </div>
          <div class="code-line">
            <span class="code-prompt">$</span>
            <span class="code-cmd">soma -c</span>
            <button class="copy-btn" data-copy="soma -c" title="Copy">
              <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
            </button>
          </div>
        </div>
      </div>
    </section>

    <script>
      document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const text = (btn as HTMLElement).dataset.copy || '';
          const copyIcon = btn.querySelector('.copy-icon') as HTMLElement;
          const checkIcon = btn.querySelector('.check-icon') as HTMLElement;
          try {
            await navigator.clipboard.writeText(text);
            copyIcon.style.display = 'none';
            checkIcon.style.display = 'block';
            setTimeout(() => { copyIcon.style.display = 'block'; checkIcon.style.display = 'none'; }, 2000);
          } catch {}
        });
      });
    </script>

    <!-- AMPS — The Content System -->
    <section class="layers">
      <SectionHeader title="The AMPS Ecosystem" subtitle="Automations · Muscles · Protocols · Scripts" />
      <div class="layers-grid">
        <a href="/ecosystem#automations" class="layer-card">
          <div class="layer-icon"><Icon name="automations" size={34} /></div>
          <h3 class="layer-name">Automations</h3>
          <p class="layer-type">triggered actions</p>
          <p class="layer-desc">
            Step-by-step flows that fire on triggers — session start, post-commit,
            pre-deploy. Procedural and heat-tracked. The reflexes.
          </p>
          <div class="layer-examples">
            <code>session-start</code>
            <code>post-commit</code>
          </div>
        </a>

        <a href="/ecosystem#muscles" class="layer-card">
          <div class="layer-icon"><Icon name="muscles" size={34} /></div>
          <h3 class="layer-name">Muscles</h3>
          <p class="layer-type">learned patterns</p>
          <p class="layer-desc">
            Patterns learned from experience — deployment workflows, code conventions,
            API recipes. Heat-tracked and token-budgeted. The muscle memory.
          </p>
          <div class="layer-examples">
            <code>test-hygiene</code>
            <code>icon-audit</code>
            <code>micro-exhale</code>
          </div>
        </a>

        <a href="/ecosystem#protocols" class="layer-card">
          <div class="layer-icon"><Icon name="protocols" size={34} /></div>
          <h3 class="layer-name">Protocols</h3>
          <p class="layer-type">behavioral rules</p>
          <p class="layer-desc">
            Drop-in behavioral rules that shape how the agent thinks and operates.
            Used protocols heat up and stay loaded. Unused ones fade. The value system.
          </p>
          <div class="layer-examples">
            <code>breath-cycle</code>
            <code>frontmatter</code>
            <code>heat-tracking</code>
          </div>
        </a>

        <a href="/ecosystem#scripts" class="layer-card">
          <div class="layer-icon"><Icon name="scripts" size={34} /></div>
          <h3 class="layer-name">Scripts</h3>
          <p class="layer-type">developer tools</p>
          <p class="layer-desc">
            Reusable bash tools the agent builds and runs. Health checks, deployment
            helpers, verification suites. Discovered at boot, listed in context.
          </p>
          <div class="layer-examples">
            <code>soma-verify.sh</code>
            <code>soma-ship.sh</code>
          </div>
        </a>
      </div>

      <div class="system-layers">
        <a href="/ecosystem#extensions" class="system-card">
          <span class="system-icon"><Icon name="extensions" size={20} /></span>
          <span class="system-name">Extensions</span>
          <span class="system-type">TypeScript runtime hooks</span>
        </a>
        <a href="/ecosystem#skills" class="system-card">
          <span class="system-icon"><Icon name="skills" size={20} /></span>
          <span class="system-name">Skills</span>
          <span class="system-type">Pi-native knowledge sets</span>
        </a>
      </div>
    </section>

    <!-- What Makes Soma Different -->
    <section class="features">
      <SectionHeader title="What Makes Soma Different" />
      <div class="features-grid">
        <div class="feature-card">
          <h3 class="feature-title">Persistent Memory</h3>
          <p class="feature-desc">
            Sessions end. Memory doesn't. Soma flushes what it learns to disk —
            preloads, muscles, context — and picks it back up next time.
          </p>
        </div>
        <div class="feature-card">
          <h3 class="feature-title">Evolving Identity</h3>
          <p class="feature-desc">
            Not pre-configured. Soma's identity file grows through use —
            voice, preferences, working patterns, all discovered, not assigned.
          </p>
        </div>
        <div class="feature-card">
          <h3 class="feature-title">Session Continuity</h3>
          <p class="feature-desc">
            <code>soma -c</code> loads identity plus the last session's preload.
            The agent knows where you left off and what's next.
          </p>
        </div>
        <div class="feature-card">
          <h3 class="feature-title">Adaptive Protocols</h3>
          <p class="feature-desc">
            Behavioral rules that heat up when used and fade when they don't.
            Hot protocols load full context. Cold ones stay available but silent.
            The agent's value system tunes itself.
          </p>
        </div>
        <div class="feature-card">
          <h3 class="feature-title">Workspace Inheritance</h3>
          <p class="feature-desc">
            Parent-child <code>.soma/</code> directories for monorepos. Shared identity,
            protocols, and muscles flow down. Each project overrides what it needs.
          </p>
        </div>
        <div class="feature-card">
          <h3 class="feature-title">Smart Init</h3>
          <p class="feature-desc">
            First run detects your stack — parent workspaces, CLAUDE.md, package manager,
            languages, frameworks. Soma tailors itself to what it finds.
          </p>
        </div>
        <div class="feature-card">
          <h3 class="feature-title">Built on Pi</h3>
          <p class="feature-desc">
            Soma extends pi's coding agent with custom extensions.
            Everything pi can do, Soma can do — with memory on top.
          </p>
        </div>
        <div class="feature-card">
          <h3 class="feature-title">Open Source</h3>
          <p class="feature-desc">
            AMPS, extensions, skills — all MIT licensed.
            Build your own agent identity on the same foundation.
          </p>
        </div>
      </div>
    </section>

    <!-- Ecosystem Map -->
    <section class="ecosystem">
      <SectionHeader title="The Soma Ecosystem" link={{ href: "/ecosystem", text: "Learn more →" }} />
      <div class="ecosystem-grid">
        <a href="https://github.com/meetsoma/soma-agent" target="_blank" rel="noopener" class="eco-card">
          <span class="eco-icon">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" width="40" height="40">
              <!-- Soma mascot silhouette — planet + moon, flat icon style -->
              <circle cx="22" cy="28" r="16" fill="var(--accent-bright)"/>
              <circle cx="37" cy="14" r="7" fill="var(--accent-bright)"/>
              <!-- Eyes cutout -->
              <circle cx="17" cy="26" r="3.5" fill="var(--surface-card)"/>
              <circle cx="27" cy="26" r="3.5" fill="var(--surface-card)"/>
              <!-- Pupils -->
              <circle cx="18.2" cy="25.5" r="1.6" fill="var(--accent-bright)"/>
              <circle cx="28.2" cy="25.5" r="1.6" fill="var(--accent-bright)"/>
            </svg>
          </span>
          <span class="eco-name">agent</span>
          <span class="eco-desc">Extensions, skills & protocols</span>
        </a>
        <a href="https://www.npmjs.com/package/meetsoma" target="_blank" rel="noopener" class="eco-card">
          <span class="eco-icon">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" width="40" height="40">
              <!-- npm logo — flat -->
              <rect x="4" y="12" width="40" height="24" rx="3" fill="#CB3837"/>
              <rect x="10" y="18" width="8" height="12" fill="white"/>
              <rect x="13" y="18" width="3" height="9" fill="#CB3837"/>
              <rect x="21" y="18" width="8" height="12" fill="white"/>
              <rect x="24" y="18" width="3" height="9" fill="#CB3837"/>
              <rect x="32" y="18" width="8" height="9" fill="white"/>
              <rect x="35" y="18" width="3" height="6" fill="#CB3837"/>
            </svg>
          </span>
          <span class="eco-name">npm</span>
          <span class="eco-desc">npm i -g meetsoma</span>
        </a>
        <a href="/blog" class="eco-card">
          <span class="eco-icon">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" width="40" height="40">
              <!-- Blog / writing icon — quill pen -->
              <path d="M36 8L14 30l-2 8 8-2L42 14a4 4 0 00-6-6z" stroke="var(--accent-bright)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M32 12l4 4" stroke="var(--accent-bright)" stroke-width="2.5" stroke-linecap="round"/>
              <path d="M12 38h24" stroke="var(--accent-bright)" stroke-width="2.5" stroke-linecap="round" opacity="0.4"/>
            </svg>
          </span>
          <span class="eco-name">blog</span>
          <span class="eco-desc">Souls & Symlinks</span>
        </a>
        <a href="https://github.com/meetsoma" target="_blank" rel="noopener" class="eco-card">
          <span class="eco-icon">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" width="40" height="40">
              <!-- GitHub mark — simplified octocat silhouette -->
              <path d="M24 4C12.954 4 4 12.954 4 24c0 8.837 5.731 16.329 13.682 18.976.999.184 1.364-.434 1.364-.964 0-.476-.018-2.05-.026-3.72-5.567 1.209-6.74-2.364-6.74-2.364-.91-2.313-2.222-2.929-2.222-2.929-1.815-1.242.138-1.217.138-1.217 2.009.141 3.065 2.063 3.065 2.063 1.784 3.058 4.681 2.174 5.822 1.662.181-1.293.698-2.175 1.27-2.675-4.443-.505-9.114-2.221-9.114-9.888 0-2.184.78-3.97 2.058-5.369-.206-.505-.892-2.54.196-5.293 0 0 1.679-.538 5.499 2.05A19.128 19.128 0 0124 13.2c1.7.008 3.411.23 5.009.673 3.818-2.588 5.494-2.05 5.494-2.05 1.09 2.753.405 4.788.198 5.293 1.281 1.399 2.055 3.185 2.055 5.369 0 7.687-4.677 9.378-9.132 9.872.718.619 1.357 1.839 1.357 3.706 0 2.676-.024 4.833-.024 5.49 0 .534.36 1.156 1.374.96C38.275 40.323 44 32.834 44 24 44 12.954 35.046 4 24 4z" fill="var(--accent-bright)"/>
            </svg>
          </span>
          <span class="eco-name">github</span>
          <span class="eco-desc">meetsoma — source & community</span>
        </a>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="cta-content">
        <h2 class="cta-title">Start growing</h2>
        <p class="cta-desc">Install Soma. Start a session. Let the memory build.</p>
        <div class="cta-buttons">
          <a href="https://github.com/meetsoma/agent" target="_blank" rel="noopener" class="cta-primary">
            View on GitHub →
          </a>
          <a href="/docs" class="cta-secondary">
            Read the docs
          </a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* Design tokens: see Layout.astro :root */

  .container {
    position: relative;
    z-index: 1;
    max-width: 890px;              /* ~55 * φ^4 */
    margin: 0 auto;
    padding: var(--space-3xl) var(--space-xl) var(--space-2xl);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── Hero ── */
  .hero {
    text-align: center;
    margin-bottom: var(--section-gap);
    padding-top: var(--space-2xl);
    animation: fadeUp 0.8s ease-out;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(var(--space-xl)); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-icon {
    width: 144px;                  /* fib */
    height: 144px;
    margin: 0 auto var(--space-2xl);
    animation: float 5s ease-in-out infinite;
  }

  .hero-icon img {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 0 var(--space-xl) var(--logo-glow));
    transition: filter 0.3s;
  }

  .hero-icon:hover img {
    filter: drop-shadow(0 0 var(--space-2xl) var(--logo-glow-hover));
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .title {
    position: relative;
    display: inline-flex;
    align-items: flex-start;
    gap: var(--space-md);
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 12vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: var(--leading-none);
    margin-bottom: var(--space-lg);
    /* Offset to optically center "Soma" — badge adds visual weight to the right */
    transform: translateX(-1.5%);
  }

  .title-main {
    background: linear-gradient(135deg, var(--hero-title-start) 0%, var(--accent-bright) 50%, var(--hero-title-end) 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradientShift 8s ease infinite;
  }

  .beta-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--label-text);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--bg-deep);
    background: linear-gradient(135deg, var(--accent-bright) 0%, rgba(124, 178, 212, 0.8) 100%);
    padding: var(--radius-sm) var(--space-md);
    border-radius: var(--radius-md);
    margin-top: 0.15em;
    -webkit-text-fill-color: var(--bg-deep);
    animation: badgeBob 3s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes badgeBob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .tagline {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--accent-bright);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-xl);
  }

  .description {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: var(--content-wide);
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  .description a {
    color: var(--accent-bright);
    text-decoration: none;
    border-bottom: 1px solid var(--border-accent);
    transition: color 0.2s;
  }

  .description a:hover { color: var(--moon-bright); }

  /* ── Recent Posts ── */
  .recent-posts {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--section-gap);
    animation: fadeUp 0.8s ease-out 0.1s both;
  }

  .recent-post-card {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.25s ease;
  }

  .recent-post-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-2px);
    box-shadow: 0 var(--space-md) var(--space-xl) var(--shadow-accent-soft);
  }

  .recent-post-badge {
    font-family: var(--font-display);
    font-size: var(--badge-text);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--bg-deep);
    background: var(--accent-bright);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-md);
    flex-shrink: 0;
  }

  .recent-post-title {
    flex: 1;
    font-size: var(--body-text);
    font-weight: 500;
  }

  .recent-post-arrow {
    color: var(--text-muted);
    font-size: var(--text-lg);
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .recent-post-card:hover .recent-post-arrow { transform: translateX(5px); }

  /* ── Quick Start ── */
  .quickstart {
    margin-bottom: var(--section-gap);
    animation: fadeUp 0.8s ease-out 0.2s both;
  }

  .code-block {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card-strong);
    overflow: hidden;
  }

  .code-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg) var(--space-xl);
    border-bottom: 1px solid var(--border-subtle);
  }

  .code-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--surface-interactive);
  }

  .code-label {
    margin-left: var(--space-md);
    font-family: var(--font-mono);
    font-size: var(--label-text);
    color: var(--text-muted);
  }

  .code-body {
    padding: var(--space-xl);
    font-family: var(--font-mono);
    font-size: var(--body-secondary);
    line-height: var(--leading-loose);
  }

  .code-line {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .code-prompt {
    color: var(--accent-bright);
    user-select: none;
  }

  .code-cmd { color: var(--text-primary); }

  .code-comment {
    color: var(--text-muted);
    font-style: italic;
  }

  .copy-btn {
    margin-left: auto;
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: var(--space-sm);
    border-radius: var(--radius-md);
    transition: color 0.2s, background 0.2s;
    display: flex;
    align-items: center;
  }

  .copy-btn:hover {
    color: var(--accent-bright);
    background: var(--surface-interactive);
  }

  .copy-btn svg { width: 18px; height: 18px; }

  /* ── AMPS Layers ── */
  .layers {
    margin-bottom: var(--section-gap);
    animation: fadeUp 0.8s ease-out 0.3s both;
  }

  .layers-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--grid-gap);
  }

  .system-layers {
    display: flex;
    gap: var(--grid-gap);
    margin-top: var(--space-lg);
  }

  .system-card {
    flex: 1;
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg) var(--card-pad-x);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
