---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Icon from '../../components/icons/SomaIcons.astro';
---

<Layout
  title="Ecosystem — Soma"
  description="How Soma's four layers work together — extensions, skills, muscles, and protocols."
  canonicalUrl="https://soma.gravicity.ai/ecosystem"
>
  <main class="container">
    <Breadcrumbs items={[
      { label: 'Ecosystem', href: '/ecosystem' },
    ]} />

    <header class="header">
      <h1 class="title">The Soma Ecosystem</h1>
      <p class="subtitle">
        Extensions, skills, muscles, and protocols — four layers that give an AI agent 
        persistent memory, evolving identity, learned patterns, and adaptive behavior.
      </p>
    </header>

    <!-- Orbital Architecture Diagram -->
    <section class="diagram-section">
      <div class="orbit-diagram" aria-label="Soma ecosystem orbital diagram">
        <!-- Orbital ring -->
        <div class="orbit-ring"></div>
        <div class="orbit-ring orbit-ring-inner"></div>

        <!-- Center: Soma -->
        <div class="orbit-center">
          <img src="/media/soma-logo-animated.svg" alt="" width="55" height="55" class="orbit-logo" />
          <span class="orbit-center-label">soma</span>
        </div>

        <!-- Inner orbit: you + pi + memory -->
        <div class="orbit-node orbit-you">
          <span class="orbit-node-icon"><Icon name="you" size={21} /></span>
          <span class="orbit-node-label">you</span>
        </div>

        <div class="orbit-node orbit-pi">
          <span class="orbit-node-icon"><Icon name="pi" size={21} /></span>
          <span class="orbit-node-label">pi</span>
          <span class="orbit-node-sub">runtime</span>
        </div>

        <div class="orbit-node orbit-memory">
          <span class="orbit-node-icon"><Icon name="memory" size={21} /></span>
          <span class="orbit-node-label">memory</span>
          <span class="orbit-node-sub">.soma/</span>
        </div>

        <!-- Outer orbit: the four layers -->
        <div class="orbit-node orbit-layer orbit-ext">
          <span class="orbit-node-icon"><Icon name="extensions" size={24} /></span>
          <span class="orbit-node-label">extensions</span>
        </div>

        <div class="orbit-node orbit-layer orbit-skill">
          <span class="orbit-node-icon"><Icon name="skills" size={24} /></span>
          <span class="orbit-node-label">skills</span>
        </div>

        <div class="orbit-node orbit-layer orbit-muscle">
          <span class="orbit-node-icon"><Icon name="muscles" size={24} /></span>
          <span class="orbit-node-label">muscles</span>
        </div>

        <div class="orbit-node orbit-layer orbit-protocol">
          <span class="orbit-node-icon"><Icon name="protocols" size={24} /></span>
          <span class="orbit-node-label">protocols</span>
        </div>
      </div>
    </section>

    <!-- Three Layers Detail -->
    <section class="layers-detail">
      <div class="layer-detail" id="extensions">
        <div class="layer-header">
          <span class="layer-glyph"><Icon name="extensions" size={34} /></span>
          <div>
            <h2 class="layer-title">Extensions</h2>
            <p class="layer-kind">system hooks · TypeScript</p>
          </div>
        </div>
        <p class="layer-body">
          Extensions are TypeScript files that hook into pi's lifecycle. They run at boot, 
          render custom UI, intercept events, and manage background processes. They're the 
          lowest level of customization — full access to the agent runtime.
        </p>
        <div class="layer-details">
          <div class="detail-col">
            <h4>What they do</h4>
            <ul>
              <li>Boot sequences — load identity, preload memory</li>
              <li>Custom headers and statuslines</li>
              <li>Auto-flush memory to disk</li>
              <li>Context usage warnings</li>
              <li>Slash commands (<code>/exhale</code>, <code>/breathe</code>, <code>/rest</code>, <code>/soma</code>)</li>
            </ul>
          </div>
          <div class="detail-col">
            <h4>Where they live</h4>
            <ul>
              <li><code>.soma/extensions/</code> — project-level</li>
              <li><code>~/.soma/extensions/</code> — global</li>
            </ul>
            <h4 class="mt">Soma ships with</h4>
            <ul>
              <li><code>soma-boot.ts</code> — identity + preload + commands</li>
              <li><code>soma-header.ts</code> — branded σῶμα header</li>
              <li><code>soma-statusline.ts</code> — footer + auto-flush</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="layer-detail" id="skills">
        <div class="layer-header">
          <span class="layer-glyph"><Icon name="skills" size={34} /></span>
          <div>
            <h2 class="layer-title">Skills</h2>
            <p class="layer-kind">knowledge sets · Markdown</p>
          </div>
        </div>
        <p class="layer-body">
          Skills are markdown files that give the agent domain expertise. When the agent 
          encounters a task that matches a skill, it loads the instructions and follows them. 
          Low barrier to create — just write markdown.
        </p>
        <div class="layer-details">
          <div class="detail-col">
            <h4>What they contain</h4>
            <ul>
              <li>Task-specific instructions and best practices</li>
              <li>Tool usage patterns and examples</li>
              <li>Decision frameworks and checklists</li>
              <li>Reference material the agent can cite</li>
            </ul>
          </div>
          <div class="detail-col">
            <h4>Where they live</h4>
            <ul>
              <li><code>~/.soma/skills/</code> — global skills</li>
              <li><code>.soma/skills/</code> — project-specific</li>
            </ul>
            <h4 class="mt">Examples</h4>
            <ul>
              <li><code>logo-creator</code> — AI logo generation workflow</li>
              <li><code>favicon-gen</code> — favicon from any source</li>
              <li><code>remotion-best-practices</code> — video in React</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="layer-detail" id="muscles">
        <div class="layer-header">
          <span class="layer-glyph"><Icon name="muscles" size={34} /></span>
          <div>
            <h2 class="layer-title">Muscles</h2>
            <p class="layer-kind">learned patterns · heat-tracked · Markdown</p>
          </div>
        </div>
        <p class="layer-body">
          Muscles are patterns learned from experience — reusable knowledge that Soma 
          builds across sessions. Each muscle has a heat score and a digest block for 
          token-efficient loading. They're the muscle memory.
        </p>
        <div class="layer-details">
          <div class="detail-col">
            <h4>What they do</h4>
            <ul>
              <li>Encode workflows discovered through repeated use</li>
              <li>Load automatically when context matches their topic</li>
              <li>Include digest blocks for efficient context loading</li>
              <li>Track load count — grow stronger with use</li>
            </ul>
          </div>
          <div class="detail-col">
            <h4>Built-in muscles</h4>
            <ul>
              <li><code>blog-writing</code> — voice, accuracy, pre-publish checks</li>
              <li><code>test-hygiene</code> — catch stale tests after changes</li>
              <li><code>pre-publish-cleanup</code> — preserve before you delete</li>
              <li><code>pr-release-workflow</code> — branching and release patterns</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="layer-detail" id="protocols">
        <div class="layer-header">
          <span class="layer-glyph"><Icon name="protocols" size={34} /></span>
          <div>
            <h2 class="layer-title">Protocols</h2>
            <p class="layer-kind">behavioral rules · adaptive · Markdown</p>
          </div>
        </div>
        <p class="layer-body">
          Protocols are behavioral rules the agent follows — not how to do a task, but how 
          to <em>be</em>. Drop a protocol into your project and the agent adapts. The more a 
          protocol gets used, the more deeply it's loaded. Unused protocols fade naturally.
        </p>
        <div class="layer-details">
          <div class="detail-col">
            <h4>How they work</h4>
            <ul>
              <li>Drop a <code>.md</code> file into <code>.soma/protocols/</code></li>
              <li>Agent discovers it on next boot</li>
              <li>Used protocols "heat up" — always loaded</li>
              <li>Unused protocols "cool down" — fade out</li>
              <li>Each protocol has a breadcrumb TL;DR for token efficiency</li>
            </ul>
          </div>
          <div class="detail-col">
            <h4>Where they live</h4>
            <ul>
              <li><code>~/.soma/protocols/</code> — global defaults</li>
              <li><code>.soma/protocols/</code> — project-specific</li>
            </ul>
            <h4 class="mt">Core protocols</h4>
            <ul>
              <li><code>breath-cycle</code> — session lifecycle (inhale/hold/exhale)</li>
              <li><code>frontmatter-standard</code> — document metadata rules</li>
              <li><code>heat-tracking</code> — adaptive loading by usage</li>
            </ul>
            <p class="coming-soon">Heat system is enterprise. Free tier gets manual loading.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Templates -->
    <section class="templates" id="templates">
      <SectionHeader title="Agent Templates" />
      <p class="templates-intro">
        Share your entire agent setup as a template. A template is a preconfigured 
        <code>.soma/</code> bundle — identity, protocols, skills, settings — that anyone 
        can clone and customize. Start with a personality, not a blank slate.
      </p>
      <div class="templates-grid">
        <div class="template-card">
          <div class="template-icon"><Icon name="wrench" size={24} /></div>
          <h3 class="template-name">DevOps Agent</h3>
          <p class="template-desc">
            Deployment protocols, CI/CD skills, infra muscles. Pre-heated for 
            shipping code to production.
          </p>
          <code class="template-cmd">soma init --template devops</code>
        </div>
        <div class="template-card">
          <div class="template-icon"><Icon name="pen-line" size={24} /></div>
          <h3 class="template-name">Content Writer</h3>
          <p class="template-desc">
            SEO protocols, blog-writing muscle, tone-of-voice identity. 
            Ready to write and ship content.
          </p>
          <code class="template-cmd">soma init --template writer</code>
        </div>
        <div class="template-card">
          <div class="template-icon"><Icon name="ruler" size={24} /></div>
          <h3 class="template-name">Architect</h3>
          <p class="template-desc">
            Frontmatter standards, code review protocols, test-hygiene muscle.
            For teams that care about structure.
          </p>
          <code class="template-cmd">soma init --template architect</code>
        </div>
        <div class="template-card">
          <div class="template-icon"><Icon name="flask" size={24} /></div>
          <h3 class="template-name">Roll Your Own</h3>
          <p class="template-desc">
            Export your current setup as a template. Share your agent's 
            personality with the community.
          </p>
          <code class="template-cmd">soma template export my-agent</code>
        </div>
      </div>
      <p class="coming-soon" style="text-align: center; margin-top: 16px;">
        Template system coming soon. <a href="https://github.com/meetsoma/soma-agent" target="_blank" rel="noopener">Follow development →</a>
      </p>
    </section>

    <!-- Community -->
    <section class="community" id="community">
      <SectionHeader title="Community" />
      <p class="community-intro">
        Share your agent's protocols, muscles, and skills with others. Import what works.
        The community repo is the library — fork it, contribute back, or just browse.
      </p>
      <div class="community-stats">
        <div class="stat-card">
          <span class="stat-number">4</span>
          <span class="stat-label">Protocols</span>
          <span class="stat-detail">breath-cycle · frontmatter · heat-tracking · git-identity</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">4</span>
          <span class="stat-label">Muscles</span>
          <span class="stat-detail">test-hygiene · pre-publish · blog-writing · pr-release</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">3</span>
          <span class="stat-label">Templates</span>
          <span class="stat-detail">devops · writer · architect</span>
        </div>
      </div>
      <div class="community-cta">
        <code class="install-cmd">soma community install protocol breath-cycle</code>
        <p class="coming-soon">CLI install coming soon. For now, copy from the <a href="https://github.com/meetsoma/community" target="_blank" rel="noopener">community repo</a>.</p>
      </div>
    </section>

    <!-- Repos -->
    <section class="repos">
      <SectionHeader title="Repositories" />
      <div class="repos-grid">
        <a href="https://github.com/meetsoma/soma-agent" target="_blank" rel="noopener" class="repo-card">
          <h3>meetsoma/soma-agent</h3>
          <p>Extensions, skills, muscles, protocols, and documentation. The core.</p>
        </a>
        <a href="https://github.com/meetsoma/community" target="_blank" rel="noopener" class="repo-card repo-card-featured">
          <h3>meetsoma/community</h3>
          <p>Shared protocols, muscles, skills, and templates. Fork it, contribute, browse.</p>
        </a>
        <a href="https://github.com/meetsoma/cli" target="_blank" rel="noopener" class="repo-card">
          <h3>meetsoma/cli</h3>
          <p>The <code>soma</code> CLI — wraps pi with Soma's config and extensions.</p>
        </a>
        <a href="https://github.com/meetsoma/website" target="_blank" rel="noopener" class="repo-card">
          <h3>meetsoma/website</h3>
          <p>This site. Astro, static, deployed on Vercel.</p>
        </a>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* Design tokens: see Layout.astro :root */

  .container {
    position: relative; z-index: 1;
    max-width: 890px;
    margin: 0 auto;
    padding: var(--space-3xl) 21px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .header { text-align: center; margin-bottom: var(--space-3xl); }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 2.625rem);
    font-weight: 700;
    margin-bottom: var(--space-lg);
    line-height: var(--leading-tight);
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    max-width: 560px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  /* ── Orbital Diagram ── */
  .diagram-section { margin-bottom: var(--space-3xl); }

  .orbit-diagram {
    position: relative;
    width: 100%;
    max-width: 480px;
    aspect-ratio: 1;
    margin: 0 auto;
  }

  /* Orbital rings */
  .orbit-ring {
    position: absolute;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-subtle);
    /* Outer ring — the four layers orbit here */
    inset: 0;
  }

  .orbit-ring-inner {
    /* Inner ring — you, pi, memory */
    inset: 22%;
    border-style: dashed;
    border-color: rgba(104, 152, 190, 0.15);
  }

  /* Center node */
  .orbit-center {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    z-index: 2;
  }

  .orbit-logo {
    filter: drop-shadow(0 0 21px var(--logo-glow));
    animation: float 5s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  .orbit-center-label {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: 0.05em;
  }

  /* Orbit nodes — shared */
  .orbit-node {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    transform: translate(-50%, -50%);
    z-index: 3;
  }

  .orbit-node-icon {
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card-strong);
    font-size: var(--text-lg);
    color: var(--accent-bright);
    backdrop-filter: blur(8px);
    transition: all 0.3s ease;
  }

  .orbit-node:hover .orbit-node-icon {
    border-color: var(--border-accent);
    box-shadow: 0 0 21px var(--shadow-accent-soft);
    transform: scale(1.12);
  }

  .orbit-node-label {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
  }

  .orbit-node-sub {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    white-space: nowrap;
  }

  /* Inner orbit positions (33% from center) */
  .orbit-you     { top: 28%; left: 28%; }
  .orbit-pi      { top: 28%; left: 72%; }
  .orbit-memory   { top: 76%; left: 50%; }
  .orbit-memory .orbit-node-icon { color: var(--warm-bright); border-color: rgba(232, 168, 124, 0.25); }

  /* Outer orbit positions — cardinal + diagonal spread */
  .orbit-ext      { top: 3%;  left: 50%; }
  .orbit-skill    { top: 50%; left: 97%; }
  .orbit-muscle   { top: 97%; left: 50%; }
  .orbit-protocol { top: 50%; left: 3%;  }

  /* Layer nodes slightly larger */
  .orbit-layer .orbit-node-icon {
    width: 50px;
    height: 50px;
    font-size: var(--text-xl);
  }

  .orbit-layer .orbit-node-label {
    font-size: var(--text-base);
  }

  /* Subtle slow rotation for the outer ring */
  @keyframes orbitSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Connection lines — SVG would be better but CSS pseudo-elements work */
  .orbit-diagram::before {
    content: '';
    position: absolute;
    inset: 11%;
    border-radius: var(--radius-full);
    border: 1px solid rgba(104, 152, 190, 0.08);
    z-index: 1;
    animation: orbitPulse 8s ease-in-out infinite;
  }

  @keyframes orbitPulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.02); }
  }

  /* ── Layer Details ── */
  .layers-detail {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
    margin-bottom: var(--space-3xl);
  }

  .layer-detail {
    padding: var(--space-2xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
  }

  .layer-header {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .layer-glyph {
    font-size: var(--text-3xl);
    color: var(--accent-bright);
    line-height: var(--leading-none);
  }

  .layer-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: var(--leading-tight);
  }

  .layer-kind {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .layer-body {
    color: var(--text-secondary);
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-xl);
  }

  .layer-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
  }

  .detail-col h4 {
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: 600;
    margin-bottom: var(--space-md);
    color: var(--text-primary);
    line-height: var(--leading-tight);
  }

  .detail-col .mt { margin-top: var(--space-xl); }

  .detail-col ul {
    list-style: none;
    padding: 0;
  }

  .detail-col li {
    font-size: var(--text-base);
    color: var(--text-secondary);
    padding: var(--space-sm) 0;
    padding-left: 13px;
    position: relative;
    line-height: var(--leading-relaxed);
  }

  .detail-col li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--accent-bright);
    font-weight: bold;
  }

  .detail-col code {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: 2px var(--space-md);
    border-radius: var(--radius-sm);
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  .coming-soon {
    margin-top: var(--space-lg);
    font-size: var(--text-base);
    color: var(--warm-bright);
    font-style: italic;
  }

  .coming-soon a {
    color: var(--warm-bright);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Templates ── */
  .templates { margin-bottom: var(--space-3xl); }

  .templates-intro {
    color: var(--text-secondary);
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-xl);
    text-align: center;
    max-width: 610px;
    margin-left: auto;
    margin-right: auto;
  }

  .templates-intro code {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    padding: 2px var(--space-md);
    border-radius: var(--radius-sm);
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  .templates-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .template-card {
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    background: var(--surface-card);
    text-align: center;
    transition: all 0.25s ease;
  }

  .template-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-3px);
    box-shadow: 0 8px 21px var(--shadow-accent-soft);
  }

  .template-icon { color: var(--accent-bright); margin-bottom: var(--space-md); display: flex; justify-content: center; }

  .template-name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-md);
    line-height: var(--leading-tight);
  }

  .template-desc {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-lg);
  }

  .template-cmd {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: var(--space-sm) 13px;
    border-radius: var(--radius-md);
    background: var(--surface-accent-soft);
    color: var(--accent-bright);
  }

  /* ── Community ── */
  .community { margin-bottom: var(--space-3xl); }

  .community-intro {
    color: var(--text-secondary);
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-xl);
    text-align: center;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .community-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
