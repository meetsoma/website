---
import Layout from '../../layouts/Layout.astro';

const title = "Beta Access — Soma";
const description = "Request early access to Soma — the AI agent that grows with you.";
---

<Layout title={title} description={description}>
<style>
  .beta-page {
    max-width: var(--content-wide, 610px);
    margin: 0 auto;
    padding: var(--space-4xl) var(--space-xl);
    text-align: center;
  }
  .beta-page h1 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-md);
  }
  .beta-page .subtitle {
    color: var(--text-muted);
    font-size: var(--text-lg);
    margin-bottom: var(--space-2xl);
  }
  .beta-page .description {
    text-align: left;
    line-height: 1.7;
    font-size: var(--body-text);
    margin-bottom: var(--space-2xl);
  }
  .beta-page .description p {
    margin-bottom: var(--space-lg);
  }
  .beta-form {
    text-align: left;
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--space-lg);
    padding: var(--space-2xl);
    margin-bottom: var(--space-2xl);
  }
  .beta-form h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-xl);
  }
  .form-field {
    margin-bottom: var(--space-xl);
  }
  .form-field label {
    display: block;
    font-size: var(--label-text);
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }
  .form-field input, .form-field select, .form-field textarea {
    width: 100%;
    padding: var(--space-md) var(--space-lg);
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--space-md);
    color: var(--text-primary);
    font-size: var(--body-text);
    font-family: inherit;
  }
  .form-field textarea {
    min-height: 80px;
    resize: vertical;
  }
  .form-field input:focus, .form-field select:focus, .form-field textarea:focus {
    outline: none;
    border-color: var(--accent-bright);
  }
  .submit-btn {
    width: 100%;
    padding: var(--space-lg);
    background: var(--accent-mid);
    color: var(--text-primary);
    border: none;
    border-radius: var(--space-md);
    font-size: var(--body-text);
    cursor: pointer;
    font-family: inherit;
    transition: opacity 0.2s;
  }
  .submit-btn:hover {
    opacity: 0.85;
  }
  .beta-tiers {
    text-align: left;
    margin-top: var(--space-2xl);
  }
  .beta-tiers h3 {
    font-size: var(--text-md);
    margin-bottom: var(--space-lg);
  }
  .tier {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-lg);
    border: 1px solid var(--border-subtle);
    border-radius: var(--space-md);
    margin-bottom: var(--space-lg);
  }
  .tier-icon {
    font-size: var(--text-2xl);
    flex-shrink: 0;
  }
  .tier-name {
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }
  .tier-desc {
    font-size: var(--body-secondary);
    color: var(--text-muted);
  }
</style>

<div class="beta-page">
  <h1>Private Beta</h1>
  <p class="subtitle">Early access to Soma — the AI agent that grows with you</p>

  <div class="description">
    <p>
      We're building an AI coding agent with real memory — identity that evolves,
      patterns that crystallize through use, and tools the agent builds for itself.
      Not RAG. Not vector search. Actual memory that changes how the agent works.
    </p>
    <p>
      Soma is entering private beta. We want thoughtful early users who'll push the system,
      find the edges, and help shape what this becomes.
    </p>
  </div>

  <div class="how-it-works" style="text-align: left; margin-bottom: var(--space-2xl); padding: var(--space-xl); border: 1px solid var(--border-subtle); border-radius: var(--space-lg); background: var(--bg-surface);">
    <h3 style="font-size: var(--text-md); margin-bottom: var(--space-lg);">How it works</h3>
    <ol style="line-height: 1.8; color: var(--text-muted); padding-left: var(--space-xl);">
      <li>Submit the form below with your GitHub username</li>
      <li>Your request is created as a GitHub issue — you'll get a tracking link</li>
      <li>We review your request (usually within 24 hours)</li>
      <li>On approval, you're added to our beta testers team on GitHub</li>
      <li>You get access to the private repo + install instructions</li>
      <li>Install, use, break things, tell us what happened</li>
    </ol>
  </div>

  <div class="beta-form">
    <h2>Request Access</h2>
    <form id="beta-form" onsubmit="return handleSubmit(event)">
      <div class="form-field">
        <label for="github">GitHub Username *</label>
        <div style="position: relative;">
          <input type="text" id="github" name="github" required placeholder="your-username" autocomplete="off" />
          <span id="gh-check" style="position: absolute; right: var(--space-lg); top: 50%; transform: translateY(-50%); font-size: var(--text-sm);"></span>
        </div>
      </div>
      <div class="form-field">
        <label for="email">Email *</label>
        <input type="email" id="email" name="email" required placeholder="you@example.com" />
      </div>
      <div class="form-field">
        <label for="interest">What interests you about Soma?</label>
        <select id="interest" name="interest">
          <option value="">Select...</option>
          <option value="memory">Agent memory across sessions</option>
          <option value="protocols">Protocol and muscle system</option>
          <option value="tools">Self-building tools (scripts, MAPs)</option>
          <option value="multi-agent">Multi-agent orchestration</option>
          <option value="contribute">Contributing to the project</option>
          <option value="other">Something else</option>
        </select>
      </div>
      <div class="form-field">
        <label for="context">What are you building? (optional)</label>
        <textarea id="context" name="context" placeholder="Brief description of your project or use case..."></textarea>
      </div>
      <button type="submit" class="submit-btn" id="submit-btn">Request Early Access</button>
      <p id="form-status" style="margin-top: 1rem; text-align: center; display: none;"></p>
    </form>
    <script>
      // GitHub username validation — debounced, checks API
      let ghTimer = null;
      let ghValid = false;
      const ghInput = document.getElementById('github');
      const ghCheck = document.getElementById('gh-check');

      ghInput.addEventListener('input', () => {
        clearTimeout(ghTimer);
        const val = ghInput.value.trim();
        ghValid = false;

        if (!val) {
          ghCheck.textContent = '';
          return;
        }
        if (!/^[a-zA-Z0-9](?:[a-zA-Z0-9]|-(?=[a-zA-Z0-9])){0,38}$/.test(val)) {
          ghCheck.textContent = '✗';
          ghCheck.style.color = '#f87171';
          return;
        }

        ghCheck.textContent = '...';
        ghCheck.style.color = 'var(--text-muted)';

        ghTimer = setTimeout(async () => {
          try {
            const res = await fetch(`https://api.github.com/users/${val}`);
            if (res.ok) {
              const data = await res.json();
              ghCheck.innerHTML = `<img src="${data.avatar_url}" width="20" height="20" style="border-radius:50%;vertical-align:middle;margin-right:4px" /> ✓`;
              ghCheck.style.color = '#4ade80';
              ghValid = true;
            } else {
              ghCheck.textContent = '✗ not found';
              ghCheck.style.color = '#f87171';
            }
          } catch {
            ghCheck.textContent = '';
          }
        }, 400);
      });

      async function handleSubmit(e) {
        e.preventDefault();
        const btn = document.getElementById('submit-btn');
        const status = document.getElementById('form-status');
        const form = document.getElementById('beta-form');

        if (!ghValid) {
          status.style.display = 'block';
          status.textContent = '✗ Please enter a valid GitHub username';
          status.style.color = '#f87171';
          return false;
        }

        btn.disabled = true;
        btn.textContent = 'Submitting...';
        status.style.display = 'none';
        try {
          const res = await fetch('/api/beta-signup', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              github: form.github.value,
              email: form.email.value,
              interest: form.interest.value,
              context: form.context.value,
            }),
          });
          const data = await res.json();
          status.style.display = 'block';
          if (data.success) {
            if (data.issueUrl) {
              status.innerHTML = '✓ ' + data.message + '<br><a href="' + data.issueUrl + '" target="_blank" rel="noopener" style="color: var(--accent-bright); text-decoration: underline;">Track your request →</a>';
            } else {
              status.textContent = '✓ ' + data.message;
            }
            status.style.color = '#4ade80';
            form.reset();
          } else {
            status.textContent = '✗ ' + (data.error || 'Something went wrong');
            status.style.color = '#f87171';
          }
        } catch (err) {
          status.style.display = 'block';
          status.textContent = '✗ Network error. Please try again.';
          status.style.color = '#f87171';
        }
        btn.disabled = false;
        btn.textContent = 'Request Early Access';
        return false;
      }
    </script>
  </div>

  <div class="beta-tiers">
    <h3>Access Tiers</h3>
    <div class="tier">
      <span class="tier-icon">⚡</span>
      <div>
        <div class="tier-name">Beta Tester</div>
        <div class="tier-desc">Compiled CLI + all protocols + scripts + documentation. Use Soma in your projects. Provide feedback.</div>
      </div>
    </div>
    <div class="tier">
      <span class="tier-icon">🔧</span>
      <div>
        <div class="tier-name">Contributor</div>
        <div class="tier-desc">Full source access + dev tools + direct line to the team. Help build the future of agent memory.</div>
      </div>
    </div>
  </div>
</div>
</Layout>
