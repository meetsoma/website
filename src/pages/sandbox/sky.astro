---
/**
 * /sandbox/sky — design iteration sandbox for the light theme.
 *
 * Cycle 17 (s01-7b287c). Curtis: "we'd have to get it right first tho on a
 * test page" before adopting Tincture sitewide. This page renders the
 * full atmospheric stack (Starfield + Sky + glow-orbs + nav + content
 * blocks) but with EXPERIMENTAL palette overrides scoped to this route.
 *
 * Iterate the palette here. When the look is locked, copy the winning
 * --token values into src/layouts/Layout.astro (or migrate the whole
 * stack to Tincture per personal/tincture-css/tincture.skill.md).
 *
 * NOT for users — sitemap-excluded, robots-noindex.
 */
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Sandbox · Sky · σ"
  description="Design iteration sandbox — light theme palette tuning."
  path="/sandbox/sky"
>
  <!-- Extra cloud depth layers — sandbox only. The 3 glow-orbs from Layout
       handle mid-altitude. These add the near + far extremes. -->
  <div class="sb-clouds" aria-hidden="true">
    <!-- Cirrus — very high, hairline thin, barely there -->
    <div class="sb-cloud sb-cloud-cirrus"></div>
    <!-- Near cumulus — low, chunkier, moves slower visually -->
    <div class="sb-cloud sb-cloud-cumulus"></div>
    <!-- Horizon haze — diffuse warm band where sun leaks through -->
    <div class="sb-cloud sb-cloud-haze"></div>
  </div>

  <main class="sandbox-main">
    <header class="sandbox-hero">
      <h1>cloud cover at dawn</h1>
      <p class="sandbox-lead">
        A sky that breathes. Pale blue overcast with thin wisps of cirrus,
        a sun just out of frame casting warmth from one side. Toggle theme
        in the nav to see the time-lapse.
      </p>
    </header>

    <section class="sandbox-grid">
      <article class="sandbox-card">
        <h2>Card on cloud-white</h2>
        <p>Body text against a pale sky. Should read crisply but feel soft.</p>
        <p>Inline <code>code</code> token, <a href="#">a link</a>, and a button.</p>
        <button class="sandbox-btn">Action</button>
      </article>

      <article class="sandbox-card sandbox-card-elevated">
        <h2>Elevated card</h2>
        <p>Subtly raised — slightly more saturated background, soft shadow.</p>
        <code class="sandbox-code-inline">soma:body.audit</code>
      </article>

      <article class="sandbox-card">
        <h2>Code block</h2>
        <pre class="sandbox-code-block"><code>{`async function dawnBreaks(theme) {
  const sky = await getSky();
  return sky.transition(theme, {
    stars: 'buzz',
    horizon: 'sweep',
    sun: 'spin-in'
  });
}`}</code></pre>
      </article>
    </section>

    <section class="sandbox-tones">
      <h2>Tone scale</h2>
      <div class="sandbox-swatches">
        <div class="swatch" style="background: var(--bg)">bg-deep</div>
        <div class="swatch" style="background: var(--bg-card)">bg-surface</div>
        <div class="swatch" style="background: var(--bg-elev)">bg-elevated</div>
        <div class="swatch" style="background: var(--accent); color: white">accent</div>
        <div class="swatch" style="background: var(--moon-bright); color: white">moon</div>
        <div class="swatch" style="background: var(--warm-bright); color: white">warm</div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  /* ==========================================================================
   * SANDBOX SKY — iter 3 (s01-b73653)
   * Curtis: "needs to feel like it has depth — light mode is lacking that,
   * the blue feel of a sky, some clouds close others farther, slightly moving."
   * + "Soma title shadow is now on the front of it (sun behind)."
   *
   * Architecture:
   *   body gradient  — zenith deep blue → pale diffuse horizon
   *   .glow-orb-1/2  — mid-altitude altostratus layers (tuned from Layout)
   *   .glow-orb-3    — low warm wisp / sunlit cloud edge
   *   .sb-cloud-cirrus  — high cirrus, hairline, barely there, fast drift
   *   .sb-cloud-cumulus — near low cumulus, thicker, slowest angular speed
   *   .sb-cloud-haze    — horizon warm band (sun leaking through overcast)
   * ==========================================================================*/

  /* ── 1. SKY GRADIENT — real zenith→horizon gradient ──────────────────────
   * Overcast dawn: blue comes through cloud layer diffused — saturated but
   * not blazing. Warm amber bleeds in from bottom-right (sun below horizon). */
  html[data-theme='light'] body:has(.sandbox-main) {
    background: none !important;
  }
  html[data-theme='light'] body:has(.sandbox-main)::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: -1;
    background:
      /* Warm sun breaking through from lower-right (sun still low at dawn) */
      radial-gradient(
        ellipse 55% 45% at 108% 108%,
        rgba(255, 205, 120, 0.40) 0%,
        rgba(230, 165, 70, 0.14) 38%,
        transparent 65%
      ),
      /* Real sky gradient — derived from Pexels deep-blue clear sky reference.
       * Zenith #1a5ba0 (true deep blue) → pale diffuse horizon.
       * The richness at top is the key missing piece vs earlier iterations. */
      linear-gradient(
        to bottom,
        #1a5ba0 0%,    /* zenith — real sky blue (from pexels clear sky ref) */
        #2e70b0 10%,   /* upper sky */
        #4a8dc4 25%,   /* upper-mid */
        #6aa8d4 40%,   /* mid sky, cloud layer starts diffusing */
        #92c0da 55%,   /* lower mid — progressively paler */
        #bbd6e8 70%,   /* near horizon, milky */
        #d8ecf4 85%,   /* horizon diffuse */
        #e8f5fa 100%   /* horizon, near white */
      );
  }

  /* Card/surface tokens for this palette */
  html[data-theme='light'] body:has(.sandbox-main) {
    /* Tincture token overrides — tuned for saturated blue sky bg */
    --bg:      #92c0da;
    --bg-card: #e4f2f9;   /* cloud-white, clearly lighter than sky */
    --bg-elev: #cce2f0;   /* cloud shadow — slightly deeper */
    --ink:          #081624;
    --ink-soft:     #172e48;
    --ink-muted:    #2e4d6a;
    --accent:       #1555a0;
    --border:       rgba(8, 22, 36, 0.14);
    --border-accent: rgba(21, 85, 160, 0.38);
    --shadow-accent: rgba(21, 85, 160, 0.20);
    --shadow-card:  0 2px 10px rgba(8,22,36,0.12), 0 8px 24px rgba(8,22,36,0.08);

    /* Legacy aliases */
    --accent-bright: var(--accent);
    --border-subtle: var(--border);
    --shadow-accent-soft: var(--shadow-accent);
    --shadow-accent-mid: rgba(21, 85, 160, 0.30);
    --moon-bright:  #2870b0;
    --moon-glow:    rgba(21, 85, 160, 0.28);
    --warm-bright:  #c0682a;
    --logo-glow:    rgba(21, 85, 160, 0.24);
    --logo-glow-hover: rgba(21, 85, 160, 0.42);

    /* Glass-card feel: white-blue at high opacity so cards pop from the sky */
    --surface-card:              rgba(232, 246, 252, 0.90);
    --surface-card-strong:       rgba(240, 250, 255, 0.97);
    --surface-interactive:       rgba(8, 22, 36, 0.07);
    --surface-interactive-hover: rgba(8, 22, 36, 0.13);
    --surface-accent-soft:       rgba(21, 85, 160, 0.10);
  }

  /* ── 2. EXISTING GLOW ORBS — mid-altitude cloud layers ───────────────────
   * Repurposed from Layout's circular nebula orbs into horizontal cloud streaks.
   * orb-1 = altostratus (mid-high)  orb-2 = stratus (mid)  orb-3 = sunlit edge */
  html[data-theme='light'] body:has(.sandbox-main) .glow-orbs {
    opacity: 1;
  }
  html[data-theme='light'] body:has(.sandbox-main) .glow-orb {
    mix-blend-mode: multiply;
  }
  html[data-theme='light'] body:has(.sandbox-main) .glow-orb-1 {
    /* Altostratus band — mid-high, wide, blue-grey, slow.
     * From pexels ref: cloud bodies are darker than sky on a clear blue day.
     * These clouds are slightly darker than the #4a8dc4 mid-sky zone. */
    background: radial-gradient(ellipse,
      rgba(90, 130, 170, 0.28) 0%,
      rgba(70, 112, 155, 0.10) 50%,
      transparent 78%);
    transform: scale(4.0, 0.16) rotate(-4deg);
    animation-duration: 42s;
    opacity: 0.9;
  }
  html[data-theme='light'] body:has(.sandbox-main) .glow-orb-2 {
    /* Stratus layer — slightly lower, wider sweep, fractionally warmer. */
    background: radial-gradient(ellipse,
      rgba(75, 118, 160, 0.24) 0%,
      rgba(55, 98, 145, 0.06) 55%,
      transparent 80%);
    transform: scale(4.6, 0.20) rotate(3deg);
    animation-duration: 30s;
    opacity: 0.85;
  }
  html[data-theme='light'] body:has(.sandbox-main) .glow-orb-3 {
    /* Low sun-gilded cloud edge — warm amber tint from light below horizon.
     * Positioned low on screen, warm, slow breathing. */
    background: radial-gradient(ellipse,
      rgba(235, 185, 100, 0.20) 0%,
      rgba(210, 155, 65, 0.06) 50%,
      transparent 78%);
    transform: scale(3.0, 0.30) rotate(-9deg);
    animation-duration: 20s;
    opacity: 0.85;
  }

  /* ── 3. NEW CLOUD DEPTH LAYERS — sandbox-only fixed elements ───────────── */
  .sb-clouds {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    /* Only show in light mode — dark mode has stars for depth */
    display: none;
  }
  html[data-theme='light'] body:has(.sandbox-main) .sb-clouds { display: block; }

  .sb-cloud {
    position: absolute;
    border-radius: 50%;
    mix-blend-mode: multiply;
  }

  /* Cirrus — very high, very thin ice clouds. Hairline streaks almost lost
   * in the deep blue zenith. Drift fastest (wind is strong up high). */
  .sb-cloud-cirrus {
    top: 5%;
    left: 5%;
    width: 800px;
    height: 800px;
    /* Blue-white, slightly cooler than sky so they read as ice-crystal wisps */
    background: radial-gradient(ellipse,
      rgba(195, 220, 240, 0.22) 0%,
      rgba(175, 208, 230, 0.06) 45%,
      transparent 72%);
    transform: scale(6.0, 0.06) rotate(-2deg);
    animation: sbCloudCirrus 55s ease-in-out infinite;
  }
  @keyframes sbCloudCirrus {
    0%, 100% { transform: scale(6.0, 0.06) rotate(-2deg) translate(0px, 0px); }
    33%       { transform: scale(6.0, 0.06) rotate(-1.5deg) translate(70px, 5px); }
    66%       { transform: scale(6.0, 0.06) rotate(-2.5deg) translate(-35px, 10px); }
  }

  /* Near cumulus — the WHITE PUFFY clouds of the pexels center reference.
   * Close = large apparent size, thick, BRIGHT (lit by sun), slowest angular speed.
   * Positioned lower-right as if floating past. Cloud-white with blue shadow. */
  .sb-cloud-cumulus {
    bottom: 20%;
    right: 5%;
    width: 550px;
    height: 550px;
    /* Bright cloud-white top, blue-grey shadow underneath — layered radials */
    background:
      radial-gradient(ellipse 60% 40% at 40% 30%,
        rgba(238, 248, 255, 0.80) 0%,
        rgba(215, 238, 250, 0.45) 45%,
        transparent 70%),
      radial-gradient(ellipse 80% 60% at 50% 65%,
        rgba(165, 200, 225, 0.40) 0%,
        rgba(140, 180, 210, 0.12) 50%,
        transparent 75%);
    transform: scale(2.0, 0.50) rotate(4deg);
    animation: sbCloudCumulus 20s ease-in-out infinite;
  }
  @keyframes sbCloudCumulus {
    0%, 100% { transform: scale(2.0, 0.50) rotate(4deg) translate(0px, 0px); }
    50%       { transform: scale(2.0, 0.50) rotate(3.5deg) translate(-20px, 8px); }
  }

  /* Horizon haze — warm atmospheric scatter where sun is low.
   * The golden warmth that bleeds up from below the horizon line. */
  .sb-cloud-haze {
    bottom: 0;
    left: 0;
    right: 0;
    width: 100%;
    height: 380px;
    border-radius: 0;
    background:
      radial-gradient(
        ellipse 70% 100% at 75% 100%,
        rgba(255, 195, 100, 0.28) 0%,
        rgba(240, 160, 60, 0.10) 40%,
        transparent 68%
      ),
      radial-gradient(
        ellipse 100% 60% at 50% 100%,
        rgba(255, 220, 160, 0.14) 0%,
        transparent 60%
      );
    animation: sbCloudHaze 45s ease-in-out infinite;
  }
  @keyframes sbCloudHaze {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.75; }
  }

  /* ── 4. STARFIELD — repurpose as tiny far-away birds/particles ──────────
   * In dark mode = stars. In light sky = tiny distant specks of life. */
  html[data-theme='light'] body:has(.sandbox-main) .starfield {
    opacity: 0.25;  /* subtle — depth, not distraction */
  }

  /* ── 5. SKY HORIZON — transition overlay + idle state ───────────────── */
  html[data-theme='light'] body:has(.sandbox-main) .sky-horizon {
    /* Warm sun coming through overcast from lower-right.
     * Blue wash from upper-left as counterpoint. */
    background:
      radial-gradient(
        ellipse 50% 60% at 100% 100%,
        rgba(255, 195, 110, 0.28) 0%,
        rgba(240, 165, 70, 0.10) 45%,
        transparent 70%
      ),
      radial-gradient(
        ellipse 80% 40% at 0% 0%,
        rgba(80, 130, 190, 0.12) 0%,
        rgba(60, 110, 170, 0.04) 55%,
        transparent 80%
      );
  }

  /* ── 6. SOMA TITLE — backlit / sun-behind effect ─────────────────────
   * Curtis: "Soma title shadow is now on the front of it (sun behind)."
   * The title is a SILHOUETTE — dark against bright sky. The sun is
   * BEHIND it, so:
   *   — warm halo radiates OUTWARD from behind the letters (above)
   *   — hard shadow falls FORWARD / below (toward the viewer)
   * Result reads as contre-jour / backlit photography. */
  html[data-theme='light'] body:has(.sandbox-main) .sandbox-hero h1 {
    /* Dark silhouette — contre-jour against bright sky.
     * Rich dark navy so the letter shapes read clearly against the blue. */
    background: linear-gradient(
      175deg,
      #142a4e 0%,   /* slightly lighter top (catching rim glow) */
      #0a1c38 100%  /* deep base silhouette */
    ) !important;
    /* Sun-behind effect — WARM halo radiates from behind/above the letters,
     * forward shadow is SOFT (not hard box) so letters stay legible. */
    filter:
      drop-shadow(0 -10px 28px rgba(255, 210, 110, 0.65))   /* primary sun halo above */
      drop-shadow(0 -4px 14px rgba(255, 230, 155, 0.40))    /* secondary warm rim */
      drop-shadow(0 7px 14px rgba(6, 16, 40, 0.38));        /* soft forward shadow */
  }

  /* Nav sigma in light sky — deep blue silhouette + sun halo */
  html[data-theme='light'] body:has(.sandbox-main) .nav-sigma {
    color: #0d2040;
    text-shadow:
      0 -4px 14px rgba(255, 215, 130, 0.55),
      0 4px 8px rgba(6, 18, 45, 0.40);
  }
  html[data-theme='light'] body:has(.sandbox-main) .nav-brand:hover .nav-sigma {
    color: #0a1832;
    text-shadow:
      0 -5px 18px rgba(255, 220, 140, 0.70),
      0 4px 10px rgba(6, 18, 45, 0.45);
  }
</style>

<style>
  .sandbox-main {
    max-width: 980px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
    position: relative;
    z-index: 2;
  }

  .sandbox-hero {
    margin-bottom: 4rem;
  }

  .sandbox-hero h1 {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.025em;
    background: linear-gradient(135deg, var(--hero-title-start), var(--hero-title-end));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1.25rem;
  }

  .sandbox-lead {
    font-size: 1.25rem;
    color: var(--ink-soft);
    max-width: 600px;
    line-height: 1.6;
  }

  .sandbox-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .sandbox-card {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem;
    backdrop-filter: blur(8px);
    box-shadow: 0 4px 20px var(--shadow-accent-soft);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .sandbox-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px var(--shadow-accent-mid);
  }

  .sandbox-card-elevated {
    background: var(--surface-card-strong);
    box-shadow: 0 8px 32px var(--shadow-accent-mid);
  }

  .sandbox-card h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 0.75rem;
  }

  .sandbox-card p {
    color: var(--ink-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .sandbox-card code,
  .sandbox-code-inline {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--surface-interactive);
    color: var(--accent);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .sandbox-card a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .sandbox-card a:hover {
    color: var(--moon-bright);
  }

  .sandbox-btn {
    margin-top: 0.5rem;
    background: var(--accent);
    color: white;
    border: none;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    font-family: var(--font-body);
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.1s ease;
  }
  .sandbox-btn:hover {
    background: var(--moon-bright);
  }

  .sandbox-code-block {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.6;
    margin-top: 0.75rem;
  }

  .sandbox-tones {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    backdrop-filter: blur(6px);
  }

  .sandbox-tones h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  .sandbox-swatches {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 0.5rem;
  }

  .swatch {
    height: 80px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-soft);
    border: 1px solid var(--border);
  }
</style>
