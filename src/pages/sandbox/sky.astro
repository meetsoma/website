---
/**
 * /sandbox/sky — design iteration sandbox for the light theme.
 *
 * Cycle 17 (s01-7b287c). Curtis: "we'd have to get it right first tho on a
 * test page" before adopting Tincture sitewide. This page renders the
 * full atmospheric stack (Starfield + Sky + glow-orbs + nav + content
 * blocks) but with EXPERIMENTAL palette overrides scoped to this route.
 *
 * Iterate the palette here. When the look is locked, copy the winning
 * --token values into src/layouts/Layout.astro (or migrate the whole
 * stack to Tincture per personal/tincture-css/tincture.skill.md).
 *
 * NOT for users — sitemap-excluded, robots-noindex.
 */
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Sandbox · Sky · σ"
  description="Design iteration sandbox — light theme palette tuning."
  path="/sandbox/sky"
>
  <!-- Extra cloud depth layers — sandbox only. The 3 glow-orbs from Layout
       handle mid-altitude. These add the near + far extremes. -->
  <div class="sb-clouds" aria-hidden="true">
    <!-- Cirrus — very high, hairline thin, barely there -->
    <div class="sb-cloud sb-cloud-cirrus"></div>
    <!-- Near cumulus — low, chunkier, moves slower visually -->
    <div class="sb-cloud sb-cloud-cumulus"></div>
    <!-- Horizon haze — diffuse warm band where sun leaks through -->
    <div class="sb-cloud sb-cloud-haze"></div>
  </div>

  <main class="sandbox-main">
    <!-- Mood switcher -->
    <div class="mood-row" id="mood-row">
      <button class="mood-btn active" data-mood="dawn-dusk">Dawn / Dusk</button>
      <button class="mood-btn" data-mood="day">Day</button>
    </div>

    <header class="sandbox-hero">
      <h1 id="sandbox-title">cloud cover at dawn</h1>
      <p class="sandbox-lead">
        A sky that breathes. Pale blue overcast with thin wisps of cirrus,
        a sun just out of frame casting warmth from one side. Toggle theme
        in the nav to see the time-lapse.
      </p>
    </header>

    <section class="sandbox-grid">
      <article class="sandbox-card">
        <h2>Card on cloud-white</h2>
        <p>Body text against a pale sky. Should read crisply but feel soft.</p>
        <p>Inline <code>code</code> token, <a href="#">a link</a>, and a button.</p>
        <button class="sandbox-btn">Action</button>
      </article>

      <article class="sandbox-card sandbox-card-elevated">
        <h2>Elevated card</h2>
        <p>Subtly raised — slightly more saturated background, soft shadow.</p>
        <code class="sandbox-code-inline">soma:body.audit</code>
      </article>

      <article class="sandbox-card">
        <h2>Code block</h2>
        <pre class="sandbox-code-block"><code>{`async function dawnBreaks(theme) {
  const sky = await getSky();
  return sky.transition(theme, {
    stars: 'buzz',
    horizon: 'sweep',
    sun: 'spin-in'
  });
}`}</code></pre>
      </article>
    </section>

    <section class="sandbox-tones">
      <h2>Tone scale</h2>
      <div class="sandbox-swatches">
        <div class="swatch" style="background: var(--bg)">bg-deep</div>
        <div class="swatch" style="background: var(--bg-card)">bg-surface</div>
        <div class="swatch" style="background: var(--bg-elev)">bg-elevated</div>
        <div class="swatch" style="background: var(--accent); color: white">accent</div>
        <div class="swatch" style="background: var(--moon-bright); color: white">moon</div>
        <div class="swatch" style="background: var(--warm-bright); color: white">warm</div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  /* ==========================================================================
   * SANDBOX SKY — iter 3 (s01-b73653)
   * Curtis: "needs to feel like it has depth — light mode is lacking that,
   * the blue feel of a sky, some clouds close others farther, slightly moving."
   * + "Soma title shadow is now on the front of it (sun behind)."
   *
   * Architecture:
   *   body gradient  — zenith deep blue → pale diffuse horizon
   *   .glow-orb-1/2  — mid-altitude altostratus layers (tuned from Layout)
   *   .glow-orb-3    — low warm wisp / sunlit cloud edge
   *   .sb-cloud-cirrus  — high cirrus, hairline, barely there, fast drift
   *   .sb-cloud-cumulus — near low cumulus, thicker, slowest angular speed
   *   .sb-cloud-haze    — horizon warm band (sun leaking through overcast)
   * ==========================================================================*/

  /* ── SKY GLOW ORBS — mid-altitude cloud layers ───────────────────
   * Repurposed from Layout's circular nebula orbs into horizontal cloud streaks.
   * orb-1 = altostratus (mid-high)  orb-2 = stratus (mid)  orb-3 = sunlit edge */
  html[data-theme='light'] body:has(.sandbox-main) .glow-orbs {
    opacity: 1;
  }
  html[data-theme='light'] body:has(.sandbox-main) .glow-orb {
    mix-blend-mode: multiply;
  }
  html[data-theme='light'] body:has(.sandbox-main) .glow-orb-1 {
    /* Upper cloud band — still blue, mid-high altitude. */
    background: radial-gradient(ellipse,
      var(--sky-cloud-high) 0%,
      rgba(50, 90, 138, 0.06) 52%,
      transparent 78%);
    transform: scale(4.2, 0.15) rotate(-4deg);
    animation-duration: 44s;
    opacity: 0.9;
  }
  html[data-theme='light'] body:has(.sandbox-main) .glow-orb-2 {
    /* Mid cloud band — beginning to pick up warm tones from below. */
    background: radial-gradient(ellipse,
      var(--sky-cloud-mid) 0%,
      rgba(90, 55, 35, 0.06) 52%,
      transparent 80%);
    transform: scale(4.5, 0.22) rotate(4deg);
    animation-duration: 32s;
    opacity: 0.88;
  }
  html[data-theme='light'] body:has(.sandbox-main) .glow-orb-3 {
    /* Low cloud — fully lit by sunset. Orange-red undersides like the reference.
     * Positioned at ~bottom third of screen. */
    background: radial-gradient(ellipse,
      var(--sky-cloud-low) 0%,
      rgba(90, 30, 10, 0.10) 45%,
      transparent 72%);
    transform: scale(3.2, 0.35) rotate(-8deg);
    animation-duration: 22s;
    opacity: 0.90;
  }

  /* ── 3. NEW CLOUD DEPTH LAYERS — sandbox-only fixed elements ───────────── */
  .sb-clouds {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    /* Only show in light mode — dark mode has stars for depth */
    display: none;
  }
  html[data-theme='light'] body:has(.sandbox-main) .sb-clouds { display: block; }

  .sb-cloud {
    position: absolute;
    border-radius: 50%;
    mix-blend-mode: multiply;
  }

  /* Cirrus — very high, very thin ice clouds. Hairline streaks almost lost
   * in the deep blue zenith. Drift fastest (wind is strong up high). */
  .sb-cloud-cirrus {
    top: 5%;
    left: 5%;
    width: 800px;
    height: 800px;
    /* Blue-white, slightly cooler than sky so they read as ice-crystal wisps */
    background: radial-gradient(ellipse,
      rgba(195, 220, 240, 0.22) 0%,
      rgba(175, 208, 230, 0.06) 45%,
      transparent 72%);
    transform: scale(6.0, 0.06) rotate(-2deg);
    animation: sbCloudCirrus 55s ease-in-out infinite;
  }
  @keyframes sbCloudCirrus {
    0%, 100% { transform: scale(6.0, 0.06) rotate(-2deg) translate(0px, 0px); }
    33%       { transform: scale(6.0, 0.06) rotate(-1.5deg) translate(70px, 5px); }
    66%       { transform: scale(6.0, 0.06) rotate(-2.5deg) translate(-35px, 10px); }
  }

  /* Near cumulus — lit from below by sunset. Cloud bodies dark-blue/purple on
   * top (shadow side, away from sun), vivid orange-red on undersides.
   * Like the reference: the cloud tops are silhouettes, bottoms are fire. */
  .sb-cloud-cumulus {
    bottom: 15%;
    right: 5%;
    width: 600px;
    height: 600px;
    background:
      /* Lit underside — vivid orange-red like the reference photo */
      radial-gradient(ellipse 70% 40% at 50% 75%,
        rgba(210, 65, 22, 0.60) 0%,
        rgba(180, 48, 16, 0.28) 40%,
        transparent 68%),
      /* Shadow top — deep blue-grey like the cloud bodies in the ref */
      radial-gradient(ellipse 80% 50% at 45% 30%,
        rgba(42, 55, 80, 0.50) 0%,
        rgba(30, 42, 65, 0.18) 45%,
        transparent 70%);
    transform: scale(2.2, 0.55) rotate(4deg);
    animation: sbCloudCumulus 22s ease-in-out infinite;
  }
  @keyframes sbCloudCumulus {
    0%, 100% { transform: scale(2.2, 0.55) rotate(4deg) translate(0px, 0px); }
    50%       { transform: scale(2.2, 0.55) rotate(3.5deg) translate(-22px, 8px); }
  }

  /* Horizon ember — the deep red-orange glow at the very bottom where
   * the sun just set. Radiates upward, most intense at the edges. */
  .sb-cloud-haze {
    bottom: 0;
    left: 0;
    right: 0;
    width: 100%;
    height: 420px;
    border-radius: 0;
    background:
      /* Central deep red glow */
      radial-gradient(
        ellipse 80% 100% at 50% 100%,
        rgba(175, 40, 14, 0.55) 0%,
        rgba(145, 28, 10, 0.25) 30%,
        rgba(100, 20, 8, 0.08) 55%,
        transparent 72%
      ),
      /* Right-side warmth — sun setting to the right */
      radial-gradient(
        ellipse 50% 80% at 90% 100%,
        rgba(200, 55, 18, 0.45) 0%,
        rgba(165, 38, 12, 0.15) 45%,
        transparent 70%
      );
    animation: sbCloudHaze 38s ease-in-out infinite;
  }
  @keyframes sbCloudHaze {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.80; }
  }

  /* ── 4. STARFIELD — repurpose as tiny far-away birds/particles ──────────
   * In dark mode = stars. In light sky = tiny distant specks of life. */
  html[data-theme='light'] body:has(.sandbox-main) .starfield {
    opacity: 0.25;  /* subtle — depth, not distraction */
  }

  /* ── 5. SKY HORIZON — transition overlay + idle state ───────────────── */
  html[data-theme='light'] body:has(.sandbox-main) .sky-horizon {
    /* Sunset ember radiating up from below — matches the body gradient. */
    background:
      radial-gradient(
        ellipse 80% 80% at 50% 110%,
        rgba(180, 45, 15, 0.45) 0%,
        rgba(140, 30, 10, 0.18) 35%,
        transparent 62%
      ),
      radial-gradient(
        ellipse 50% 60% at 92% 105%,
        rgba(200, 60, 20, 0.35) 0%,
        rgba(165, 42, 14, 0.10) 40%,
        transparent 68%
      );
  }

  /* ── 6. SOMA TITLE — backlit / sun-behind effect ─────────────────────
   * Curtis: "Soma title shadow is now on the front of it (sun behind)."
   * The title is a SILHOUETTE — dark against bright sky. The sun is
   * BEHIND it, so:
   *   — warm halo radiates OUTWARD from behind the letters (above)
   *   — hard shadow falls FORWARD / below (toward the viewer)
   * Result reads as contre-jour / backlit photography. */
  html[data-theme='light'] body:has(.sandbox-main) .sandbox-hero h1 {
    /* IMPORTANT: filter: + background-clip:text breaks in Chrome (compositing
     * layer conflict). Use text-shadow + solid fill instead.
     * Dark navy silhouette against the bright sky. */
    background: none !important;
    -webkit-background-clip: unset !important;
    background-clip: unset !important;
    -webkit-text-fill-color: #0f2040 !important;   /* dark navy — the silhouette */
    color: #0f2040 !important;
    /* Sun-behind: warm halo ABOVE (sun radiating from behind),
     * soft shadow BELOW (falling toward the viewer / ground). */
    text-shadow:
      0 -12px 32px rgba(255, 205, 100, 0.80),   /* primary warm halo above */
      0 -5px 16px rgba(255, 230, 150, 0.55),    /* secondary golden rim */
      0 8px 18px rgba(5, 14, 38, 0.42);         /* forward cast — toward viewer */
    filter: none;
  }

  /* Nav sigma — deep blue silhouette against the blue-top sky */
  html[data-theme='light'] body:has(.sandbox-main) .nav-sigma {
    color: #0a1e3a;
    text-shadow:
      0 -3px 12px rgba(210, 65, 22, 0.35),
      0 3px 8px rgba(5, 12, 30, 0.45);
  }
  html[data-theme='light'] body:has(.sandbox-main) .nav-brand:hover .nav-sigma {
    color: #081628;
    text-shadow:
      0 -4px 16px rgba(210, 65, 22, 0.55),
      0 3px 10px rgba(5, 12, 30, 0.50);
  }

  /* Sun disk repositioned — lower, redder, closer to the horizon (setting sun) */
  html[data-theme='light'] body:has(.sandbox-main) .sky-sun {
    background: radial-gradient(
      circle at 40% 40%,
      rgba(255, 220, 150, 0.95) 0%,
      rgba(230, 120, 50, 0.85) 40%,
      rgba(200, 65, 20, 0.35) 70%,
      transparent 100%
    );
    box-shadow:
      0 0 60px rgba(210, 80, 25, 0.50),
      0 0 130px rgba(180, 55, 18, 0.28),
      0 0 260px rgba(160, 40, 14, 0.12);
  }
</style>

<script>
  // Mood switcher — updates data-mood on <html> and localStorage
  function initMoodSwitcher() {
    const btns = document.querySelectorAll('.mood-btn');
    const title = document.getElementById('sandbox-title');
    const TITLES: Record<string, string> = {
      'dawn-dusk': 'cloud cover at dawn',
      'day':       'clear day',
    };
    function setMood(mood: string) {
      document.documentElement.dataset.mood = mood;
      localStorage.setItem('soma-sky-mood', mood);
      btns.forEach(b => (b as HTMLElement).classList.toggle('active', (b as HTMLElement).dataset.mood === mood));
      if (title) title.textContent = TITLES[mood] || mood;
    }
    btns.forEach(btn => {
      (btn as HTMLElement).addEventListener('click', () => setMood((btn as HTMLElement).dataset.mood || 'dawn-dusk'));
    });
    // Sync to current state
    const current = document.documentElement.dataset.mood || 'dawn-dusk';
    setMood(current);
  }
  initMoodSwitcher();
  document.addEventListener('astro:page-load', initMoodSwitcher);
</script>

<style>
  /* Mood switcher */
  .mood-row {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    position: relative;
    z-index: 2;
  }
  .mood-btn {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--border-accent);
    background: var(--surface-card);
    color: var(--ink-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .mood-btn.active {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }
  .mood-btn:hover:not(.active) {
    color: var(--ink);
    border-color: var(--accent);
  }

  .sandbox-main {
    max-width: 980px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
    position: relative;
    z-index: 2;
  }

  .sandbox-hero {
    margin-bottom: 4rem;
  }

  .sandbox-hero h1 {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.025em;
    background: linear-gradient(135deg, var(--hero-title-start), var(--hero-title-end));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1.25rem;
  }

  .sandbox-lead {
    font-size: 1.25rem;
    color: var(--ink-soft);
    max-width: 600px;
    line-height: 1.6;
  }

  .sandbox-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .sandbox-card {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem;
    backdrop-filter: blur(8px);
    box-shadow: 0 4px 20px var(--shadow-accent-soft);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .sandbox-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px var(--shadow-accent-mid);
  }

  .sandbox-card-elevated {
    background: var(--surface-card-strong);
    box-shadow: 0 8px 32px var(--shadow-accent-mid);
  }

  .sandbox-card h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 0.75rem;
  }

  .sandbox-card p {
    color: var(--ink-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .sandbox-card code,
  .sandbox-code-inline {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--surface-interactive);
    color: var(--accent);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .sandbox-card a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .sandbox-card a:hover {
    color: var(--moon-bright);
  }

  .sandbox-btn {
    margin-top: 0.5rem;
    background: var(--accent);
    color: white;
    border: none;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    font-family: var(--font-body);
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.1s ease;
  }
  .sandbox-btn:hover {
    background: var(--moon-bright);
  }

  .sandbox-code-block {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.6;
    margin-top: 0.75rem;
  }

  .sandbox-tones {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    backdrop-filter: blur(6px);
  }

  .sandbox-tones h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  .sandbox-swatches {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 0.5rem;
  }

  .swatch {
    height: 80px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-soft);
    border: 1px solid var(--border);
  }
</style>
