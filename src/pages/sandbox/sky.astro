---
/**
 * /sandbox/sky — design iteration sandbox for the light theme.
 *
 * Cycle 17 (s01-7b287c). Curtis: "we'd have to get it right first tho on a
 * test page" before adopting Tincture sitewide. This page renders the
 * full atmospheric stack (Starfield + Sky + glow-orbs + nav + content
 * blocks) but with EXPERIMENTAL palette overrides scoped to this route.
 *
 * Iterate the palette here. When the look is locked, copy the winning
 * --token values into src/layouts/Layout.astro (or migrate the whole
 * stack to Tincture per personal/tincture-css/tincture.skill.md).
 *
 * NOT for users — sitemap-excluded, robots-noindex.
 */
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Sandbox · Sky · σ"
  description="Design iteration sandbox — light theme palette tuning."
  path="/sandbox/sky"
>
  <!-- Extra cloud depth layers — sandbox only. The 3 glow-orbs from Layout
       handle mid-altitude. These add the near + far extremes. -->
  <div class="sb-clouds" aria-hidden="true">
    <!-- Cirrus — very high, hairline thin, barely there -->
    <div class="sb-cloud sb-cloud-cirrus"></div>
    <!-- Near cumulus — low, chunkier, moves slower visually -->
    <div class="sb-cloud sb-cloud-cumulus"></div>
    <!-- Horizon haze — diffuse warm band where sun leaks through -->
    <div class="sb-cloud sb-cloud-haze"></div>
  </div>

  <main class="sandbox-main">
    <header class="sandbox-hero">
      <h1>cloud cover at dawn</h1>
      <p class="sandbox-lead">
        A sky that breathes. Pale blue overcast with thin wisps of cirrus,
        a sun just out of frame casting warmth from one side. Toggle theme
        in the nav to see the time-lapse.
      </p>
    </header>

    <section class="sandbox-grid">
      <article class="sandbox-card">
        <h2>Card on cloud-white</h2>
        <p>Body text against a pale sky. Should read crisply but feel soft.</p>
        <p>Inline <code>code</code> token, <a href="#">a link</a>, and a button.</p>
        <button class="sandbox-btn">Action</button>
      </article>

      <article class="sandbox-card sandbox-card-elevated">
        <h2>Elevated card</h2>
        <p>Subtly raised — slightly more saturated background, soft shadow.</p>
        <code class="sandbox-code-inline">soma:body.audit</code>
      </article>

      <article class="sandbox-card">
        <h2>Code block</h2>
        <pre class="sandbox-code-block"><code>{`async function dawnBreaks(theme) {
  const sky = await getSky();
  return sky.transition(theme, {
    stars: 'buzz',
    horizon: 'sweep',
    sun: 'spin-in'
  });
}`}</code></pre>
      </article>
    </section>

    <section class="sandbox-tones">
      <h2>Tone scale</h2>
      <div class="sandbox-swatches">
        <div class="swatch" style="background: var(--bg)">bg-deep</div>
        <div class="swatch" style="background: var(--bg-card)">bg-surface</div>
        <div class="swatch" style="background: var(--bg-elev)">bg-elevated</div>
        <div class="swatch" style="background: var(--accent); color: white">accent</div>
        <div class="swatch" style="background: var(--moon-bright); color: white">moon</div>
        <div class="swatch" style="background: var(--warm-bright); color: white">warm</div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  /* ==========================================================================
   * SANDBOX SKY — iter 3 (s01-b73653)
   * Curtis: "needs to feel like it has depth — light mode is lacking that,
   * the blue feel of a sky, some clouds close others farther, slightly moving."
   * + "Soma title shadow is now on the front of it (sun behind)."
   *
   * Architecture:
   *   body gradient  — zenith deep blue → pale diffuse horizon
   *   .glow-orb-1/2  — mid-altitude altostratus layers (tuned from Layout)
   *   .glow-orb-3    — low warm wisp / sunlit cloud edge
   *   .sb-cloud-cirrus  — high cirrus, hairline, barely there, fast drift
   *   .sb-cloud-cumulus — near low cumulus, thicker, slowest angular speed
   *   .sb-cloud-haze    — horizon warm band (sun leaking through overcast)
   * ==========================================================================*/

  /* ── 1. SKY GRADIENT — real zenith→horizon gradient ──────────────────────
   * Overcast dawn: blue comes through cloud layer diffused — saturated but
   * not blazing. Warm amber bleeds in from bottom-right (sun below horizon). */
  html[data-theme='light'] body:has(.sandbox-main) {
    background: none !important;
  }
  html[data-theme='light'] body:has(.sandbox-main)::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: -1;
    background:
      /* Warm sun leak — bottom-right corner, faint */
      radial-gradient(
        ellipse 60% 50% at 105% 110%,
        rgba(255, 210, 140, 0.35) 0%,
        rgba(220, 170, 90, 0.12) 40%,
        transparent 70%
      ),
      /* Sky gradient: zenith blue → pale horizon */
      linear-gradient(
        to bottom,
        #4e85b5 0%,      /* zenith — proper overcast sky blue */
        #6fa3c8 18%,     /* upper sky */
        #95bfd8 38%,     /* mid sky, diffused through cloud layer */
        #bdd7e9 58%,     /* lower mid, getting milky */
        #d8ecf5 78%,     /* near horizon, very pale */
        #e8f4f9 100%     /* horizon, almost white */
      );
  }

  /* Card/surface tokens for this palette */
  html[data-theme='light'] body:has(.sandbox-main) {
    /* Tincture token overrides for this sky palette */
    --bg:      #a8c9dd;   /* sky mid — tincture --bg alias */
    --bg-card: #e8f3fa;   /* cloud white — cards */
    --bg-elev: #d0e5f0;   /* cloud shadow — elevated */
    --ink:          #091829;
    --ink-soft:     #1e3a56;
    --ink-muted:    #3a5872;
    --accent:       #1e5f9e;
    --border:       rgba(9, 24, 41, 0.12);
    --border-accent: rgba(30, 95, 158, 0.35);
    --shadow-accent: rgba(30, 95, 158, 0.18);
    --shadow-card:  0 2px 8px rgba(9,24,41,0.10), 0 6px 20px rgba(9,24,41,0.07);

    /* Legacy aliases */
    --accent-bright: var(--accent);
    --border-subtle: var(--border);
    --shadow-accent-soft: var(--shadow-accent);
    --shadow-accent-mid: rgba(30, 95, 158, 0.28);
    --moon-bright:  #3878a8;
    --moon-glow:    rgba(30, 95, 158, 0.25);
    --warm-bright:  #b06030;
    --logo-glow:    rgba(30, 95, 158, 0.22);
    --logo-glow-hover: rgba(30, 95, 158, 0.38);

    /* Surface overrides for glass-card feel against the sky bg */
    --surface-card:              rgba(235, 248, 255, 0.88);
    --surface-card-strong:       rgba(242, 251, 255, 0.96);
    --surface-interactive:       rgba(9, 24, 41, 0.06);
    --surface-interactive-hover: rgba(9, 24, 41, 0.11);
    --surface-accent-soft:       rgba(30, 95, 158, 0.09);
  }

  /* ── 2. EXISTING GLOW ORBS — mid-altitude cloud layers ───────────────────
   * Repurposed from Layout's circular nebula orbs into horizontal cloud streaks.
   * orb-1 = altostratus (mid-high)  orb-2 = stratus (mid)  orb-3 = sunlit edge */
  html[data-theme='light'] body:has(.sandbox-main) .glow-orbs {
    opacity: 1;  /* full — depth is tuned per-orb */
  }
  html[data-theme='light'] body:has(.sandbox-main) .glow-orb {
    mix-blend-mode: multiply;
  }
  html[data-theme='light'] body:has(.sandbox-main) .glow-orb-1 {
    /* Altostratus — mid-high altitude. Wide blue-grey band, slow drift. */
    background: radial-gradient(ellipse, rgba(100, 148, 190, 0.22) 0%, rgba(80, 130, 175, 0.06) 55%, transparent 80%);
    transform: scale(3.8, 0.18) rotate(-4deg);
    animation-duration: 38s;
    opacity: 0.9;
  }
  html[data-theme='light'] body:has(.sandbox-main) .glow-orb-2 {
    /* Stratus — mid altitude, slightly lower, wider + fatter streak. */
    background: radial-gradient(ellipse, rgba(80, 130, 175, 0.18) 0%, rgba(60, 110, 160, 0.04) 60%, transparent 82%);
    transform: scale(4.2, 0.22) rotate(3deg);
    animation-duration: 28s;
    opacity: 0.85;
  }
  html[data-theme='light'] body:has(.sandbox-main) .glow-orb-3 {
    /* Sunlit cloud edge — warm tint where sun light bleeds through. */
    background: radial-gradient(ellipse, rgba(220, 165, 90, 0.14) 0%, rgba(200, 145, 70, 0.04) 55%, transparent 80%);
    transform: scale(2.8, 0.26) rotate(-10deg);
    animation-duration: 22s;
    opacity: 0.8;
  }

  /* ── 3. NEW CLOUD DEPTH LAYERS — sandbox-only fixed elements ───────────── */
  .sb-clouds {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    /* Only show in light mode — dark mode has stars for depth */
    display: none;
  }
  html[data-theme='light'] body:has(.sandbox-main) .sb-clouds { display: block; }

  .sb-cloud {
    position: absolute;
    border-radius: 50%;
    mix-blend-mode: multiply;
  }

  /* Cirrus — very high altitude. Hairline thin, barely visible.
   * Fastest angular drift because smallest scale = most responsive to wind.
   * Tinted very pale blue-grey. */
  .sb-cloud-cirrus {
    top: 8%;
    left: 15%;
    width: 700px;
    height: 700px;
    background: radial-gradient(ellipse, rgba(160, 195, 220, 0.18) 0%, rgba(140, 180, 210, 0.04) 50%, transparent 75%);
    transform: scale(5.5, 0.07) rotate(-2deg);
    animation: sbCloudCirrus 52s ease-in-out infinite;
  }
  @keyframes sbCloudCirrus {
    0%, 100% { transform: scale(5.5, 0.07) rotate(-2deg) translate(0, 0); }
    33%       { transform: scale(5.5, 0.07) rotate(-1.5deg) translate(60px, 4px); }
    66%       { transform: scale(5.5, 0.07) rotate(-2.5deg) translate(-30px, 8px); }
  }

  /* Near cumulus — lowest altitude, closest to viewer.
   * THICKER (high scaleY), more opaque, but moves SLOWEST (low angular speed
   * for close objects). Positioned low on screen where low clouds would appear. */
  .sb-cloud-cumulus {
    bottom: 25%;
    right: 10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(220, 238, 248, 0.55) 0%, rgba(200, 225, 240, 0.20) 40%, transparent 70%);
    transform: scale(2.2, 0.45) rotate(5deg);
    animation: sbCloudCumulus 18s ease-in-out infinite;
  }
  @keyframes sbCloudCumulus {
    0%, 100% { transform: scale(2.2, 0.45) rotate(5deg) translate(0, 0); }
    50%       { transform: scale(2.2, 0.45) rotate(4.5deg) translate(-18px, 6px); }
  }

  /* Horizon haze — warm diffuse band at the bottom where sun leaks through.
   * Not a cloud — atmospheric scattering at low angle. Static-ish. */
  .sb-cloud-haze {
    bottom: 0;
    left: 0;
    right: 0;
    width: 100%;
    height: 400px;
    border-radius: 0;
    background: radial-gradient(
      ellipse 80% 100% at 70% 100%,
      rgba(255, 200, 120, 0.22) 0%,
      rgba(240, 170, 80, 0.08) 35%,
      transparent 65%
    );
    animation: sbCloudHaze 40s ease-in-out infinite;
  }
  @keyframes sbCloudHaze {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.7; }
  }

  /* ── 4. STARFIELD — repurpose as tiny far-away birds/particles ──────────
   * In dark mode = stars. In light sky = tiny distant specks of life. */
  html[data-theme='light'] body:has(.sandbox-main) .starfield {
    opacity: 0.25;  /* subtle — depth, not distraction */
  }

  /* ── 5. SKY HORIZON — transition overlay + idle state ───────────────── */
  html[data-theme='light'] body:has(.sandbox-main) .sky-horizon {
    /* Warm sun coming through overcast from lower-right.
     * Blue wash from upper-left as counterpoint. */
    background:
      radial-gradient(
        ellipse 50% 60% at 100% 100%,
        rgba(255, 195, 110, 0.28) 0%,
        rgba(240, 165, 70, 0.10) 45%,
        transparent 70%
      ),
      radial-gradient(
        ellipse 80% 40% at 0% 0%,
        rgba(80, 130, 190, 0.12) 0%,
        rgba(60, 110, 170, 0.04) 55%,
        transparent 80%
      );
  }

  /* ── 6. SOMA TITLE — backlit / sun-behind effect ─────────────────────
   * Curtis: "Soma title shadow is now on the front of it (sun behind)."
   * The title is a SILHOUETTE — dark against bright sky. The sun is
   * BEHIND it, so:
   *   — warm halo radiates OUTWARD from behind the letters (above)
   *   — hard shadow falls FORWARD / below (toward the viewer)
   * Result reads as contre-jour / backlit photography. */
  html[data-theme='light'] body:has(.sandbox-main) .sandbox-hero h1 {
    /* Dark silhouette gradient — deepest at base (shadow side),
     * slightly warm-dark at top (edge catching rim of sun glow) */
    background: linear-gradient(
      180deg,
      #0d2040 0%,   /* top — dark with the faintest warm cast */
      #091628 100%  /* base — deepest silhouette */
    ) !important;
    /* Sun-behind: warm halo above + forward shadow below.
     * drop-shadow works on the composited text (including background-clip). */
    filter:
      drop-shadow(0 -8px 24px rgba(255, 215, 130, 0.60))   /* warm sun halo behind/above */
      drop-shadow(0 -3px 10px rgba(255, 230, 160, 0.35))   /* secondary rim glow */
      drop-shadow(0 10px 20px rgba(6, 18, 45, 0.55));      /* hard shadow TOWARD viewer */
  }

  /* Nav sigma in light sky — deep blue silhouette + sun halo */
  html[data-theme='light'] body:has(.sandbox-main) .nav-sigma {
    color: #0d2040;
    text-shadow:
      0 -4px 14px rgba(255, 215, 130, 0.55),
      0 4px 8px rgba(6, 18, 45, 0.40);
  }
  html[data-theme='light'] body:has(.sandbox-main) .nav-brand:hover .nav-sigma {
    color: #0a1832;
    text-shadow:
      0 -5px 18px rgba(255, 220, 140, 0.70),
      0 4px 10px rgba(6, 18, 45, 0.45);
  }
</style>

<style>
  .sandbox-main {
    max-width: 980px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
    position: relative;
    z-index: 2;
  }

  .sandbox-hero {
    margin-bottom: 4rem;
  }

  .sandbox-hero h1 {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.025em;
    background: linear-gradient(135deg, var(--hero-title-start), var(--hero-title-end));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1.25rem;
  }

  .sandbox-lead {
    font-size: 1.25rem;
    color: var(--ink-soft);
    max-width: 600px;
    line-height: 1.6;
  }

  .sandbox-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .sandbox-card {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem;
    backdrop-filter: blur(8px);
    box-shadow: 0 4px 20px var(--shadow-accent-soft);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .sandbox-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px var(--shadow-accent-mid);
  }

  .sandbox-card-elevated {
    background: var(--surface-card-strong);
    box-shadow: 0 8px 32px var(--shadow-accent-mid);
  }

  .sandbox-card h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 0.75rem;
  }

  .sandbox-card p {
    color: var(--ink-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .sandbox-card code,
  .sandbox-code-inline {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--surface-interactive);
    color: var(--accent);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .sandbox-card a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .sandbox-card a:hover {
    color: var(--moon-bright);
  }

  .sandbox-btn {
    margin-top: 0.5rem;
    background: var(--accent);
    color: white;
    border: none;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    font-family: var(--font-body);
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.1s ease;
  }
  .sandbox-btn:hover {
    background: var(--moon-bright);
  }

  .sandbox-code-block {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.6;
    margin-top: 0.75rem;
  }

  .sandbox-tones {
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    backdrop-filter: blur(6px);
  }

  .sandbox-tones h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  .sandbox-swatches {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 0.5rem;
  }

  .swatch {
    height: 80px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-soft);
    border: 1px solid var(--border);
  }
</style>
