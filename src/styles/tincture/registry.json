{
  "version": "0.1.0",
  "name": "soma/tincture",
  "doc": "Token registry for soma.gravicity.ai. Deep-space dark / cloud-cover-at-dawn light. Two surfaces, one substrate.",
  "tokens": {
    "bg": {
      "kind": "color",
      "axes": ["surface"],
      "doc": "Page background. Deep space on dark, pale dawn sky on light.",
      "values": {
        "default":       "#0C0F16",
        "surface=light": "#e8eef5"
      }
    },
    "bg-card": {
      "kind": "color",
      "axes": ["surface"],
      "doc": "Card / panel surface. Slightly elevated from page bg.",
      "values": {
        "default":       "#0b1018",
        "surface=light": "#fafbfc"
      }
    },
    "bg-elev": {
      "kind": "color",
      "axes": ["surface"],
      "doc": "Elevated surface — modals, popovers, raised cards.",
      "values": {
        "default":       "#121a28",
        "surface=light": "#dde5f0"
      }
    },
    "ink": {
      "kind": "color",
      "axes": ["surface"],
      "doc": "Primary text. High contrast on both surfaces.",
      "values": {
        "default":       "#e4eaf4",
        "surface=light": "#0a0f1a"
      }
    },
    "ink-soft": {
      "kind": "color",
      "axes": ["surface"],
      "doc": "Secondary text. Body copy, descriptions.",
      "values": {
        "default":       "#9dafc4",
        "surface=light": "#2a3648"
      }
    },
    "ink-muted": {
      "kind": "color",
      "axes": ["surface"],
      "doc": "Tertiary text. Metadata, timestamps, captions.",
      "values": {
        "default":       "#647080",
        "surface=light": "#4a5a70"
      }
    },
    "accent": {
      "kind": "color",
      "axes": ["surface"],
      "doc": "Primary accent — soma blue. Canonical #7cb2d4 on dark, deeper on light for contrast.",
      "values": {
        "default":       "#7cb2d4",
        "surface=light": "#2e6094"
      }
    },
    "accent-fg": {
      "kind": "color",
      "axes": ["surface"],
      "doc": "Ink on accent surface.",
      "values": {
        "default":       "#0C0F16",
        "surface=light": "#ffffff"
      }
    },
    "accent-warm": {
      "kind": "color",
      "axes": ["surface"],
      "doc": "Warm signal accent — CTAs, highlights. Complements the blue accent.",
      "values": {
        "default":       "#e8a87c",
        "surface=light": "#a85a2a"
      }
    },
    "border": {
      "kind": "color",
      "axes": ["surface"],
      "doc": "Default border. Low alpha ink tint on both surfaces.",
      "values": {
        "default":       "rgba(132, 148, 170, 0.12)",
        "surface=light": "rgba(10, 15, 26, 0.18)"
      }
    },
    "border-accent": {
      "kind": "color",
      "axes": ["surface"],
      "doc": "Accent-tinted border. Used on interactive cards, focused inputs.",
      "values": {
        "default":       "rgba(104, 152, 190, 0.3)",
        "surface=light": "rgba(46, 96, 148, 0.35)"
      }
    },
    "weight-regular": {
      "kind": "typography",
      "axes": [],
      "doc": "Body / default text weight.",
      "values": { "default": "400" }
    },
    "weight-medium": {
      "kind": "typography",
      "axes": [],
      "doc": "Slightly emphasized body / nav links.",
      "values": { "default": "500" }
    },
    "weight-semibold": {
      "kind": "typography",
      "axes": [],
      "doc": "Section headings / labels.",
      "values": { "default": "600" }
    },
    "weight-bold": {
      "kind": "typography",
      "axes": [],
      "doc": "Strong emphasis / button labels / page titles.",
      "values": { "default": "700" }
    },
    "weight-display": {
      "kind": "typography",
      "axes": [],
      "doc": "Hero / display titles — the heaviest weight we ship.",
      "values": { "default": "800" }
    },
    "font-display": {
      "kind": "typography",
      "axes": [],
      "doc": "Display headlines — Manrope. System fallback.",
      "values": {
        "default": "'Manrope', system-ui, sans-serif"
      }
    },
    "font-body": {
      "kind": "typography",
      "axes": [],
      "doc": "Body copy — Satoshi. System fallback.",
      "values": {
        "default": "'Satoshi', system-ui, sans-serif"
      }
    },
    "font-mono": {
      "kind": "typography",
      "axes": [],
      "doc": "Monospace — code blocks, terminal output.",
      "values": {
        "default": "'SF Mono', 'Fira Code', 'JetBrains Mono', monospace"
      }
    },
    "shadow-card": {
      "kind": "shadow",
      "axes": ["surface"],
      "doc": "Default card shadow.",
      "values": {
        "default":       "0 1px 3px rgba(0,0,0,0.25), 0 4px 12px rgba(0,0,0,0.12)",
        "surface=light": "0 1px 4px rgba(0,0,0,0.08), 0 4px 14px rgba(0,0,0,0.05)"
      }
    },
    "shadow-accent": {
      "kind": "shadow",
      "axes": ["surface"],
      "doc": "Accent-tinted glow shadow — used on focused/featured elements.",
      "values": {
        "default":       "rgba(104, 152, 190, 0.15)",
        "surface=light": "rgba(46, 96, 148, 0.2)"
      }
    },
    "shadow-elevated": {
      "kind": "shadow",
      "axes": ["surface"],
      "doc": "Multi-layer drop shadow for cards that need to feel like they're floating. Subtle on dark, pronounced on light (cards need to lift off the page bg).",
      "values": {
        "default":       "0 1px 2px rgba(0,0,0,0.20), 0 4px 12px rgba(0,0,0,0.12), 0 12px 28px rgba(0,0,0,0.08)",
        "surface=light": "0 1px 2px rgba(8,22,36,0.06), 0 6px 16px rgba(8,22,36,0.08), 0 18px 36px rgba(8,22,36,0.10), 0 32px 64px rgba(46,96,148,0.06)"
      }
    },
    "shadow-elevated-hover": {
      "kind": "shadow",
      "axes": ["surface"],
      "doc": "Hover lift — deeper than --shadow-elevated, pairs with translateY(-4px) on hovered cards.",
      "values": {
        "default":       "0 2px 4px rgba(0,0,0,0.25), 0 8px 20px rgba(0,0,0,0.16), 0 20px 44px rgba(0,0,0,0.12)",
        "surface=light": "0 2px 4px rgba(8,22,36,0.08), 0 12px 24px rgba(8,22,36,0.12), 0 28px 56px rgba(8,22,36,0.14), 0 48px 96px rgba(46,96,148,0.08)"
      }
    },
    "brand-sigma": {
      "kind": "brand-lock",
      "axes": [],
      "locked": true,
      "doc": "Soma σ mark blue. Immutable — the canonical brand anchor. Moods cannot override.",
      "values": {
        "default": "#7cb2d4"
      }
    },
    "sun-core": {
      "kind": "color",
      "axes": [],
      "doc": "Brightest sun center — near-white peach. Surface-invariant (sun is the same character across themes).",
      "values": { "default": "#fff5d4" }
    },
    "sun-mid": {
      "kind": "color",
      "axes": [],
      "doc": "Sun mid-tone — warm gold. The 'happy daylight' color.",
      "values": { "default": "#ffd88a" }
    },
    "sun-warm": {
      "kind": "color",
      "axes": [],
      "doc": "Sun warm-mid — honey orange. Mid-orange that reads as 'sun' not 'fire'.",
      "values": { "default": "#f0a868" }
    },
    "sun-deep": {
      "kind": "color",
      "axes": [],
      "doc": "Sun deep — copper orange. Sun outer body, rays' end-of-fade.",
      "values": { "default": "#c47852" }
    },
    "sun-text": {
      "kind": "color",
      "axes": [],
      "doc": "Deepest readable ORANGE — high saturation so it doesn't slide into brown/bronze. HSL(20°, 86%, 42%). For TEXT in the promo hue against pale bg.",
      "values": { "default": "#c4520e" }
    },
    "sun-shadow": {
      "kind": "color",
      "axes": [],
      "doc": "Sun's underside shadow. Used for the smirk in the mascot SVG and very dark warm accents.",
      "values": { "default": "#6a2818" }
    },
    "promo": {
      "kind": "color",
      "axes": ["surface"],
      "doc": "Promo accent. Gold-yellow on dark (#f0c866 against deep space). On light: vivid orange (HSL ~26°, 88%, 53%) used for icons, dots, lines, glows, the σ sigma, version badge bg. For TEXT use --promo-text.",
      "values": {
        "default":       "#f0c866",
        "surface=light": "#ec8430"
      }
    },
    "promo-text": {
      "kind": "color",
      "axes": ["surface"],
      "doc": "Readable text variant of --promo. On dark: bright gold pops. On light: vivid deep orange (--sun-text). High saturation so it doesn't read as brown/bronze.",
      "values": {
        "default":       "#f0c866",
        "surface=light": "#c4520e"
      }
    },
    "promo-dim": {
      "kind": "color",
      "axes": ["surface"],
      "doc": "Dimmed promo — secondary text, hover-leave state. Light: deeper than --promo-text but still saturated orange (no brown).",
      "values": {
        "default":       "#c4a24e",
        "surface=light": "#a04210"
      }
    },
    "promo-glow": {
      "kind": "color",
      "axes": ["surface"],
      "doc": "Translucent promo wash for backgrounds and soft surfaces.",
      "values": {
        "default":       "rgba(240, 200, 102, 0.15)",
        "surface=light": "rgba(232, 144, 72, 0.20)"
      }
    },
    "promo-border": {
      "kind": "color",
      "axes": ["surface"],
      "doc": "Promo border ring — visible outline around badges, chips, version pills.",
      "values": {
        "default":       "rgba(240, 200, 102, 0.25)",
        "surface=light": "rgba(232, 144, 72, 0.40)"
      }
    }
  }
}
