---
/**
 * MoonDisk — PARKED COMPONENT (cycle 17, s01-7b287c).
 *
 * Originally part of <Sky> (src/components/Sky.astro) as the dark-mode
 * celestial counterpart to the sun disk. Curtis's call after first look:
 * "save the planet — like in a sep file, but remove it for now."
 *
 * Looks cool but the day-night cinematic worked better with a single
 * directional light source (sun rising from one side) and stars buzzing
 * by — the moon competed with the stars as the dark-mode focal point.
 *
 * To re-enable: import this in src/components/Sky.astro and render
 * inside the .sky-celestial container.
 *
 *   import MoonDisk from './_parked/MoonDisk.astro';
 *   ...
 *   <div class="sky-celestial">
 *     <MoonDisk />
 *     <div class="sky-sun"></div>
 *   </div>
 *
 * Both .sky-moon and .sky-moon-crater-* CSS rules need to be restored
 * to Sky.astro <style> too (extracted below).
 */
---

<div class="sky-moon">
  <div class="sky-moon-crater sky-moon-crater-1"></div>
  <div class="sky-moon-crater sky-moon-crater-2"></div>
  <div class="sky-moon-crater sky-moon-crater-3"></div>
</div>

<style>
  /* Moon: pale silver-blue disk. Visible in dark, slides down in light → dark. */
  .sky-moon {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(
      circle at 65% 35%,
      rgba(228, 234, 244, 0.92) 0%,
      rgba(180, 198, 222, 0.75) 50%,
      rgba(124, 152, 188, 0.3) 80%,
      transparent 100%
    );
    box-shadow:
      0 0 30px rgba(124, 178, 212, 0.2),
      0 0 60px rgba(124, 178, 212, 0.1);
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s ease, transform 1.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  html[data-theme='light'] .sky-moon {
    opacity: 0;
    transform: translateY(-40px);
  }

  /* Moon craters — tiny darker spots */
  .sky-moon-crater {
    position: absolute;
    border-radius: 50%;
    background: rgba(80, 100, 130, 0.18);
  }
  .sky-moon-crater-1 { top: 30%; left: 35%; width: 14px; height: 14px; }
  .sky-moon-crater-2 { top: 55%; left: 50%; width: 9px; height: 9px; }
  .sky-moon-crater-3 { top: 42%; left: 62%; width: 6px; height: 6px; }

  @media (prefers-reduced-motion: reduce) {
    .sky-moon {
      transition: opacity 0.2s linear !important;
      transform: none !important;
    }
  }
</style>
