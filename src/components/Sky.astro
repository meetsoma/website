---
/**
 * Sky — atmospheric horizon overlay for theme transitions.
 *
 * Renders below content (z-index: 0.5) but above the bg / starfield.
 *   - Horizon gradient: a bottom-anchored radial that goes
 *     indigo → red → orange → pale-yellow during sunrise, reverses for sunset.
 *   - Sun/moon disk: small SVG that drifts up (sunrise) or down (sunset).
 *
 * Idle (post-transition): minimal opacity, just a soft horizon hint that
 * varies by theme. Daytime shows a faint warm haze at the bottom. Nighttime
 * shows a faint indigo glow.
 *
 * Cycle 17 (s01-7b287c) — Curtis's vision: "stars could slide out of view
 * and in comes the orange/blue then daylight hue of the sky as if time just
 * fast-forwarded to day."
 *
 * Animation lives in Layout.astro's theme toggle script, which uses GSAP
 * to drive the timeline. This component is the canvas; toggle is the projector.
 */
---

<!--
  Cycle 17 (s01-7b287c) refinement after Curtis's first-look feedback:
  "save the planet — like in a sep file but remove it for now."
  Moon disk parked at: src/components/_parked/MoonDisk.astro
  To re-enable, import + render inside .sky-celestial.
-->
<div class="sky" aria-hidden="true">
  <div class="sky-horizon"></div>
  <div class="sky-warmth"></div>
  <div class="sky-celestial">
    <!-- Soma sun — mascot character with aviator shades + sun-ray hair.
         Iter 9 (s01-b73653): Ray-Ban silhouette extracted from a reference
         photo via Python+PIL→potrace, baked into the sun. Kept as a self-
         contained inline SVG so we can transition opacity/transform on the
         wrapper without touching child elements. -->
    <div class="sky-sun">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400" class="sky-sun-svg" aria-hidden="true">
        <defs>
          <radialGradient id="sun-body" cx="38%" cy="30%" r="60%">
            <stop offset="0%" stop-color="#fff5d4"/>
            <stop offset="35%" stop-color="#ffd88a"/>
            <stop offset="70%" stop-color="#f0a868"/>
            <stop offset="100%" stop-color="#c47852"/>
          </radialGradient>
          <radialGradient id="sun-ray" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#ffd88a"/>
            <stop offset="100%" stop-color="#e8a87c" stop-opacity="0.55"/>
          </radialGradient>
          <radialGradient id="sun-ray-short" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#ffe6aa"/>
            <stop offset="100%" stop-color="#e8a87c" stop-opacity="0.45"/>
          </radialGradient>
          <radialGradient id="sun-spec" cx="30%" cy="22%" r="22%">
            <stop offset="0%" stop-color="white" stop-opacity="0.40"/>
            <stop offset="100%" stop-color="white" stop-opacity="0"/>
          </radialGradient>
          <radialGradient id="sun-halo" cx="50%" cy="50%" r="50%">
            <stop offset="30%" stop-color="white"   stop-opacity="0.18"/>
            <stop offset="45%" stop-color="#ffe6aa" stop-opacity="0.24"/>
            <stop offset="65%" stop-color="#f0a868" stop-opacity="0.18"/>
            <stop offset="100%" stop-color="#e8a87c" stop-opacity="0"/>
          </radialGradient>
          <linearGradient id="sun-lens" x1="50%" y1="0%" x2="50%" y2="100%">
            <stop offset="0%" stop-color="#3a5a8c"/>
            <stop offset="35%" stop-color="#5a7eaa"/>
            <stop offset="65%" stop-color="#9ab4d0"/>
            <stop offset="100%" stop-color="#e0ecf6"/>
          </linearGradient>
          <radialGradient id="sun-cheek" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#f08858" stop-opacity="0.35"/>
            <stop offset="100%" stop-color="#f08858" stop-opacity="0"/>
          </radialGradient>
        </defs>

        <circle cx="200" cy="200" r="200" fill="url(#sun-halo)"/>

        <g transform="translate(200,200)">
          <g fill="url(#sun-ray)" opacity="0.92">
            <polygon points="0,-198 -11,-160 11,-160"/>
            <polygon points="0,-198 -11,-160 11,-160" transform="rotate(30)"/>
            <polygon points="0,-198 -11,-160 11,-160" transform="rotate(60)"/>
            <polygon points="0,-198 -11,-160 11,-160" transform="rotate(90)"/>
            <polygon points="0,-198 -11,-160 11,-160" transform="rotate(120)"/>
            <polygon points="0,-198 -11,-160 11,-160" transform="rotate(150)"/>
            <polygon points="0,-198 -11,-160 11,-160" transform="rotate(180)"/>
            <polygon points="0,-198 -11,-160 11,-160" transform="rotate(210)"/>
            <polygon points="0,-198 -11,-160 11,-160" transform="rotate(240)"/>
            <polygon points="0,-198 -11,-160 11,-160" transform="rotate(270)"/>
            <polygon points="0,-198 -11,-160 11,-160" transform="rotate(300)"/>
            <polygon points="0,-198 -11,-160 11,-160" transform="rotate(330)"/>
          </g>
          <g fill="url(#sun-ray-short)" opacity="0.75">
            <polygon points="0,-178 -7,-159 7,-159" transform="rotate(15)"/>
            <polygon points="0,-178 -7,-159 7,-159" transform="rotate(45)"/>
            <polygon points="0,-178 -7,-159 7,-159" transform="rotate(75)"/>
            <polygon points="0,-178 -7,-159 7,-159" transform="rotate(105)"/>
            <polygon points="0,-178 -7,-159 7,-159" transform="rotate(135)"/>
            <polygon points="0,-178 -7,-159 7,-159" transform="rotate(165)"/>
            <polygon points="0,-178 -7,-159 7,-159" transform="rotate(195)"/>
            <polygon points="0,-178 -7,-159 7,-159" transform="rotate(225)"/>
            <polygon points="0,-178 -7,-159 7,-159" transform="rotate(255)"/>
            <polygon points="0,-178 -7,-159 7,-159" transform="rotate(285)"/>
            <polygon points="0,-178 -7,-159 7,-159" transform="rotate(315)"/>
            <polygon points="0,-178 -7,-159 7,-159" transform="rotate(345)"/>
          </g>
        </g>

        <circle cx="200" cy="200" r="150" fill="url(#sun-body)"/>
        <ellipse cx="135" cy="252" rx="32" ry="18" fill="url(#sun-cheek)"/>
        <ellipse cx="265" cy="252" rx="32" ry="18" fill="url(#sun-cheek)"/>
        <circle cx="200" cy="200" r="150" fill="url(#sun-spec)"/>

        <!-- Aviator lenses — traced from Ray-Ban reference (potrace) -->
        <svg x="74" y="170" width="252" height="106" viewBox="173 513 1054 441" preserveAspectRatio="xMidYMid meet">
          <path d="M 412.00,515.20 c -134.20,6.00 -209.10,49.80 -226.90,132.60 -1.10,5.10 -3.90,13.40 -6.20,18.50 -5.40,12.00 -6.20,19.80 -2.90,30.70 1.90,6.60 2.30,10.90 3.00,35.50 2.20,75.40 21.10,117.50 68.60,153.10 91.10,68.20 224.20,11.70 331.30,-140.60 21.40,-30.30 24.00,-34.40 32.90,-52.50 20.50,-41.40 24.60,-54.20 24.60,-78.00 0.00,-55.30 -40.60,-83.30 -139.00,-96.00 -17.10,-2.20 -25.20,-2.70 -57.90,-3.80 -4.90,-0.20 -17.30,0.00 -27.50,0.50 Z"
                fill="url(#sun-lens)" stroke="#a0a6ae" stroke-width="9"/>
          <path d="M 945.50,514.60 c -175.20,8.60 -222.20,70.70 -147.40,194.90 76.70,127.50 192.60,213.90 275.80,205.50 90.50,-9.10 143.30,-73.10 146.10,-177.00 0.70,-28.10 0.90,-29.90 3.40,-38.00 4.00,-12.50 3.40,-21.20 -2.20,-34.10 -2.30,-5.20 -5.30,-14.30 -6.60,-20.10 -16.20,-68.50 -64.90,-106.60 -159.70,-124.70 -25.80,-4.90 -78.20,-8.10 -109.40,-6.50 Z"
                fill="url(#sun-lens)" stroke="#a0a6ae" stroke-width="9"/>
        </svg>

        <!-- Brow bar -->
        <line x1="92" y1="178" x2="200" y2="178" stroke="#a0a6ae" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="200" y1="178" x2="308" y2="178" stroke="#a0a6ae" stroke-width="2.5" stroke-linecap="round"/>
        <!-- Bridge -->
        <path d="M 188,184 Q 200,194 212,184" fill="none" stroke="#a0a6ae" stroke-width="2" stroke-linecap="round"/>
        <!-- Earpieces -->
        <path d="M 76,210 Q 54,196 36,194" fill="none" stroke="#a0a6ae" stroke-width="2.5" stroke-linecap="round"/>
        <path d="M 324,210 Q 346,196 364,194" fill="none" stroke="#a0a6ae" stroke-width="2.5" stroke-linecap="round"/>
        <!-- Lens highlights -->
        <path d="M 100,196 Q 130,188 160,194" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" opacity="0.50"/>
        <path d="M 240,194 Q 270,188 300,196" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" opacity="0.50"/>
        <!-- Dad smirk -->
        <path d="M 162,288 Q 200,310 244,278" fill="none" stroke="#6a2818" stroke-width="6" stroke-linecap="round" opacity="0.80"/>
      </svg>
    </div>
  </div>
</div>

<style>
  .sky {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  /* Horizon: ANGULAR / SIDE-ANCHORED gradient, idle state.
   * Curtis's call (s01-7b287c): "light fading in heavier from one side,
   * like as if spinning out of view." Anchor the radial off-screen to
   * the lower-right so light pours diagonally into the frame.
   * Theme-specific overrides below + GSAP-driven during transition. */
  .sky-horizon {
    position: absolute;
    inset: 0;
    /* Dark theme idle: very subtle indigo wash from lower-right */
    background: radial-gradient(
      ellipse 70% 90% at 110% 110%,
      rgba(46, 80, 124, 0.10) 0%,
      transparent 55%
    );
    opacity: 1;
    transition: opacity 1.2s ease, background 1.2s ease;
  }

  html[data-theme='light'] .sky-horizon {
    /* Light theme idle: BLUE-DOMINANT sky with a small warm wisp on the right.
     * Per Curtis (s01-7b287c) refinement: "more blue." The horizon is mostly
     * pale dawn blue with just a hint of sun-warm at the corner edge. */
    background:
      radial-gradient(
        ellipse 80% 100% at 100% 100%,
        rgba(232, 168, 124, 0.10) 0%,
        rgba(124, 168, 200, 0.12) 25%,
        rgba(124, 168, 200, 0.06) 55%,
        transparent 75%
      ),
      radial-gradient(
        ellipse 100% 60% at 50% 100%,
        rgba(124, 168, 200, 0.10) 0%,
        rgba(124, 178, 212, 0.04) 40%,
        transparent 70%
      );
  }

  /* Warm overlay — SEPARATE from the sky gradient so it can fade
   * independently when crossing mid ↔ day. Curtis (s01-b73653): "the
   * organg glow more gently increase as it gets brighter" + "shouldn't be
   * gradiant -- should be more of an overlay that can fade out as it
   * transitions to the day mood."
   *
   * Mid + light = full warmth. Day + light = 0 (clear sky). Night = 0. */
  .sky-warmth {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    background:
      radial-gradient(ellipse 95% 55% at 50% 100%,
        rgba(245, 175, 120, 0.42) 0%,
        rgba(240, 195, 155, 0.22) 28%,
        transparent 58%),
      radial-gradient(ellipse 55% 70% at 105% 85%,
        rgba(245, 175, 120, 0.38) 0%,
        transparent 62%);
    /* Curtis (s01-b73653): "appear from almost full transparency and
     * increase quickly, not come in at like instant 50 percent."
     * `ease` front-loads movement (~40% progress in first quarter —
     * exactly the pop he was seeing). cubic-bezier with strong ease-in
     * shape keeps opacity near 0 for the first ~40% of duration, then
     * ramps fast — truly fades up from invisible. */
    transition: opacity 1.8s cubic-bezier(0.7, 0, 0.84, 0.4);
  }

  html[data-mood='mid'][data-surface='light'] .sky-warmth { opacity: 1; }
  html[data-mood='day'][data-surface='light'] .sky-warmth { opacity: 0; }
  html[data-mood='night'] .sky-warmth { opacity: 0; }

  @media (prefers-reduced-motion: reduce) {
    .sky-warmth { transition: opacity 0.2s linear !important; }
  }

  /* Celestial layer — sun (moon parked). Position at upper-right.
   * Sized at 170px so the SVG character + halo reads at full presence.
   * Curtis (s01-b73653): "make the sun a bit bigger like it was before". */
  .sky-celestial {
    position: absolute;
    top: 10%;
    right: 7%;
    width: 170px;
    height: 170px;
    pointer-events: none;
  }
  @media (max-width: 640px) {
    .sky-celestial { width: 110px; height: 110px; top: 9%; right: 5%; }
  }

  /* Sun: warm gold disk with halo. In dark, sits OFF-SCREEN to the right
   * (translateX positive). On dark→light, sweeps in from the right edge
   * with a slight upward arc — "spinning out of view" reversed: it's
   * spinning INTO view from offstage. */
  /* Soma sun: SVG character. Wrapper handles position + dark→light fade
   * + the EMANATING SHINE (white core → gold mid → warm orange outer).
   * Three stacked drop-shadows give the layered glow Curtis asked for:
   * "he's got to shine a bit — like a whiter hue, slightly of white
   * maybe like white/gold/orange hue eminating from him." */
  .sky-sun {
    position: absolute;
    inset: 0;
    filter:
      drop-shadow(0 0 18px rgba(255, 248, 220, 0.55))    /* white core */
      drop-shadow(0 0 38px rgba(255, 220, 150, 0.42))    /* gold mid */
      drop-shadow(0 0 78px rgba(240, 168, 104, 0.28));   /* warm orange outer */
    opacity: 0;
    transform: translate(140px, 60px) rotate(-30deg);
    transition:
      opacity 1.8s ease 0.7s,
      transform 2.6s cubic-bezier(0.34, 1.0, 0.4, 1) 0.4s;
  }
  .sky-sun-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  html[data-theme='light'] .sky-sun {
    opacity: 1;
    /* Light: sun rests in upper-right, slightly tilted (just "settled") */
    transform: translate(0, 0) rotate(0);
  }

  /* During transition, GSAP adds .sky-transitioning to <html> — we use it
   * to expose the sky layer more aggressively and make the horizon "swept by sunrise". */
  html.sky-transitioning .sky-horizon {
    /* GSAP overrides background + opacity directly during the transition. */
  }

  @media (prefers-reduced-motion: reduce) {
    .sky-sun,
    .sky-moon {
      transition: opacity 0.2s linear !important;
      transform: none !important;
    }
  }

  @media (max-width: 640px) {
    .sky-celestial {
      width: 75px;
      height: 75px;
      top: 10%;
      right: 6%;
    }
  }
</style>
