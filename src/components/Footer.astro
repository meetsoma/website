---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/">Home</a>
      <span class="sep">·</span>
      <a href="/docs/getting-started">Docs</a>
      <span class="sep">·</span>
      <a href="/blog">Blog</a>
      <span class="sep">·</span>
      <a href="/ecosystem">Ecosystem</a>
      <span class="sep">·</span>
      <a href="/hub">Hub</a>
      <span class="sep">·</span>
      <a href="/roadmap">Roadmap</a>
      <span class="sep">·</span>
      <a href="https://github.com/meetsoma" target="_blank" rel="noopener">GitHub</a>
      <span class="sep">·</span>
      <a href="https://www.npmjs.com/package/meetsoma" target="_blank" rel="noopener">npm</a>
      <span class="sep">·</span>
      <a href="/rss.xml" target="_blank" rel="noopener">RSS</a>
    </nav>
    <p class="footer-copy">© {year} <a href="https://gravicity.ai" target="_blank" rel="noopener">Gravicity</a></p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--border-subtle);
    padding: var(--space-2xl) var(--space-xl);
    text-align: center;
  }

  .footer-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .footer-nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
    font-size: var(--text-base);
  }

  .footer-nav a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-nav a:hover {
    color: var(--accent-bright);
  }

  .sep {
    color: var(--text-muted);
    opacity: 0.4;
  }

  .footer-copy {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .footer-copy a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .footer-copy a:hover {
    color: var(--accent-bright);
  }
</style>
