---
/**
 * Starfield — Canvas-based drifting stars
 * Soft, slow movement. Breathing night sky, not hyperspace.
 * Stars drift upward and slightly right, with gentle twinkling.
 */
---

<canvas id="starfield-canvas" class="starfield"></canvas>

<style>
  .starfield {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  html[data-theme='light'] .starfield {
    /* Cycle 17: bumped from 0.15 — dark stars on light bg need more presence */
    opacity: 0.35;
  }
</style>

<script>
  function initStarfield() {
    const canvas = document.getElementById('starfield-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let w = 0, h = 0;
    let stars: { x: number; y: number; r: number; alpha: number; drift: number; twinkleSpeed: number; twinklePhase: number; color: [number, number, number] }[] = [];
    let animId: number;

    const STAR_DENSITY = 0.00018; // stars per pixel² — visible but not crowded
    const DRIFT_SPEED = 0.06;     // px/frame base — gentle drift

    // Cycle 17 (s01-7b287c): light-mode-aware palette. Dark stars (white-blue,
    // blue) are invisible on a near-white background — the canvas just shows as
    // empty. In light mode, INVERT to use deeper saturated colors that read
    // against #eaeef4. Light mode opacity also bumps in CSS (was 0.15 ghost,
    // now 0.35 visible). Re-detected on theme toggle via 'soma-theme' event.
    const COLORS_DARK: [number, number, number][] = [
      [228, 234, 244],  // text-primary (white-blue)
      [124, 178, 212],  // moon-bright (blue)
      [104, 152, 190],  // accent-bright (deeper blue)
      [240, 200, 102],  // promo gold — rare
    ];
    const COLORS_LIGHT: [number, number, number][] = [
      [46, 96, 148],    // accent-bright dark (deep blue)
      [26, 61, 102],    // accent-dark (deeper blue)
      [42, 54, 72],     // text-secondary dark (slate)
      [168, 90, 42],    // warm-bright dark (rare bronze)
    ];
    const isLight = () => document.documentElement.dataset.theme === 'light';
    let COLORS: [number, number, number][] = isLight() ? COLORS_LIGHT : COLORS_DARK;

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = window.innerWidth;
      h = window.innerHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      canvas.style.width = w + 'px';
      canvas.style.height = h + 'px';
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      createStars();
    }

    function createStars() {
      const count = Math.floor(w * h * STAR_DENSITY);
      stars = [];
      for (let i = 0; i < count; i++) {
        // 80% white-blue, 15% blue, 4% deeper blue, 1% warm
        const roll = Math.random();
        const colorIdx = roll < 0.80 ? 0 : roll < 0.95 ? 1 : roll < 0.99 ? 2 : 3;

        stars.push({
          x: Math.random() * w,
          y: Math.random() * h,
          r: Math.random() * 1.2 + 0.3,  // 0.3–1.5px radius
          alpha: Math.random() * 0.6 + 0.15,
          drift: (Math.random() * 0.5 + 0.5) * DRIFT_SPEED,
          twinkleSpeed: Math.random() * 0.008 + 0.003,
          twinklePhase: Math.random() * Math.PI * 2,
          color: COLORS[colorIdx],
        });
      }
    }

    // Cycle 17 (s01-7b287c): canvas-level alpha multiplier so the theme
    // toggle's GSAP timeline can fade the WHOLE starfield in/out as part of
    // the day-night cinematic. 1.0 = fully visible; 0 = invisible.
    let canvasAlpha = 1;
    // Drift boost during transition — stars seem to "sweep away" faster
    // when day arrives, then "settle in" when night returns.
    let driftMultiplier = 1;

    let time = 0;
    function draw() {
      ctx!.clearRect(0, 0, w, h);
      time++;

      if (canvasAlpha <= 0.001) {
        // Stars effectively gone — still rAF so we can resume on theme flip
        animId = requestAnimationFrame(draw);
        return;
      }

      for (const s of stars) {
        // Drift: slow upward + slight rightward (boosted during transitions)
        s.y -= s.drift * driftMultiplier;
        s.x += s.drift * 0.3 * driftMultiplier;

        // Wrap around
        if (s.y < -5) { s.y = h + 5; s.x = Math.random() * w; }
        if (s.x > w + 5) { s.x = -5; }

        // Twinkle
        const twinkle = Math.sin(time * s.twinkleSpeed + s.twinklePhase);
        const alpha = (s.alpha + twinkle * 0.2) * canvasAlpha;
        if (alpha <= 0) continue;

        const [r, g, b] = s.color;
        ctx!.beginPath();
        ctx!.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${r},${g},${b},${Math.min(alpha, 0.8)})`;
        ctx!.fill();
      }

      animId = requestAnimationFrame(draw);
    }

    // Theme transition listener: dim/restore stars to choreograph with the
    // sky cinematic. Sunrise (→ light): fade out + drift faster (stars sweep
    // away as day arrives). Sunset (→ dark): fade IN + drift settles
    // (stars emerge as night falls). On settled palette change, restore
    // canvas color palette (already handled inline isLight check).
    function animateAlpha(target: number, durMs: number) {
      const start = canvasAlpha;
      const startTime = performance.now();
      function step() {
        const t = Math.min(1, (performance.now() - startTime) / durMs);
        // ease-out-cubic
        const eased = 1 - Math.pow(1 - t, 3);
        canvasAlpha = start + (target - start) * eased;
        if (t < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }
    function animateDrift(target: number, durMs: number) {
      const start = driftMultiplier;
      const startTime = performance.now();
      function step() {
        const t = Math.min(1, (performance.now() - startTime) / durMs);
        const eased = 1 - Math.pow(1 - t, 2);
        driftMultiplier = start + (target - start) * eased;
        if (t < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    window.addEventListener('soma-theme:transitioning', (e: any) => {
      const isSunrise = e.detail?.isSunrise === true;
      if (isSunrise) {
        // Stars dim and drift away as day arrives
        animateDrift(4, 700);
        animateAlpha(0, 800);
      } else {
        // Stars emerge from the night sky
        animateDrift(2.5, 400);
        // Hold low briefly so the dark palette settles, then re-fade in
        setTimeout(() => animateAlpha(1, 900), 600);
        setTimeout(() => animateDrift(1, 800), 900);
      }
    });
    window.addEventListener('soma-theme', (e: any) => {
      // Theme settled — swap palette + restore color choice for re-init.
      COLORS = e.detail?.theme === 'light' ? COLORS_LIGHT : COLORS_DARK;
      // Re-color existing stars (rotate through palette by index)
      for (let i = 0; i < stars.length; i++) {
        const roll = (i * 17) % 100;
        const colorIdx = roll < 80 ? 0 : roll < 95 ? 1 : roll < 99 ? 2 : 3;
        stars[i].color = COLORS[colorIdx];
      }
      // If we're now LIGHT, hold stars dim. If DARK, ensure they're at full alpha.
      if (e.detail?.theme === 'light') {
        canvasAlpha = 0;
      }
    });

    // Pause when tab hidden
    function handleVisibility() {
      if (document.hidden) {
        cancelAnimationFrame(animId);
      } else {
        animId = requestAnimationFrame(draw);
      }
    }

    // Reduce motion preference
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (prefersReducedMotion.matches) {
      resize();
      // Draw once, no animation
      time = 42; // offset for variety
      ctx!.clearRect(0, 0, w, h);
      for (const s of stars) {
        const [r, g, b] = s.color;
        ctx!.beginPath();
        ctx!.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${r},${g},${b},${s.alpha})`;
        ctx!.fill();
      }
      return;
    }

    resize();
    window.addEventListener('resize', resize);
    document.addEventListener('visibilitychange', handleVisibility);
    animId = requestAnimationFrame(draw);

    // Cleanup on Astro view transitions
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animId);
      window.removeEventListener('resize', resize);
      document.removeEventListener('visibilitychange', handleVisibility);
    });
  }

  // Init on load and on Astro page transitions
  initStarfield();
  document.addEventListener('astro:after-swap', initStarfield);
</script>
