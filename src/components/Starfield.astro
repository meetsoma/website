---
/**
 * Starfield — Canvas-based drifting stars
 * Soft, slow movement. Breathing night sky, not hyperspace.
 * Stars drift upward and slightly right, with gentle twinkling.
 */
---

<canvas id="starfield-canvas" class="starfield"></canvas>

<style>
  .starfield {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    /* Smooth fade between dark (full stars) and light (faint stars) */
    transition: opacity 1.4s ease;
  }

  html[data-theme='light'] .starfield {
    /* Cycle 17: bumped from 0.15 — dark stars on light bg need more presence.
     * s01-b73653: down to 0.18 — with the new airy mid mood the stars feel
     * busy. Faint constellation hint, not full starfield. */
    opacity: 0.18;
  }

  @media (prefers-reduced-motion: reduce) {
    .starfield { transition: opacity 0.2s linear !important; }
  }
</style>

<script>
  function initStarfield() {
    const canvas = document.getElementById('starfield-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let w = 0, h = 0;
    let stars: { x: number; y: number; r: number; alpha: number; drift: number; twinkleSpeed: number; twinklePhase: number; color: [number, number, number] }[] = [];
    let animId: number;

    const STAR_DENSITY = 0.00018; // stars per pixel² — visible but not crowded
    const DRIFT_SPEED = 0.06;     // px/frame base — gentle drift

    // Cycle 17 (s01-7b287c): light-mode-aware palette. Dark stars (white-blue,
    // blue) are invisible on a near-white background — the canvas just shows as
    // empty. In light mode, INVERT to use deeper saturated colors that read
    // against #eaeef4. Light mode opacity also bumps in CSS (was 0.15 ghost,
    // now 0.35 visible). Re-detected on theme toggle via 'soma-theme' event.
    const COLORS_DARK: [number, number, number][] = [
      [228, 234, 244],  // text-primary (white-blue)
      [124, 178, 212],  // moon-bright (blue)
      [104, 152, 190],  // accent-bright (deeper blue)
      [240, 200, 102],  // promo gold — rare
    ];
    const COLORS_LIGHT: [number, number, number][] = [
      [46, 96, 148],    // accent-bright dark (deep blue)
      [26, 61, 102],    // accent-dark (deeper blue)
      [42, 54, 72],     // text-secondary dark (slate)
      [168, 90, 42],    // warm-bright dark (rare bronze)
    ];
    const isLight = () => document.documentElement.dataset.theme === 'light';
    let COLORS: [number, number, number][] = isLight() ? COLORS_LIGHT : COLORS_DARK;

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = window.innerWidth;
      h = window.innerHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      canvas.style.width = w + 'px';
      canvas.style.height = h + 'px';
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      createStars();
    }

    function createStars() {
      const count = Math.floor(w * h * STAR_DENSITY);
      stars = [];
      for (let i = 0; i < count; i++) {
        // 80% white-blue, 15% blue, 4% deeper blue, 1% warm
        const roll = Math.random();
        const colorIdx = roll < 0.80 ? 0 : roll < 0.95 ? 1 : roll < 0.99 ? 2 : 3;

        stars.push({
          x: Math.random() * w,
          y: Math.random() * h,
          r: Math.random() * 1.2 + 0.3,  // 0.3–1.5px radius
          alpha: Math.random() * 0.6 + 0.15,
          drift: (Math.random() * 0.5 + 0.5) * DRIFT_SPEED,
          twinkleSpeed: Math.random() * 0.008 + 0.003,
          twinklePhase: Math.random() * Math.PI * 2,
          color: COLORS[colorIdx],
        });
      }
    }

    // Cycle 17 (s01-7b287c, refined): state object tweened by GSAP rather
    // than raw rAF loops. Per gsap-core skill: GSAP can tween any object
    // property. Cleaner + composable into the toggle's master timeline
    // later if needed. Per gsap-core: stick to documented eases + matchMedia
    // for prefers-reduced-motion.
    //
    // canvasAlpha: full-starfield opacity multiplier (1 = visible, 0 = gone)
    // driftMultiplier: vertical drift speed (1 = idle, 8+ = warp during transition)
    // lateralBoost: ADDITIONAL horizontal sweep — stars 'buzz by' diagonally
    //   during sunrise (Curtis's specific ask: "i'd like to see those stars buzz by")
    const state = { canvasAlpha: 1, driftMultiplier: 1, lateralBoost: 0 };

    // Lazy-load GSAP for non-critical interactivity (theme transitions only).
    // Imported dynamically inside the listener to avoid blocking initial render.
    let gsapLib: any = null;
    async function getGsap() {
      if (!gsapLib) {
        const mod = await import('gsap');
        gsapLib = mod.gsap;
      }
      return gsapLib;
    }

    let time = 0;
    function draw() {
      ctx!.clearRect(0, 0, w, h);
      time++;

      if (state.canvasAlpha <= 0.001) {
        animId = requestAnimationFrame(draw);
        return;
      }

      for (const s of stars) {
        // Vertical drift (slow upward) + lateral boost during transitions.
        // The lateralBoost is what creates the 'buzz by' streaking effect:
        // during sunrise, stars not only fade but ALSO rip diagonally
        // across the screen as if blown away by the incoming day.
        s.y -= s.drift * state.driftMultiplier;
        s.x += s.drift * (0.3 + state.lateralBoost) * state.driftMultiplier;

        // Wrap around
        if (s.y < -5) { s.y = h + 5; s.x = Math.random() * w; }
        if (s.x > w + 5) { s.x = -5; }

        // Twinkle
        const twinkle = Math.sin(time * s.twinkleSpeed + s.twinklePhase);
        const alpha = (s.alpha + twinkle * 0.2) * state.canvasAlpha;
        if (alpha <= 0) continue;

        const [r, g, b] = s.color;
        ctx!.beginPath();
        ctx!.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${r},${g},${b},${Math.min(alpha, 0.8)})`;
        ctx!.fill();
      }

      animId = requestAnimationFrame(draw);
    }

    // Theme-transition listener: stars BUZZ BY during sunrise (warp speed +
    // lateral sweep), settle back in at night. Per gsap-core skill: tween
    // arbitrary object properties; the draw loop reads state every frame.
    window.addEventListener('soma-theme:transitioning', async (e: any) => {
      const isSunrise = e.detail?.isSunrise === true;
      const gsap = await getGsap();
      gsap.killTweensOf(state); // overwrite any in-flight transition

      if (isSunrise) {
        // Stars warp out: ramp drift HARD + add lateral sweep, then fade.
        // The buzz-by effect = high driftMultiplier (8x) + lateralBoost (1.2)
        // so stars streak diagonally across before disappearing.
        gsap.timeline()
          .to(state, { driftMultiplier: 8, duration: 0.45, ease: 'power3.in' }, 0)
          .to(state, { lateralBoost: 1.2, duration: 0.45, ease: 'power2.in' }, 0)
          .to(state, { canvasAlpha: 0, duration: 0.7, ease: 'power2.out' }, 0.15)
          // Reset drift values to idle so when stars come back next sunset,
          // they're not still warping. canvasAlpha stays at 0 in light mode.
          .set(state, { driftMultiplier: 1, lateralBoost: 0 });
      } else {
        // Stars emerge from the night sky: fade in slowly, no warp.
        // Brief hold at 0 so the dark palette settles first, then drift in.
        gsap.timeline({ defaults: { ease: 'power2.out' } })
          .set(state, { driftMultiplier: 2, lateralBoost: 0 }, 0.2)
          .to(state, { canvasAlpha: 1, duration: 1.0 }, 0.5)
          .to(state, { driftMultiplier: 1, duration: 0.8 }, 0.7);
      }
    });
    window.addEventListener('soma-theme', (e: any) => {
      // Theme settled — swap palette + ensure stars are dim in light mode.
      COLORS = e.detail?.theme === 'light' ? COLORS_LIGHT : COLORS_DARK;
      for (let i = 0; i < stars.length; i++) {
        const roll = (i * 17) % 100;
        const colorIdx = roll < 80 ? 0 : roll < 95 ? 1 : roll < 99 ? 2 : 3;
        stars[i].color = COLORS[colorIdx];
      }
      if (e.detail?.theme === 'light') {
        state.canvasAlpha = 0;
      }
    });

    // Pause when tab hidden
    function handleVisibility() {
      if (document.hidden) {
        cancelAnimationFrame(animId);
      } else {
        animId = requestAnimationFrame(draw);
      }
    }

    // Reduce motion preference
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (prefersReducedMotion.matches) {
      resize();
      // Draw once, no animation
      time = 42; // offset for variety
      ctx!.clearRect(0, 0, w, h);
      for (const s of stars) {
        const [r, g, b] = s.color;
        ctx!.beginPath();
        ctx!.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(${r},${g},${b},${s.alpha})`;
        ctx!.fill();
      }
      return;
    }

    resize();
    window.addEventListener('resize', resize);
    document.addEventListener('visibilitychange', handleVisibility);
    animId = requestAnimationFrame(draw);

    // Cleanup on Astro view transitions
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animId);
      window.removeEventListener('resize', resize);
      document.removeEventListener('visibilitychange', handleVisibility);
    });
  }

  // Init on load and on Astro page transitions
  initStarfield();
  document.addEventListener('astro:after-swap', initStarfield);
</script>
