---
interface Props {
  title: string;
  subtitle?: string;
  link?: { href: string; text: string };
}

const { title, subtitle, link } = Astro.props;
---

<div class="section-header">
  <h2 class="section-title">
    <span class="accent">σ</span> {title}
  </h2>
  {subtitle && <p class="section-subtitle">{subtitle}</p>}
  {link && <a href={link.href} class="section-link">{link.text}</a>}
</div>

<style>
  .section-header {
    margin-bottom: 34px;          /* fib */
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 13px;                    /* fib */
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 1.625rem;          /* f-xl (26px) */
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.2;
  }

  .accent {
    color: var(--accent-bright);
    font-weight: 700;
    margin-right: 3px;
  }

  .section-subtitle {
    color: var(--text-secondary);
    font-size: 1rem;              /* f-base — was 0.95 */
    line-height: 1.618;
  }

  .section-link {
    margin-left: auto;
    color: var(--accent-bright);
    text-decoration: none;
    font-size: 1rem;              /* f-base — was 0.9 */
    transition: color 0.2s;
  }

  .section-link:hover {
    color: var(--moon-bright);
  }
</style>
