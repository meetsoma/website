---
/**
 * HeroTitle — page hero h1 with the canonical σ-for-o swap.
 *
 * Curtis (s01-b73653): "all of the headers that have a word with an o
 * should use the body/soma symbol (and same font)". This centralizes the
 * pattern so every page hero is consistent — same font, same sigma color,
 * same swap rule.
 *
 * Usage:
 *   <HeroTitle text="Roadmap" />               → R<σ>admap
 *   <HeroTitle text="Documentation" />         → D<σ>cumentation
 *   <HeroTitle text="Hub" />                   → Hub (no swap if no o)
 *   <HeroTitle text="The Somaverse" prefix="The " /> → The S<σ>maverse
 *   <HeroTitle text="Blog" align="center" />   → centered
 *
 * Behavior:
 *   - First lowercase 'o' in the text gets replaced (case-preserving — the
 *     σ inherits color/font; for an uppercase 'O' we still emit lowercase σ).
 *   - If a `prefix` prop is given (e.g. "The "), the swap happens on the
 *     remainder so "The Somaverse" → "The S<σ>maverse" not "The S<σ>maverse"
 *     vs random earlier o.
 *   - No o anywhere → renders as plain text.
 */

interface Props {
  text: string;
  /** Optional prefix that's rendered as plain text before the σ-able word. */
  prefix?: string;
  /** Class hook for parent positioning. */
  class?: string;
  /** 'left' (default) | 'center' */
  align?: 'left' | 'center';
  /** h1 (default) or h2 */
  level?: 1 | 2;
}

const { text, prefix = '', class: extraClass = '', align = 'left', level = 1 } = Astro.props;

// Find the FIRST 'o' or 'O' in the text. If found, split into [before, after].
const idx = text.search(/o/i);
const before = idx >= 0 ? text.slice(0, idx) : text;
const after  = idx >= 0 ? text.slice(idx + 1) : '';
const Tag = level === 1 ? 'h1' : 'h2';
---

<Tag class={`hero-title ${align === 'center' ? 'is-center' : ''} ${extraClass}`}>
  {prefix && <span class="hero-prefix">{prefix}</span>}
  <span class="hero-main">{before}{idx >= 0 && <span class="hero-sigma" aria-hidden="true">σ</span>}{after}</span>
  {idx < 0 && /* if no σ swap happened, embed an aria-label is not needed; the text is the text */ null}
</Tag>

<style>
  /* Hero titles — SAME font / weight / size / leading on every page.
   * Pulls from registry tokens so a typography-scale change ripples
   * through every page hero in lockstep. */
  .hero-title {
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    letter-spacing: -0.025em;
    line-height: var(--leading-tight);
    color: var(--ink);
    margin: 0;
  }
  .hero-title.is-center { text-align: center; }

  .hero-prefix {
    color: var(--ink-soft);
    font-weight: var(--weight-medium);
    margin-right: 0.2em;
  }

  .hero-main {
    letter-spacing: inherit;
  }

  /* The signature σ — must read as the SAME glyph weight as its Latin
   * siblings. Greek lowercase glyphs in most fonts are optically
   * lighter than Latin caps/lowercase at the same numerical weight, so
   * we bump the weight + scale slightly so it doesn't look anemic. */
  .hero-sigma {
    color: var(--promo);
    font-family: var(--font-display);
    font-weight: 900;              /* +100 over surrounding text for optical match */
    font-size: 1.06em;             /* tiny scale-up to match Latin x-height */
    display: inline-block;
    transform: translateY(-0.02em);
    text-shadow: 0 0 24px var(--promo-glow),
                 0 0 6px  var(--promo-glow);
    /* Tracking adjustment so the sigma doesn't crowd its neighbors */
    letter-spacing: -0.01em;
  }

  .hero-title:focus-within { outline: none; }
</style>
