---
import MobileMenu from './islands/MobileMenu.tsx';

/**
 * Nav — site navigation bar.
 *
 * Two modes:
 *   1. DEFAULT: shows logo (σ) + desktop nav-links + external icons.
 *      Mobile (<768px): hides nav-links, shows hamburger dropdown.
 *
 *   2. CENTERED-TITLE: pass `centeredTitle` prop (e.g. "Somaverse").
 *      Desktop: hides nav-links, centers the title, shows hamburger for nav.
 *      Mobile: same as default but with centered title.
 *
 * ARCHITECTURE NOTES for future editors:
 *   - .mobile-menu-trigger, .mobile-menu-dropdown, .mobile-menu-link styles
 *     live OUTSIDE @media queries — they must apply at all widths.
 *     The mobile-menu-root's display:none on desktop prevents them from
 *     rendering on the main nav; has-centered-title overrides to show them.
 *   - Dropdown uses `top: 100%` (not hardcoded px) — nav height differs
 *     between mobile (48px) and desktop (55px).
 *   - Standalone pages (no Layout.astro) must define --space-* tokens.
 *   - See design-system.md § Phase 7 for the full checklist.
 */

interface Props {
  /** Optional centered title (e.g. "SomaVerse"). When set, replaces the nav
   *  link bar with a centered h1 heading and applies the σ-for-o swap. */
  centeredTitle?: string;
}

const { centeredTitle = '' } = Astro.props as Props;
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/docs', label: 'Docs' },
  { href: '/blog', label: 'Blog' },
  { href: '/ecosystem', label: 'Ecosystem' },
  { href: '/hub', label: 'Hub' },
  { href: '/roadmap', label: 'Roadmap' },
];

function isActive(href: string, current: string): boolean {
  if (href === '/') return current === '/';
  return current.startsWith(href);
}

// σ-for-o swap on centered title (matching HeroTitle pattern)
const titleIdx = centeredTitle.search(/o/i);
const titleBefore = titleIdx >= 0 ? centeredTitle.slice(0, titleIdx) : centeredTitle;
const titleSigma = titleIdx >= 0;
const titleAfter = titleIdx >= 0 ? centeredTitle.slice(titleIdx + 1) : '';
---

<header class="site-nav-wrapper">
  <nav class="site-nav" aria-label="Main navigation" class:list={{ 'has-centered-title': !!centeredTitle }}>
    <a href="/" class="nav-brand" aria-label="Soma home">
      <span class="nav-sigma">σ</span>
    </a>
    <MobileMenu client:load />
    {centeredTitle && (
      <h1 class="nav-centered-title">
        {titleBefore}{titleSigma && <span class="nav-cs-sigma" aria-hidden="true">σ</span>}{titleAfter}
      </h1>
    )}
    <div class="nav-links">
      {links.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: isActive(link.href, currentPath) }]}
          aria-current={isActive(link.href, currentPath) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="nav-external">
      <a href="https://github.com/meetsoma" target="_blank" rel="noopener" class="nav-icon-link" aria-label="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
        </svg>
      </a>
      <slot name="nav-right-extra" />
      <button class="theme-toggle" type="button" aria-label="Switch color theme">
        <svg class="theme-icon theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2"/>
          <path d="M12 20v2"/>
          <path d="m4.93 4.93 1.41 1.41"/>
          <path d="m17.66 17.66 1.41 1.41"/>
          <path d="M2 12h2"/>
          <path d="M20 12h2"/>
          <path d="m6.34 17.66-1.41 1.41"/>
          <path d="m19.07 4.93-1.41 1.41"/>
        </svg>
        <svg class="theme-icon theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
        </svg>
      </button>
    </div>
  </nav>
</header>
<style>
  .site-nav-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    backdrop-filter: blur(12px) saturate(1.2);
    -webkit-backdrop-filter: blur(12px) saturate(1.2);
    background: rgba(6, 8, 14, 0.65);
    border-bottom: 1px solid var(--border);
    transition: background-color 0.6s ease, border-color 0.5s ease;
  }

  :global(html[data-theme='light']) .site-nav-wrapper {
    background: rgba(244, 246, 249, 0.75);
  }

  .site-nav {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: 0 var(--space-xl);
    height: 55px;
  }

  /* ── Brand mark ── */
  .nav-brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    margin-right: var(--space-lg);
    flex-shrink: 0;
  }

  .nav-sigma {
    font-family: var(--font-display);
    font-size: 1.85rem;
    font-weight: 800;
    color: var(--promo-text);
    line-height: 0.85;
    padding-bottom: 5px;
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }

  .nav-brand:hover .nav-sigma {
    color: var(--moon-bright);
    text-shadow: 0 0 var(--space-xl) var(--moon-glow);
  }

  /* ── Links ── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    flex: 1;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: var(--body-secondary);
    font-weight: 500;
    color: var(--ink-soft);
    text-decoration: none;
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    transition: color 0.15s ease, background-color 0.15s ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--ink);
    background: var(--surface-interactive);
  }

  .nav-link.active {
    color: var(--accent);
    background: var(--surface-accent-soft);
  }

  /* ── External icons ── */
  .nav-external {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-left: auto;
  }

  .nav-icon-link {
    display: grid;
    place-items: center;
    width: var(--space-2xl);
    height: var(--space-2xl);
    border-radius: var(--radius-md);
    color: var(--ink-soft);
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .nav-icon-link:hover {
    color: var(--ink);
    background: var(--surface-interactive);
  }

  /* ── Theme toggle ── */
  .theme-toggle {
    display: grid;
    place-items: center;
    width: var(--space-2xl);
    height: var(--space-2xl);
    border-radius: var(--radius-md);
    border: none;
    background: transparent;
    cursor: pointer;
    padding: 0;
    color: var(--ink-soft);
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .theme-toggle:hover {
    color: var(--ink);
    background: var(--surface-interactive);
  }

  /* Show sun in dark mode, moon in light mode */
  .theme-icon-sun { display: none; }
  .theme-icon-moon { display: none; }
  :global(html[data-theme='dark']) .theme-icon-sun { display: block; }
  :global(html[data-theme='light']) .theme-icon-moon { display: block; }
  /* Default to sun (dark mode is default) */
  :global(html:not([data-theme])) .theme-icon-sun { display: block; }

  /* ── Centered title mode ── */
  .site-nav.has-centered-title {
    position: relative;
    gap: 2px;
  }

  .site-nav.has-centered-title .nav-links {
    display: none;
  }

  /* Show hamburger on desktop too — centered-title hides the nav links */
  .site-nav.has-centered-title :global(.mobile-menu-root) {
    display: flex;
    align-items: center;
  }

  .site-nav.has-centered-title .nav-brand {
    margin-right: 0;
  }

  .nav-centered-title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--ink);
    white-space: nowrap;
    margin: 0;
  }

  .nav-cs-sigma {
    font-family: var(--font-display);
    color: var(--promo-text);
    font-size: inherit;
  }

  /* ── Mobile menu root (hidden on desktop) — :global because Preact island renders inside <astro-island> without scoped attr */
  :global(.mobile-menu-root) {
    display: none;
  }

  /* Mobile menu trigger always needs these styles — they only show when .mobile-menu-root is visible */
  :global(.mobile-menu-trigger) {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    width: 28px;
    height: 28px;
    background: transparent;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s;
  }

  :global(.mobile-menu-trigger:hover) {
    background: var(--surface-interactive);
  }

  /* Dropdown menu — positioned below nav regardless of height */
  :global(.mobile-menu-dropdown) {
    position: absolute;
    top: 100%;
    left: var(--space-lg);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 6px;
    min-width: 160px;
    box-shadow: var(--shadow-card);
    animation: mobileMenuIn 0.15s ease-out;
  }

  :global(.mobile-menu-link) {
    display: block;
    padding: 8px 14px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-soft);
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.12s, background 0.12s;
  }

  :global(.mobile-menu-link:hover) {
    color: var(--ink);
    background: var(--surface-interactive);
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .site-nav {
      padding: 0 var(--space-lg);
      height: 48px;
      gap: 2px;
    }

    /* Kill the brand margin so σ and hamburger sit tight, same as /verse/ */
    .nav-brand {
      margin-right: 0;
    }

    /* Hide desktop nav links on tablet/mobile */
    .nav-links {
      display: none;
    }

    /* Show mobile hamburger menu — sits tight next to σ like /verse/ */
    :global(.mobile-menu-root) {
      display: flex;
      align-items: center;
    }
  }

  /* Mobile dropdown animation — keyframes are always global */
  @keyframes mobileMenuIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Tight mobile ── */
  @media (max-width: 480px) {
    .site-nav {
      padding: 0 var(--space-md);
    }

    :global(.mobile-menu-dropdown) {
      left: var(--space-md);
    }
  }
</style>
