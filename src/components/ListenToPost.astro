---
/**
 * ListenToPost — "narrated by Nova" audio player.
 *
 * Renders an <audio> element + caption if a matching MP3 exists at
 * `public/audio/blog/<slug>.mp3`. Otherwise renders nothing (graceful
 * fallback so posts without audio just look normal).
 *
 * Audio source of truth: meetsoma/media/blog/audio/<slug>.mp3
 * Generated via: meetsoma/media/tools/voice/render-blog.py <slug>
 * Synced via:    meetsoma/media/tools/voice/sync-audio.sh
 *
 * s01-8c5230 — initial.
 */
import { existsSync, statSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { dirname, resolve } from 'node:path';

export interface Props {
  /** Blog post slug (filename without .md). */
  slug: string;
}

const { slug } = Astro.props;

const __dirname = dirname(fileURLToPath(import.meta.url));
// components/ → src/ → repos/website/ → public/audio/blog/<slug>.mp3
const audioPath = resolve(__dirname, '../../public/audio/blog', `${slug}.mp3`);

const hasAudio = existsSync(audioPath);
let sizeKB: number | null = null;
if (hasAudio) {
  try {
    sizeKB = Math.round(statSync(audioPath).size / 1024);
  } catch {
    sizeKB = null;
  }
}

const src = `/audio/blog/${slug}.mp3`;
---

{hasAudio && (
  <figure class="listen-to-post">
    <figcaption class="listen-caption">
      <span class="listen-label">🎧 Listen</span>
      <span class="listen-by">narrated by Nova</span>
      {sizeKB !== null && <span class="listen-size">· {sizeKB < 1024 ? `${sizeKB} KB` : `${(sizeKB/1024).toFixed(1)} MB`}</span>}
    </figcaption>
    <audio controls preload="none" src={src}>
      <a href={src}>Download audio</a>
    </audio>
  </figure>
)}

<style>
  .listen-to-post {
    margin: 2rem 0 2.5rem;
    padding: 1rem 1.25rem;
    border: 1px solid rgba(100, 148, 190, 0.2);
    border-radius: 10px;
    background: rgba(20, 25, 34, 0.4);
    backdrop-filter: blur(8px);
  }

  .listen-caption {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    font-size: 0.875rem;
    font-family: 'SF Mono', ui-monospace, monospace;
    color: #9dafc4;
  }

  .listen-label {
    color: #7cb2d4;
    font-weight: 600;
  }

  .listen-by {
    color: #c9d1d9;
    font-style: italic;
  }

  .listen-size {
    color: #647080;
    font-size: 0.8125rem;
  }

  .listen-to-post audio {
    width: 100%;
    height: 36px;
  }

  /* Style the native audio controls on WebKit — at least the outer shell */
  .listen-to-post audio::-webkit-media-controls-panel {
    background: rgba(13, 17, 23, 0.8);
  }
</style>
