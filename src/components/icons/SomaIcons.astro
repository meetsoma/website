---
/**
 * Soma Icon Set — SVG icons for the four layers + utility icons.
 * Uses currentColor for theme compatibility. Designed at 24x24 viewBox.
 *
 * Core four (Lucide-based, stroke-style):
 *   extensions → plug     | system hooks, plugins
 *   skills     → book-open| knowledge, learned expertise
 *   muscles    → zap      | fast reflex, learned patterns
 *   protocols  → dna      | behavioral DNA, rules
 *   memory     → atom     | persistent state, orbital
 *
 * Utility (custom):
 *   sigma, terminal, you, pi
 *
 * Source audit: browser-tools/examples/icon-audit-soma-2026-03-11.html
 */

interface Props {
  name: 'extensions' | 'skills' | 'muscles' | 'protocols' | 'memory' | 'sigma' | 'terminal' | 'you' | 'pi' | 'dna';
  size?: number;
  class?: string;
}

const { name, size = 24, class: className = '' } = Astro.props;
---

{/* Extensions — plug (system hooks, plugins) */}
{name === 'extensions' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="M12 22v-5"/>
    <path d="M15 8V2"/>
    <path d="M17 8a1 1 0 0 1 1 1v4a4 4 0 0 1-4 4h-4a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1z"/>
    <path d="M9 8V2"/>
  </svg>
)}

{/* Skills — book-open (knowledge, learned expertise) */}
{name === 'skills' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="M12 7v14"/>
    <path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/>
  </svg>
)}

{/* Muscles — zap (fast reflex, learned patterns) */}
{name === 'muscles' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>
  </svg>
)}

{/* Protocols — dna (behavioral DNA, rules) */}
{name === 'protocols' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="m10 16 1.5 1.5"/>
    <path d="m14 8-1.5-1.5"/>
    <path d="M15 2c-1.798 1.998-2.518 3.995-2.807 5.993"/>
    <path d="m16.5 10.5 1 1"/>
    <path d="m17 6-2.891-2.891"/>
    <path d="M2 15c6.667-6 13.333 0 20-6"/>
    <path d="m20 9 .891.891"/>
    <path d="M3.109 14.109 4 15"/>
    <path d="m6.5 12.5 1 1"/>
    <path d="m7 18 2.891 2.891"/>
    <path d="M9 22c1.798-1.998 2.518-3.995 2.807-5.993"/>
  </svg>
)}

{/* Memory — atom (persistent state, orbital motif) */}
{name === 'memory' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <circle cx="12" cy="12" r="1"/>
    <path d="M20.2 20.2c2.04-2.03.02-7.36-4.5-11.9-4.54-4.52-9.87-6.54-11.9-4.5-2.04 2.03-.02 7.36 4.5 11.9 4.54 4.52 9.87 6.54 11.9 4.5Z"/>
    <path d="M15.7 15.7c4.52-4.54 6.54-9.87 4.5-11.9-2.03-2.04-7.36-.02-11.9 4.5-4.52 4.54-6.54 9.87-4.5 11.9 2.03 2.04 7.36.02 11.9-4.5Z"/>
  </svg>
)}

{/* Sigma — the Soma mark (custom) */}
{name === 'sigma' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M18 5H7l5 7-5 7h11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
)}

{/* Terminal — command prompt (custom) */}
{name === 'terminal' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <rect x="3" y="4" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/>
    <path d="M7 15h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M7 9l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
)}

{/* You — user/person (custom) */}
{name === 'you' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5"/>
    <path d="M4 20c0-3.3 3.6-6 8-6s8 2.7 8 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  </svg>
)}

{/* Pi — the runtime framework (custom) */}
{name === 'pi' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M6 7h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    <path d="M9 7v10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    <path d="M15 7v10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    <path d="M6 7c0-1.7 1.3-3 3-3h6c1.7 0 3 1.3 3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
  </svg>
)}

{/* DNA — alias for protocols (backward compat) */}
{name === 'dna' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <path d="m10 16 1.5 1.5"/>
    <path d="m14 8-1.5-1.5"/>
    <path d="M15 2c-1.798 1.998-2.518 3.995-2.807 5.993"/>
    <path d="m16.5 10.5 1 1"/>
    <path d="m17 6-2.891-2.891"/>
    <path d="M2 15c6.667-6 13.333 0 20-6"/>
    <path d="m20 9 .891.891"/>
    <path d="M3.109 14.109 4 15"/>
    <path d="m6.5 12.5 1 1"/>
    <path d="m7 18 2.891 2.891"/>
    <path d="M9 22c1.798-1.998 2.518-3.995 2.807-5.993"/>
  </svg>
)}
