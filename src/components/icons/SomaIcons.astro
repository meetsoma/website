---
/**
 * Soma Icon Set — Custom SVG icons for the four layers + utility icons.
 * Uses currentColor for theme compatibility. Designed at 24x24 viewBox.
 * Follows Soma brand: soft curves, orbital motifs, minimal strokes.
 */

interface Props {
  name: 'extensions' | 'skills' | 'muscles' | 'protocols' | 'memory' | 'sigma' | 'terminal' | 'you' | 'pi' | 'dna';
  size?: number;
  class?: string;
}

const { name, size = 24, class: className = '' } = Astro.props;
---

{/* Extensions — interlocking hooks (system hooks) */}
{name === 'extensions' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M7 8V6a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <rect x="3" y="8" width="18" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
    <path d="M12 12v4m-2-2h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  </svg>
)}

{/* Skills — open book / knowledge */}
{name === 'skills' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M12 7c-2.8-2-5.3-2-8-1v11c2.7-1 5.2-1 8 1m0-11c2.8-2 5.3-2 8-1v11c-2.7-1-5.2-1-8 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
)}

{/* Muscles — strength / circular target (learned pattern) */}
{name === 'muscles' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
    <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.5"/>
    <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
  </svg>
)}

{/* Protocols — helix / behavioral DNA */}
{name === 'protocols' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M8 4c0 3 8 5 8 8s-8 5-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M16 4c0 3-8 5-8 8s8 5 8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="7" y1="8" x2="17" y2="8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
    <line x1="7" y1="12" x2="17" y2="12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
    <line x1="7" y1="16" x2="17" y2="16" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
  </svg>
)}

{/* Memory — sparkle / persistent state */}
{name === 'memory' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M12 2v4m0 12v4M2 12h4m12 0h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M5.6 5.6l2.8 2.8m7.2 7.2l2.8 2.8M18.4 5.6l-2.8 2.8M8.4 15.6l-2.8 2.8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.6"/>
    <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
  </svg>
)}

{/* Sigma — the Soma mark */}
{name === 'sigma' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M18 5H7l5 7-5 7h11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
)}

{/* Terminal — command prompt */}
{name === 'terminal' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <rect x="3" y="4" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/>
    <path d="M7 15h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M7 9l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
)}

{/* You — user/person */}
{name === 'you' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5"/>
    <path d="M4 20c0-3.3 3.6-6 8-6s8 2.7 8 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  </svg>
)}

{/* Pi — the runtime framework */}
{name === 'pi' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M6 7h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    <path d="M9 7v10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    <path d="M15 7v10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    <path d="M6 7c0-1.7 1.3-3 3-3h6c1.7 0 3 1.3 3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
  </svg>
)}

{/* DNA — alias for protocols (backward compat) */}
{name === 'dna' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M8 4c0 3 8 5 8 8s-8 5-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M16 4c0 3-8 5-8 8s8 5 8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="7" y1="8" x2="17" y2="8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
    <line x1="7" y1="12" x2="17" y2="12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
    <line x1="7" y1="16" x2="17" y2="16" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>
  </svg>
)}
