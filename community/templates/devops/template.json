{
  "name": "devops",
  "description": "Ops-focused agent for deployment, CI/CD, and infrastructure work — verify before deploy, automate everything",
  "author": "meetsoma",
  "version": "1.0.0",
  "tier": "official",
  "requires": {
    "protocols": ["breath-cycle", "git-identity", "frontmatter-standard"],
    "muscles": [],
    "skills": []
  },
  "settings": {
    "protocols": {
      "warmThreshold": 3,
      "hotThreshold": 8,
      "maxHeat": 15,
      "decayRate": 1,
      "maxBreadcrumbsInPrompt": 8,
      "maxFullProtocolsInPrompt": 3
    },
    "muscles": {
      "tokenBudget": 2000,
      "maxFull": 2,
      "maxDigest": 6,
      "fullThreshold": 5,
      "digestThreshold": 1
    },
    "heat": {
      "autoDetect": true,
      "autoDetectBump": 2,
      "pinBump": 5
    }
  }
}
