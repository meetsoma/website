{
  "name": "writer",
  "description": "Writing-focused agent for technical content, blogging, and documentation — accuracy first, honest voice",
  "author": "meetsoma",
  "version": "1.0.0",
  "tier": "official",
  "requires": {
    "protocols": ["breath-cycle", "frontmatter-standard"],
    "muscles": [],
    "skills": []
  },
  "settings": {
    "protocols": {
      "warmThreshold": 3,
      "hotThreshold": 8,
      "maxHeat": 15,
      "decayRate": 1,
      "maxBreadcrumbsInPrompt": 6,
      "maxFullProtocolsInPrompt": 2
    },
    "muscles": {
      "tokenBudget": 4000,
      "maxFull": 4,
      "maxDigest": 10,
      "fullThreshold": 3,
      "digestThreshold": 1
    },
    "heat": {
      "autoDetect": true,
      "autoDetectBump": 1,
      "pinBump": 5
    }
  }
}
