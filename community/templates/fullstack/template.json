{
  "name": "fullstack",
  "description": "Daily driver for web and app development \u2014 precision editing, safe operations, task awareness, doc hygiene, test discipline",
  "author": "meetsoma",
  "version": "1.0.0",
  "tier": "official",
  "requires": {
    "protocols": [
      "tool-discipline",
      "quality-standards",
      "working-style",
      "git-identity",
      "pre-flight",
      "correction-capture",
      "detection-triggers",
      "pattern-evolution"
    ],
    "muscles": [
      "precision-edit",
      "safe-file-ops",
      "task-tooling",
      "test-hygiene",
      "doc-hygiene",
      "micro-exhale"
    ],
    "skills": [],
    "automations": []
  },
  "settings": {
    "protocols": {
      "warmThreshold": 3,
      "hotThreshold": 8,
      "maxHeat": 15,
      "decayRate": 1,
      "maxBreadcrumbsInPrompt": 10,
      "maxFullProtocolsInPrompt": 3
    },
    "muscles": {
      "tokenBudget": 3000,
      "maxFull": 3,
      "maxDigest": 10,
      "fullThreshold": 4,
      "digestThreshold": 1
    },
    "heat": {
      "autoDetect": true,
      "autoDetectBump": 1,
      "pinBump": 5
    }
  },
  "heatPresets": {
    "precision-edit": 8,
    "safe-file-ops": 5,
    "task-tooling": 5,
    "test-hygiene": 3,
    "doc-hygiene": 3,
    "micro-exhale": 3
  },
  "notes": "The all-rounder. precision-edit starts hot because every dev session involves editing. Pattern-evolution and correction-capture help the agent learn your codebase conventions over time. doc-hygiene prevents plan rot on longer projects.",
  "scripts": [
    "soma-code",
    "soma-reflect",
    "soma-plans",
    "soma-focus"
  ]
}
