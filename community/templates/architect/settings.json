{
  "$schema": "https://soma.gravicity.ai/schemas/settings-v1.json",
  "root": "{{ROOT}}",
  "memory": {
    "flowUp": false
  },
  "protocols": {
    "warmThreshold": 2,
    "hotThreshold": 5,
    "maxHeat": 15,
    "decayRate": 1,
    "maxBreadcrumbsInPrompt": 12,
    "maxFullProtocolsInPrompt": 4
  },
  "muscles": {
    "tokenBudget": 3000,
    "maxFull": 3,
    "maxDigest": 10,
    "fullThreshold": 4,
    "digestThreshold": 1
  },
  "heat": {
    "autoDetect": true,
    "autoDetectBump": 1,
    "pinBump": 5
  }
}
